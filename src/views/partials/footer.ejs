<% const _cp = typeof currentPath === 'string' ? currentPath : ''; %>
<% const _pathOnly = _cp.split('?')[0].split('#')[0]; %>
<% const _isActive = (href) => {
  if (!href) return false;
  if (href === '/') return _pathOnly === '/';
  return _pathOnly === href || _pathOnly.startsWith(href + '/');
}; %>

<% const _showMobileNav = !/^\/(admin|commande)(\/|$)/.test(_cp); %>
<% const _showCookieBanner = !/^\/(admin)(\/|$)/.test(_cp); %>

<% if (_showMobileNav) { %>
  <nav aria-label="Navigation rapide" class="fixed bottom-0 left-0 right-0 z-50 md:hidden">
    <div class="mx-auto max-w-[1440px] px-3 pb-[env(safe-area-inset-bottom)]">
