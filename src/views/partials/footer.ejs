          <span class="material-symbols-rounded text-[22px]">home</span>
          <span>Accueil</span>
        </a>

        <a class="flex flex-col items-center justify-center gap-1 py-3 text-[10px] font-semibold transition-colors <%= _isActive('/rechercher') ? 'text-primary' : 'text-slate-600' %>" href="/rechercher" <% if (_isActive('/rechercher')) { %>aria-current="page"<% } %>>
          <span class="material-symbols-rounded text-[22px]">search</span>
          <span>Rechercher</span>
        </a>

        <a class="flex flex-col items-center justify-center gap-1 py-3 text-[10px] font-semibold transition-colors <%= _isActive('/produits') ? 'text-primary' : 'text-slate-600' %>" href="/produits" <% if (_isActive('/produits')) { %>aria-current="page"<% } %>>
          <span class="material-symbols-rounded text-[22px]">storefront</span>
          <span>Catalogue</span>
        </a>

        <a class="relative flex flex-col items-center justify-center gap-1 py-3 text-[10px] font-semibold transition-colors <%= _isActive('/panier') ? 'text-primary' : 'text-slate-600' %>" href="/panier" <% if (_isActive('/panier')) { %>aria-current="page"<% } %>>
          <span class="material-symbols-rounded text-[22px]">shopping_cart</span>
          <% const _cartCount = typeof cartItemCount !== 'undefined' ? Number(cartItemCount) : 0; %>
          <% if (_cartCount > 0) { %>
            <span class="absolute top-2 right-3 flex h-5 min-w-5 items-center justify-center rounded-full bg-primary px-1.5 text-[10px] font-bold text-white"><%= _cartCount > 99 ? '99+' : _cartCount %></span>
          <% } %>
          <span>Panier</span>
        </a>

        <a class="flex flex-col items-center justify-center gap-1 py-3 text-[10px] font-semibold transition-colors <%= _isActive('/compte') ? 'text-primary' : 'text-slate-600' %>" href="/compte" <% if (_isActive('/compte')) { %>aria-current="page"<% } %>>
          <span class="material-symbols-rounded text-[22px]">account_circle</span>
          <span>Compte</span>
        </a>
      </div>
    </div>
  </nav>
<% } %>

<% if (_showCookieBanner) { %>
  <div id="cookieBanner" class="fixed bottom-4 left-4 right-4 z-50 hidden">
    <div class="mx-auto max-w-[1440px]">
      <div class="rounded-2xl border border-slate-200 bg-white shadow-xl p-4 md:p-5 flex flex-col md:flex-row md:items-center gap-3">
        <div class="text-xs md:text-sm text-slate-700 font-semibold">
          Ce site utilise des cookies nécessaires au fonctionnement (ex: panier, connexion). Tu peux accepter ou refuser les cookies non essentiels.
        </div>
        <div class="flex gap-2 md:ml-auto">
          <button id="cookieRefuse" type="button" class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2 text-xs font-black uppercase tracking-wider text-slate-700 hover:bg-slate-50 transition">Refuser</button>
          <button id="cookieAccept" type="button" class="inline-flex items-center justify-center rounded-xl bg-primary px-4 py-2 text-xs font-black uppercase tracking-wider text-white hover:bg-red-700 transition">Accepter</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    (function () {
      function getCookie(name) {
        var m = document.cookie.match(new RegExp('(?:^|; )' + name.replace(/([.$?*|{}()\\[\\]\\\\\/\\+^])/g, '\\$1') + '=([^;]*)'));
        return m ? decodeURIComponent(m[1]) : '';
      }

      function setCookie(name, value, maxAgeSeconds) {
        var parts = [name + '=' + encodeURIComponent(value), 'Path=/', 'SameSite=Lax'];
        if (typeof maxAgeSeconds === 'number') parts.push('Max-Age=' + String(maxAgeSeconds));
        document.cookie = parts.join('; ');
      }

      var existing = getCookie('cp_cookie_consent');
      var banner = document.getElementById('cookieBanner');
      if (!banner) return;
      if (existing) return;

      banner.classList.remove('hidden');

      var acceptBtn = document.getElementById('cookieAccept');
      var refuseBtn = document.getElementById('cookieRefuse');

      function close() {
        banner.classList.add('hidden');
      }

      if (acceptBtn) {
        acceptBtn.addEventListener('click', function () {
          setCookie('cp_cookie_consent', 'accepted', 15552000);
          close();
        });
      }

      if (refuseBtn) {
        refuseBtn.addEventListener('click', function () {
          setCookie('cp_cookie_consent', 'refused', 15552000);
          close();
        });
      }
    })();
  </script>
<% } %>
</div>

</body></html>
