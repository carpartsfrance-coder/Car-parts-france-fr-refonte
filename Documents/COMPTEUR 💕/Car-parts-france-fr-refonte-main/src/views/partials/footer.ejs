          <path d="M16.01 3.2c-7.07 0-12.8 5.73-12.8 12.8 0 2.25.58 4.45 1.69 6.39L3.2 28.8l6.58-1.67a12.75 12.75 0 0 0 6.22 1.61h.01c7.06 0 12.79-5.73 12.79-12.8 0-3.43-1.34-6.65-3.77-9.07A12.72 12.72 0 0 0 16.01 3.2Zm0 23.35h-.01a10.6 10.6 0 0 1-5.39-1.47l-.39-.23-3.9.99 1.04-3.8-.26-.39a10.6 10.6 0 1 1 8.91 4.9Z" />
