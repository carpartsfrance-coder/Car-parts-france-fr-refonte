<% const _isActive = (href) => {
  if (!href) return false;
  if (href === '/') return _pathOnly === '/';
  return _pathOnly === href || _pathOnly.startsWith(href + '/');
}; %>
<% const _showWhatsAppButton = !/^\/(admin|panier|commande)(\/|$)/.test(_pathOnly); %>
<% const _whatsAppMessage = encodeURIComponent("Bonjour, j'ai une question sur une pièce..."); %>
