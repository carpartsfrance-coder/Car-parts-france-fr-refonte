<!DOCTYPE html>
<html lang="fr"><head><meta charset="utf-8"><title><%= subject || 'CarParts France — SAV' %></title></head>
<body style="margin:0;padding:0;background:#f9fafb;font-family:-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;color:#1a1a1a;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f9fafb;padding:24px 0;">
    <tr><td align="center">
      <table width="560" cellpadding="0" cellspacing="0" style="background:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 6px 24px rgba(0,0,0,.06);">
        <tr><td style="background:#ec1313;padding:20px 28px;color:#fff;">
          <div style="font-weight:700;font-size:18px;">CarParts France — Service après-vente</div>
        </td></tr>
        <tr><td style="padding:28px;line-height:1.55;font-size:15px;">
          <%- body %>
          <div style="margin-top:24px;padding:14px;background:#fef2f2;border:1px solid #fecaca;border-radius:8px;font-size:12px;color:#991b1b;text-align:center;">
            ⚠️ <strong>Merci de ne pas répondre à cet email.</strong><br>
            Pour nous écrire, utilisez votre <strong>espace client</strong> ci-dessus.
          </div>
          <p style="margin-top:28px;color:#64748b;font-size:13px;">— L'équipe CarParts France<br>sav@carpartsfrance.fr · 04 65 84 54 88</p>
        </td></tr>
        <tr><td style="background:#f1f5f9;padding:14px 28px;color:#64748b;font-size:11px;">
          Demande SAV n° <strong><%= ticket.numero %></strong>
          <% if (ticket.vehicule && ticket.vehicule.vin) { %> · VIN <%= ticket.vehicule.vin %><% } %>
        </td></tr>
      </table>
    </td></tr>
  </table>
</body></html>
