<% const baseUrl = (process.env.SITE_URL || 'https://carpartsfrance.fr').replace(/\/$/, ''); %>
<% const v = (ticket && ticket.vehicule) || {}; %>
<% const body = `
  <p>Bonjour <strong>${(ticket.client && ticket.client.nom) || ''}</strong>,</p>
  <p>Votre demande SAV <strong>${ticket.numero}</strong> est bien enregistrée. Vous trouverez en pièce jointe le justificatif <strong>"Acceptation des CGV SAV"</strong> horodaté pour vos archives.</p>

  <div style="margin:18px 0;padding:16px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;font-size:14px;color:#0f172a;">
    <div style="font-weight:700;margin-bottom:6px;">Récapitulatif</div>
    <div><strong>N° dossier :</strong> ${ticket.numero}</div>
    ${ticket.numeroCommande ? `<div><strong>Commande :</strong> ${ticket.numeroCommande}</div>` : ''}
    ${ticket.pieceType ? `<div><strong>Pièce :</strong> ${ticket.pieceType}</div>` : ''}
    ${(v.marque || v.modele) ? `<div><strong>Véhicule :</strong> ${[v.marque, v.modele, v.annee].filter(Boolean).join(' ')}</div>` : ''}
    ${v.vin ? `<div><strong>VIN :</strong> ${v.vin}</div>` : ''}
    ${v.kilometrage ? `<div><strong>Kilométrage :</strong> ${v.kilometrage} km</div>` : ''}
  </div>

  <div style="margin:18px 0;padding:14px;background:#ecfdf5;border-left:4px solid #10b981;border-radius:8px;font-size:14px;">
    <strong>Prochaines étapes :</strong>
    <ul style="margin:8px 0 0 18px;padding:0;">
      <li>Notre équipe pré-qualifie votre dossier sous <strong>48 h ouvrées</strong>.</li>
      <li>Vous recevrez par email un bon de retour gratuit pour nous envoyer la pièce.</li>
      <li>Une fois en atelier, l'analyse sur banc démarre sous 5 jours ouvrés.</li>
    </ul>
  </div>

  <p style="margin:18px 0;text-align:center;">
    <a href="${baseUrl}/sav/confirmation/${encodeURIComponent(ticket.numero)}"
       style="display:inline-block;padding:12px 22px;background:#ec1313;color:#fff;text-decoration:none;border-radius:10px;font-weight:700;">
      Accéder à mon dossier
    </a>
  </p>

  <p style="font-size:13px;color:#475569;">
    Vous pouvez également retrouver tous vos dossiers SAV depuis votre compte client :
    <a href="${baseUrl}/compte/sav" style="color:#ec1313;">${baseUrl}/compte/sav</a>
  </p>
` %>
<%- include('./_layout', { ticket: ticket, subject: 'Votre demande SAV est enregistrée', body: body }) %>
