<%- include('../partials/head') %>
<link rel="stylesheet" href="/css/sav.css">
<%- include('../partials/header') %>

<main class="sav-module flex-1 bg-background-light text-slate-900">
  <div class="mx-auto max-w-2xl px-4 sm:px-6 py-8 sm:py-12">

    <header class="mb-6 text-center">
      <div class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10 mb-3">
        <span class="material-symbols-rounded text-primary text-3xl" aria-hidden="true">build_circle</span>
      </div>
      <h1 class="text-2xl sm:text-3xl font-bold tracking-tight">Ouvrir une demande SAV</h1>
      <p class="mt-2 text-sm sm:text-base text-slate-600">
        Quelques étapes pour démarrer. <strong>Vous ne payez rien à l'ouverture.</strong>
      </p>
    </header>

    <!-- Stepper -->
    <nav class="sav-stepper mb-8" role="progressbar" aria-valuemin="1" aria-valuemax="5" aria-valuenow="1" id="sav-progress">
      <% [1,2,3,4,5].forEach(function(i) { %>
        <div class="sav-stepper__step <%= i === 1 ? 'sav-stepper__step--current' : '' %>" data-step-indicator="<%= i %>">
          <div class="sav-stepper__bar"></div>
          <span><%= ['Commande','Pièce','Symptômes','Documents','Engagement'][i-1] %></span>
        </div>
      <% }) %>
    </nav>

    <div id="sav-restore-banner" class="hidden mb-4 rounded-xl border border-emerald-200 bg-emerald-50 p-3 text-sm text-emerald-900 flex items-start gap-2">
      <span class="material-symbols-rounded" aria-hidden="true">restore</span>
      <div class="flex-1">
        <strong>Brouillon restauré.</strong> Vos réponses ont été récupérées. Merci de redéposer vos documents (ils ne sont pas conservés).
        <button type="button" class="ml-2 underline" onclick="try{localStorage.removeItem('sav:draft:v1')}catch(_){};location.reload()">Recommencer à zéro</button>
      </div>
    </div>

    <form id="sav-form" class="space-y-6" novalidate>

      <!-- ============== ÉTAPE 1 : Identification commande ============== -->
      <section class="sav-form-step sav-form-step--active sav-status-card" data-step="1" aria-labelledby="step1-title">
        <h2 id="step1-title" class="text-lg font-semibold mb-1">1. Retrouvons votre commande</h2>

        <% if (currentUser) { %>
          <p class="text-sm text-slate-600 mb-4">Bonjour <strong><%= currentUser.firstName || currentUser.email %></strong>, sélectionnez la commande concernée.</p>
          <input type="hidden" id="email" name="email" value="<%= currentUser.email %>">
          <input type="hidden" id="clientNom" name="clientNom" value="<%= [currentUser.firstName, currentUser.lastName].filter(Boolean).join(' ') || currentUser.email %>">

          <% if (!eligibleOrders || eligibleOrders.length === 0) { %>
            <div class="rounded-xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">
              Aucune commande éligible (payée, &lt; 24 mois) trouvée sur votre compte.
              Si vous pensez qu'il s'agit d'une erreur, écrivez-nous à <a class="underline" href="mailto:sav@carpartsfrance.fr">sav@carpartsfrance.fr</a>.
            </div>
          <% } else { %>
            <div class="space-y-2" role="radiogroup" aria-label="Commandes éligibles">
              <% eligibleOrders.forEach(function(o) { %>
                <label class="flex items-start gap-3 rounded-xl border border-slate-300 p-3 cursor-pointer hover:border-primary has-[:checked]:border-primary has-[:checked]:bg-primary/5 transition-colors">
                  <input type="radio" name="numeroCommande" value="<%= o.number %>" class="mt-1 accent-primary" required>
                  <div class="flex-1 min-w-0">
                    <div class="font-semibold text-slate-900"><%= o.number %></div>
                    <div class="text-xs text-slate-500"><%= new Date(o.date).toLocaleDateString('fr-FR') %></div>
                    <% if (o.label) { %><div class="text-sm text-slate-700 truncate"><%= o.label %></div><% } %>
                  </div>
                </label>
              <% }) %>
            </div>
            <p class="sav-error mt-2 text-sm text-red-600 hidden" data-error-for="numeroCommande"></p>
          <% } %>
        <% } else { %>
          <div class="mb-4 rounded-xl border border-primary/20 bg-primary/5 p-3 text-sm text-slate-700 flex items-center gap-2">
            <span class="material-symbols-rounded text-primary" aria-hidden="true">account_circle</span>
            <span>Vous avez un compte&nbsp;?
              <a href="/login?redirect=%2Fsav" class="font-semibold text-primary underline">Connectez-vous</a>
              pour retrouver vos commandes automatiquement.</span>
          </div>
          <p class="text-sm text-slate-600 mb-4">Indiquez l'email utilisé lors de l'achat et votre numéro de commande.</p>

          <div class="space-y-4">
            <div>
              <label for="email" class="block text-sm font-medium text-slate-700 mb-1">Email de la commande</label>
              <input id="email" name="email" type="email" autocomplete="email" required
                     class="w-full rounded-xl border border-slate-300 px-4 py-3 text-base min-h-[44px] focus:border-primary focus:ring-2 focus:ring-primary/20"
                     placeholder="vous@exemple.com">
              <p class="sav-error mt-1 text-sm text-red-600 hidden" data-error-for="email"></p>
            </div>
            <div>
              <label for="numeroCommande" class="block text-sm font-medium text-slate-700 mb-1">Numéro de commande</label>
              <input id="numeroCommande" name="numeroCommande" type="text" required
                     class="w-full rounded-xl border border-slate-300 px-4 py-3 text-base min-h-[44px] focus:border-primary focus:ring-2 focus:ring-primary/20"
                     placeholder="CPF-2025-XXXX">
              <p class="sav-error mt-1 text-sm text-red-600 hidden" data-error-for="numeroCommande"></p>
            </div>
          </div>
        <% } %>

        <div class="mt-6 flex justify-end">
          <button type="button" data-action="next" data-validate-step="1"
                  class="inline-flex items-center gap-2 rounded-xl bg-primary hover:bg-primary-hover text-white font-semibold px-5 py-3 min-h-[44px] focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 transition-colors">
            Continuer
            <span class="material-symbols-rounded" aria-hidden="true">arrow_forward</span>
          </button>
        </div>
      </section>

      <!-- ============== ÉTAPE 2 : Pré-qualification ============== -->
      <section class="sav-form-step sav-status-card" data-step="2" aria-labelledby="step2-title" hidden>
        <h2 id="step2-title" class="text-lg font-semibold mb-1">2. Votre pièce et son montage</h2>
        <p class="text-sm text-slate-600 mb-4">Ces informations sont indispensables pour démarrer l'analyse.</p>

        <div class="space-y-4">
          <div>
            <label for="pieceType" class="block text-sm font-medium text-slate-700 mb-1">Type de pièce</label>
            <select id="pieceType" name="pieceType" required
                    class="w-full rounded-xl border border-slate-300 px-4 py-3 text-base min-h-[44px] bg-white">
              <option value="">— Sélectionner —</option>
              <option value="mecatronique_dq200">Mécatronique DQ200</option>
              <option value="mecatronique_dq250">Mécatronique DQ250</option>
              <option value="mecatronique_dq381">Mécatronique DQ381</option>
              <option value="mecatronique_dq500">Mécatronique DQ500</option>
              <option value="boite_transfert">Boîte de transfert</option>
              <option value="pont">Pont</option>
              <option value="differentiel">Différentiel</option>
              <option value="haldex">Haldex</option>
              <option value="reducteur">Réducteur</option>
              <option value="cardan">Cardan</option>
              <option value="autre">Autre</option>
            </select>
            <p class="sav-error mt-1 text-sm text-red-600 hidden" data-error-for="pieceType"></p>
          </div>

          <div>
            <label for="dateMontage" class="block text-sm font-medium text-slate-700 mb-1">Date du montage</label>
            <input id="dateMontage" name="dateMontage" type="date" required
                   class="w-full rounded-xl border border-slate-300 px-4 py-3 text-base min-h-[44px]">
            <p class="sav-error mt-1 text-sm text-red-600 hidden" data-error-for="dateMontage"></p>
          </div>

          <div>
            <label for="garageNom" class="block text-sm font-medium text-slate-700 mb-1">Nom du garage qui a effectué le montage</label>
            <input id="garageNom" name="garageNom" type="text" required
                   class="w-full rounded-xl border border-slate-300 px-4 py-3 text-base min-h-[44px]">
            <p class="sav-error mt-1 text-sm text-red-600 hidden" data-error-for="garageNom"></p>
          </div>

          <fieldset class="rounded-xl border border-slate-200 p-4">
            <legend class="px-2 text-sm font-medium text-slate-700">Le réglage de base a-t-il été effectué après le montage ?</legend>
            <div class="mt-2 space-y-2">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="reglageBase" value="oui" class="text-primary focus:ring-primary">
                <span>Oui, le garage a effectué le réglage de base</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="reglageBase" value="non" class="text-primary focus:ring-primary">
                <span>Non</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="reglageBase" value="inconnu" class="text-primary focus:ring-primary">
                <span>Je ne sais pas</span>
              </label>
            </div>
            <div id="reglageBaseAlert" class="mt-3 hidden rounded-xl border border-amber-200 bg-amber-50 p-3 text-sm text-amber-800" role="alert">
              <strong>Le réglage de base est obligatoire</strong> après montage d'une mécatronique.
              Demandez à votre garage de l'effectuer avant de poursuivre. Sans cette étape, votre demande ne pourra pas être traitée.
            </div>
          </fieldset>
        </div>

        <div class="mt-6 flex items-center justify-between gap-2">
          <button type="button" data-action="prev" class="text-slate-600 hover:text-slate-900 font-medium">← Retour</button>
          <button type="button" data-action="next" data-validate-step="2"
                  class="inline-flex items-center gap-2 rounded-xl bg-primary hover:bg-primary-hover text-white font-semibold px-5 py-3 min-h-[44px]">
            Continuer
            <span class="material-symbols-rounded" aria-hidden="true">arrow_forward</span>
          </button>
        </div>
      </section>

      <!-- ============== ÉTAPE 3 : Symptômes ============== -->
      <section class="sav-form-step sav-status-card" data-step="3" aria-labelledby="step3-title" hidden>
        <h2 id="step3-title" class="text-lg font-semibold mb-1">3. Que se passe-t-il avec votre pièce ?</h2>
        <p class="text-sm text-slate-600 mb-4">Plus vous êtes précis, plus l'analyse sur banc sera rapide.</p>

        <fieldset class="space-y-2 mb-4">
          <legend class="text-sm font-medium text-slate-700 mb-2">Symptômes observés (cochez tout ce qui s'applique)</legend>
          <% const symptomes = ["À-coups en passage de rapport","Patinage","Refus de passer une vitesse","Mode dégradé","Voyant moteur","Bruit anormal","Fuite d'huile","Surchauffe"]; %>
          <% symptomes.forEach(function(s) { %>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" name="symptomes" value="<%= s %>" class="rounded text-primary focus:ring-primary">
              <span class="text-sm"><%= s %></span>
            </label>
          <% }) %>
        </fieldset>

        <div class="space-y-4">
          <div>
            <label for="codesDefaut" class="block text-sm font-medium text-slate-700 mb-1">Codes défaut OBD</label>
            <textarea id="codesDefaut" name="codesDefaut" rows="3"
                      class="w-full rounded-xl border border-slate-300 px-4 py-3 text-base"
                      placeholder="Ex : P173E, P0841…"></textarea>
          </div>
          <div>
            <label for="photoObd" class="block text-sm font-medium text-slate-700 mb-1">Photo de la lecture OBD <span class="text-red-600">*</span></label>
            <label class="sav-dropzone" for="photoObd">
              <span class="material-symbols-rounded text-3xl" aria-hidden="true">add_a_photo</span>
              <span class="text-sm">Touchez pour ajouter une photo (min 1)</span>
              <span class="text-xs text-slate-500" data-filename></span>
            </label>
            <input id="photoObd" name="photoObd" type="file" accept="image/*" class="sr-only" required>
            <p class="sav-error mt-1 text-sm text-red-600 hidden" data-error-for="photoObd"></p>
          </div>
          <div>
            <label for="description" class="block text-sm font-medium text-slate-700 mb-1">Décrivez ce que vous constatez</label>
            <textarea id="description" name="description" rows="4"
                      class="w-full rounded-xl border border-slate-300 px-4 py-3 text-base"
                      placeholder="Quand cela arrive, depuis quand, dans quelles conditions…"></textarea>
          </div>
        </div>

        <div class="mt-6 flex items-center justify-between gap-2">
          <button type="button" data-action="prev" class="text-slate-600 hover:text-slate-900 font-medium">← Retour</button>
          <button type="button" data-action="next" data-validate-step="3"
                  class="inline-flex items-center gap-2 rounded-xl bg-primary hover:bg-primary-hover text-white font-semibold px-5 py-3 min-h-[44px]">
            Continuer
            <span class="material-symbols-rounded" aria-hidden="true">arrow_forward</span>
          </button>
        </div>
      </section>

      <!-- ============== ÉTAPE 4 : Documents ============== -->
      <section class="sav-form-step sav-status-card" data-step="4" aria-labelledby="step4-title" hidden>
        <h2 id="step4-title" class="text-lg font-semibold mb-1">4. Les documents indispensables</h2>
        <p class="text-sm text-slate-600 mb-4">Sans ces documents, nous ne pouvons pas démarrer l'analyse.</p>

        <div class="space-y-4">
          <div>
            <label for="factureGarage" class="block text-sm font-medium text-slate-700 mb-1">Facture du garage de montage <span class="text-red-600">*</span></label>
            <label class="sav-dropzone" for="factureGarage">
              <span class="material-symbols-rounded text-3xl" aria-hidden="true">description</span>
              <span class="text-sm">PDF ou photo de la facture</span>
              <span class="text-xs text-slate-500" data-filename></span>
            </label>
            <input id="factureGarage" name="factureGarage" type="file" accept="application/pdf,image/*" class="sr-only" required>
            <p class="sav-error mt-1 text-sm text-red-600 hidden" data-error-for="factureGarage"></p>
          </div>

          <div>
            <label for="photoPiece" class="block text-sm font-medium text-slate-700 mb-1">Photo de la pièce installée <span class="text-red-600">*</span></label>
            <label class="sav-dropzone" for="photoPiece">
              <span class="material-symbols-rounded text-3xl" aria-hidden="true">photo_camera</span>
              <span class="text-sm">Pièce visible sur le véhicule</span>
              <span class="text-xs text-slate-500" data-filename></span>
            </label>
            <input id="photoPiece" name="photoPiece" type="file" accept="image/*" class="sr-only" required>
            <p class="sav-error mt-1 text-sm text-red-600 hidden" data-error-for="photoPiece"></p>
          </div>

          <p class="text-sm text-slate-600 mb-2">VIN <strong>ou</strong> plaque — un seul des deux suffit.</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="vin" class="block text-sm font-medium text-slate-700 mb-1">VIN (17 caractères)</label>
              <input id="vin" name="vin" type="text" maxlength="17"
                     class="w-full rounded-xl border border-slate-300 px-4 py-3 text-base uppercase">
              <p class="sav-error mt-1 text-sm text-red-600 hidden" data-error-for="vin"></p>
            </div>
            <div>
              <label for="immatriculation" class="block text-sm font-medium text-slate-700 mb-1">Immatriculation</label>
              <input id="immatriculation" name="immatriculation" type="text"
                     class="w-full rounded-xl border border-slate-300 px-4 py-3 text-base uppercase">
              <p class="sav-error mt-1 text-sm text-red-600 hidden" data-error-for="immatriculation"></p>
            </div>
          </div>
        </div>

        <div class="mt-6 flex items-center justify-between gap-2">
          <button type="button" data-action="prev" class="text-slate-600 hover:text-slate-900 font-medium">← Retour</button>
          <button type="button" data-action="next" data-validate-step="4"
                  class="inline-flex items-center gap-2 rounded-xl bg-primary hover:bg-primary-hover text-white font-semibold px-5 py-3 min-h-[44px]">
            Continuer
            <span class="material-symbols-rounded" aria-hidden="true">arrow_forward</span>
          </button>
        </div>
      </section>

      <!-- ============== ÉTAPE 5 : Engagement ============== -->
      <section class="sav-form-step sav-status-card" data-step="5" aria-labelledby="step5-title" hidden>
        <h2 id="step5-title" class="text-lg font-semibold mb-1">5. Comment ça se passe ensuite</h2>
        <p class="text-sm text-slate-600 mb-4">Lisez attentivement, nous voulons être totalement transparents.</p>

        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 sm:p-5 text-sm leading-relaxed space-y-3">
          <p class="font-semibold text-slate-900">Une analyse sur banc est nécessaire pour diagnostiquer votre pièce.</p>
          <ul class="space-y-2">
            <li class="flex gap-2"><span class="material-symbols-rounded text-emerald-600 text-base mt-0.5" aria-hidden="true">check_circle</span><span><strong>Si l'analyse confirme un défaut produit :</strong> 0 € pour vous, échange ou remboursement intégral, retour offert.</span></li>
            <li class="flex gap-2"><span class="material-symbols-rounded text-amber-600 text-base mt-0.5" aria-hidden="true">euro</span><span><strong>Si l'analyse conclut à un mauvais montage, une usure normale ou une pièce non défectueuse :</strong> facture de 149 € TTC à votre charge.</span></li>
            <li class="flex gap-2"><span class="material-symbols-rounded text-sky-600 text-base mt-0.5" aria-hidden="true">payments</span><span><strong>Vous ne payez RIEN à l'ouverture</strong> de votre demande.</span></li>
            <li class="flex gap-2"><span class="material-symbols-rounded text-sky-600 text-base mt-0.5" aria-hidden="true">local_shipping</span><span><strong>Retour vers nous : offert.</strong></span></li>
            <li class="flex gap-2"><span class="material-symbols-rounded text-amber-600 text-base mt-0.5" aria-hidden="true">local_shipping</span><span><strong>Retour vers vous en cas d'analyse négative : 25 € TTC.</strong></span></li>
          </ul>
        </div>

        <div class="mt-5 space-y-3">
          <label class="flex items-start gap-3 cursor-pointer">
            <input id="cgvSav" type="checkbox" required class="mt-1 rounded text-primary focus:ring-primary">
            <span class="text-sm">J'ai lu et j'accepte les <a href="/legal/cgv-sav" target="_blank" class="text-primary underline">conditions générales du SAV</a>.</span>
          </label>
          <label class="flex items-start gap-3 cursor-pointer">
            <input id="accept149" type="checkbox" required class="mt-1 rounded text-primary focus:ring-primary">
            <span class="text-sm">J'accepte que <strong>149 € TTC</strong> me soient facturés <strong>uniquement</strong> si l'analyse conclut que la pièce n'est pas défectueuse.</span>
          </label>
          <p class="sav-error text-sm text-red-600 hidden" data-error-for="acceptances"></p>
        </div>

        <div class="mt-6 flex items-center justify-between gap-2">
          <button type="button" data-action="prev" class="text-slate-600 hover:text-slate-900 font-medium">← Retour</button>
          <button type="submit" id="sav-submit"
                  class="inline-flex items-center gap-2 rounded-xl bg-primary hover:bg-primary-hover text-white font-semibold px-5 py-3 min-h-[44px] disabled:opacity-60 disabled:cursor-not-allowed">
            <span data-submit-label>Envoyer ma demande</span>
            <span class="material-symbols-rounded animate-spin hidden" data-submit-spinner aria-hidden="true">progress_activity</span>
          </button>
        </div>
      </section>

    </form>
  </div>

  <div class="sav-toast-root" id="sav-toast-root" aria-live="polite"></div>
</main>

<script src="/js/sav-form.js?v=3" defer></script>

<%- include('../partials/footer') %>
