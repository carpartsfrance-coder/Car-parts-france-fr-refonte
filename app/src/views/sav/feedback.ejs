<%- include('../partials/head') %>
<link rel="stylesheet" href="/css/sav.css?v=7">
<%- include('../partials/header') %>

<main class="sav-module flex-1 bg-background-light text-slate-900">
  <div class="mx-auto max-w-xl px-4 sm:px-6 py-8 sm:py-12">

    <% if (!ticket) { %>
      <div class="rounded-2xl border border-amber-200 bg-amber-50 p-6 text-amber-900 text-center">
        <h1 class="text-xl font-bold">Dossier introuvable</h1>
        <p class="mt-2 text-sm">Aucun dossier SAV ne correspond au numéro <strong><%= numero %></strong>.</p>
      </div>
    <% } else if (sent || completed) { %>
      <div class="text-center">
        <div class="inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-emerald-100 mb-3">
          <span class="material-symbols-rounded text-emerald-600 text-4xl" aria-hidden="true">favorite</span>
        </div>
        <h1 class="text-2xl sm:text-3xl font-bold tracking-tight">Merci pour votre retour&nbsp;!</h1>
        <p class="mt-2 text-base text-slate-600">
          <% if (ticket.reviewFeedback && ticket.reviewFeedback.note >= 4) { %>
            Nous vous redirigeons vers Google pour partager votre avis publiquement…
          <% } else { %>
            Votre retour nous est précieux. L'équipe va le traiter rapidement pour s'améliorer.
          <% } %>
        </p>
        <a href="/" class="mt-6 inline-block text-primary underline">Retour à l'accueil</a>
      </div>
    <% } else { %>
      <header class="text-center mb-6">
        <h1 class="text-2xl sm:text-3xl font-bold tracking-tight">Comment s'est passée votre expérience&nbsp;?</h1>
        <p class="mt-2 text-base text-slate-600">Dossier <strong class="font-mono"><%= ticket.numero %></strong> — votre avis nous aide à nous améliorer.</p>
      </header>

      <form method="POST" action="/sav/feedback/<%= encodeURIComponent(ticket.numero) %>" class="rounded-2xl border border-slate-200 bg-white p-6 space-y-5">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-3">Votre note globale</label>
          <div class="flex justify-center gap-2" id="sav-stars">
            <% for (var i = 1; i <= 5; i++) { %>
              <label class="cursor-pointer">
                <input type="radio" name="note" value="<%= i %>" required class="sr-only peer">
                <span class="text-4xl text-slate-300 peer-checked:text-amber-400 hover:text-amber-300 transition" data-star>★</span>
              </label>
            <% } %>
          </div>
        </div>

        <div>
          <label for="comment" class="block text-sm font-medium text-slate-700 mb-1">Un commentaire (facultatif)</label>
          <textarea id="comment" name="comment" rows="4" maxlength="2000"
                    class="w-full rounded-xl border border-slate-300 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20"
                    placeholder="Qu'est-ce qui vous a plu ou déplu ?"></textarea>
        </div>

        <button class="w-full rounded-xl bg-primary hover:bg-primary-hover text-white font-semibold px-5 py-3">Envoyer mon retour</button>

        <p class="text-xs text-slate-500 text-center">
          Si vous mettez 4 étoiles ou plus, nous vous proposerons de partager votre avis sur Google.
        </p>
      </form>
    <% } %>

  </div>
</main>

<script>
  // Coloration progressive des étoiles
  (function(){
    var stars = document.querySelectorAll('#sav-stars [data-star]');
    var radios = document.querySelectorAll('#sav-stars input[type="radio"]');
    function paint(n) {
      stars.forEach(function(s, i) {
        s.classList.toggle('text-amber-400', i < n);
        s.classList.toggle('text-slate-300', i >= n);
      });
    }
    radios.forEach(function(r, i) {
      r.parentElement.addEventListener('mouseenter', function() { paint(i + 1); });
      r.addEventListener('change', function() { paint(i + 1); });
    });
  })();
</script>

<%- include('../partials/footer') %>
