<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="flex-1 bg-slate-50">
  <div class="mx-auto max-w-[1440px] px-4 md:px-10 py-6 md:py-10">

    <%/* ── Stepper ───────────────────────────────────────────── */%>
    <nav class="flex items-center justify-center gap-2 sm:gap-4 text-[10px] sm:text-xs font-black uppercase tracking-widest text-slate-400" aria-label="Étapes de commande">
      <a href="/panier" class="flex items-center gap-2 sm:gap-3 hover:text-slate-600 transition">
        <span class="w-7 h-7 rounded-full bg-slate-900 text-white flex items-center justify-center text-xs">
          <span class="material-symbols-outlined text-[16px]">check</span>
        </span>
        <span class="hidden sm:inline text-slate-500">Panier</span>
      </a>
      <div class="h-px w-6 sm:w-10 bg-slate-300"></div>
      <div class="flex items-center gap-2 sm:gap-3">
        <span class="w-7 h-7 rounded-full bg-primary text-white flex items-center justify-center text-xs">2</span>
        <span class="text-primary">Livraison</span>
      </div>
      <div class="h-px w-6 sm:w-10 bg-slate-200"></div>
      <div class="flex items-center gap-2 sm:gap-3">
        <span class="w-7 h-7 rounded-full bg-slate-200 text-slate-400 flex items-center justify-center text-xs">3</span>
        <span class="hidden sm:inline">Paiement</span>
      </div>
    </nav>

    <% if (errorMessage) { %>
      <div class="mt-6 rounded-xl border border-red-200 bg-red-50 p-4 text-red-900 flex items-start gap-3">
        <span class="material-symbols-outlined text-red-500 mt-0.5">error</span>
        <div>
          <div class="font-bold text-sm">Une erreur est survenue</div>
          <div class="mt-1 text-sm"><%= errorMessage %></div>
        </div>
      </div>
    <% } %>

    <div class="mt-6 md:mt-8 grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8">

      <%/* ── Main Column ────────────────────────────────────── */%>
      <section class="lg:col-span-8 space-y-6">

        <%/* ── Shipping Method ──────────────────────────────── */%>
        <div class="bg-white rounded-2xl border border-slate-200 p-5 md:p-6 shadow-sm">
          <div class="flex items-center gap-3">
            <span class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
              <span class="material-symbols-outlined text-primary text-[18px]">local_shipping</span>
            </span>
            <div>
              <h2 class="text-base font-black text-slate-900">Mode de livraison</h2>
              <p class="text-sm text-slate-500">Sélectionnez une option pour continuer</p>
            </div>
          </div>

          <form action="/commande/livraison" class="mt-5 space-y-3" method="POST" id="shipping-form">
            <% shippingMethods.forEach((m) => { %>
              <% const icon = m.id === 'domicile' ? 'local_shipping' : 'store'; %>
              <label class="group block rounded-xl border-2 p-4 cursor-pointer transition-all duration-200" data-shipping-label>
                <div class="flex items-center gap-4">
                  <div class="relative flex-shrink-0">
                    <input class="peer sr-only" name="shippingMethod" type="radio" value="<%= m.id %>" <%= selectedShippingMethod === m.id ? 'checked' : '' %> />
                    <div class="w-5 h-5 rounded-full border-2 border-slate-300 peer-checked:border-primary flex items-center justify-center transition">
                      <div class="w-2.5 h-2.5 rounded-full bg-primary scale-0 peer-checked:scale-100 transition-transform"></div>
                    </div>
                  </div>
                  <div class="w-10 h-10 rounded-xl bg-slate-50 flex items-center justify-center flex-shrink-0">
                    <span class="material-symbols-outlined text-slate-400"><%= icon %></span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="font-bold text-slate-900"><%= m.title %></div>
                    <div class="text-sm text-slate-500"><%= m.description %></div>
                  </div>
                  <div class="font-black text-sm whitespace-nowrap <%= m.priceCents === 0 ? 'text-green-600' : 'text-slate-900' %>">
                    <%= m.priceCents === 0 ? 'Gratuit' : (m.priceCents / 100).toFixed(2).replace('.', ',') + ' €' %>
                  </div>
                </div>
              </label>
            <% }) %>

            <% if (guestCheckout) { %>
              <%/* ── Guest Checkout ──────────────────────────── */%>
              <div class="mt-6 pt-6 border-t border-slate-100">
                <div class="flex items-center gap-3 mb-5">
                  <span class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center flex-shrink-0">
                    <span class="material-symbols-outlined text-slate-500 text-[18px]">person</span>
                  </span>
                  <div>
                    <h2 class="text-base font-black text-slate-900">Vos informations</h2>
                    <p class="text-sm text-slate-500">Un compte sera créé automatiquement après votre commande</p>
                  </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div class="sm:col-span-2">
                    <label class="block text-sm font-semibold text-slate-700" for="email">Adresse email *</label>
                    <input class="mt-1.5 w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm focus:border-primary focus:ring-1 focus:ring-primary transition" id="email" name="email" required type="email" placeholder="votre@email.com" value="<%= guestForm ? guestForm.email : '' %>" />
                  </div>

                  <div>
                    <label class="block text-sm font-semibold text-slate-700" for="firstName">Prénom *</label>
                    <input class="mt-1.5 w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm focus:border-primary focus:ring-1 focus:ring-primary transition" id="firstName" name="firstName" required type="text" placeholder="Jean" value="<%= guestForm ? guestForm.firstName : '' %>" />
                  </div>

                  <div>
                    <label class="block text-sm font-semibold text-slate-700" for="lastName">Nom *</label>
                    <input class="mt-1.5 w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm focus:border-primary focus:ring-1 focus:ring-primary transition" id="lastName" name="lastName" required type="text" placeholder="Dupont" value="<%= guestForm ? guestForm.lastName : '' %>" />
                  </div>

                  <div class="sm:col-span-2">
                    <label class="block text-sm font-semibold text-slate-700" for="line1">Adresse *</label>
                    <input class="mt-1.5 w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm focus:border-primary focus:ring-1 focus:ring-primary transition" id="line1" name="line1" required type="text" placeholder="12 rue de la Paix" value="<%= guestForm ? guestForm.line1 : '' %>" />
                  </div>

                  <div class="sm:col-span-2">
                    <label class="block text-sm font-semibold text-slate-700" for="line2">Complément d'adresse</label>
                    <input class="mt-1.5 w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm focus:border-primary focus:ring-1 focus:ring-primary transition" id="line2" name="line2" type="text" placeholder="Bâtiment, étage, code..." value="<%= guestForm ? guestForm.line2 : '' %>" />
                  </div>

                  <div>
                    <label class="block text-sm font-semibold text-slate-700" for="postalCode">Code postal *</label>
                    <input class="mt-1.5 w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm focus:border-primary focus:ring-1 focus:ring-primary transition" id="postalCode" name="postalCode" required type="text" placeholder="75001" maxlength="5" value="<%= guestForm ? guestForm.postalCode : '' %>" data-autocomplete-postal />
                  </div>

                  <div>
                    <label class="block text-sm font-semibold text-slate-700" for="city">Ville *</label>
                    <input class="mt-1.5 w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm focus:border-primary focus:ring-1 focus:ring-primary transition" id="city" name="city" required type="text" placeholder="Paris" value="<%= guestForm ? guestForm.city : '' %>" data-autocomplete-city />
                  </div>

                  <div>
                    <label class="block text-sm font-semibold text-slate-700" for="phone">Téléphone *</label>
                    <input class="mt-1.5 w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm focus:border-primary focus:ring-1 focus:ring-primary transition" id="phone" name="phone" required type="tel" placeholder="06 12 34 56 78" value="<%= guestForm ? guestForm.phone : '' %>" />
                  </div>

                  <div>
                    <label class="block text-sm font-semibold text-slate-700" for="country">Pays</label>
                    <input class="mt-1.5 w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm focus:border-primary focus:ring-1 focus:ring-primary transition" id="country" name="country" type="text" value="<%= guestForm ? guestForm.country : 'France' %>" />
                  </div>
                </div>

                <div class="mt-5 rounded-lg bg-slate-50 border border-slate-100 p-3 text-sm text-slate-500 flex items-center gap-2">
                  <span class="material-symbols-outlined text-[16px]">info</span>
                  La facturation utilisera la même adresse que la livraison.
                </div>
              </div>
            <% } else { %>
              <%/* ── Shipping Address (logged in) ────────────── */%>
              <div class="mt-6 pt-6 border-t border-slate-100">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                  <div class="flex items-center gap-3">
                    <span class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                      <span class="material-symbols-outlined text-primary text-[18px]">home</span>
                    </span>
                    <div>
                      <h2 class="text-base font-black text-slate-900">Adresse de livraison</h2>
                      <p class="text-sm text-slate-500">Choisissez ou ajoutez une adresse</p>
                    </div>
                  </div>
                  <button class="inline-flex items-center gap-1.5 rounded-lg bg-primary text-white px-4 py-2 text-xs font-bold hover:bg-red-700 transition" id="open-add-address" type="button">
                    <span class="material-symbols-outlined text-[16px]">add</span>
                    Nouvelle adresse
                  </button>
                </div>

                <% if (!addresses || addresses.length === 0) { %>
                  <div class="mt-4 rounded-xl border-2 border-dashed border-slate-200 p-6 text-center">
                    <span class="material-symbols-outlined text-slate-300 text-[32px]">location_on</span>
                    <div class="mt-2 font-bold text-slate-700">Aucune adresse enregistrée</div>
                    <div class="mt-1 text-sm text-slate-500">Ajoutez votre première adresse de livraison</div>
                  </div>
                <% } else { %>
                  <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
                    <% addresses.forEach((a) => { %>
                      <label class="relative rounded-xl border-2 p-4 cursor-pointer transition-all duration-200 <%= selectedAddressId === String(a._id) ? 'border-primary bg-primary/5 shadow-sm' : 'border-slate-200 hover:border-slate-300 bg-white' %>" data-address-label>
                        <div class="flex items-start gap-3">
                          <div class="relative flex-shrink-0 mt-0.5">
                            <input class="peer sr-only" name="addressId" type="radio" value="<%= a._id %>" <%= selectedAddressId === String(a._id) ? 'checked' : '' %> />
                            <div class="w-5 h-5 rounded-full border-2 border-slate-300 peer-checked:border-primary flex items-center justify-center transition">
                              <div class="w-2.5 h-2.5 rounded-full bg-primary scale-0 peer-checked:scale-100 transition-transform"></div>
                            </div>
                          </div>
                          <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2">
                              <span class="font-bold text-sm text-slate-900 truncate"><%= a.label || 'Adresse' %></span>
                              <% if (a.isDefault) { %>
                                <span class="inline-flex items-center rounded-full bg-primary/10 text-primary px-2 py-0.5 text-[9px] font-bold uppercase tracking-wider flex-shrink-0">Défaut</span>
                              <% } %>
                            </div>
                            <% if (a.fullName) { %><div class="mt-1 text-sm text-slate-700"><%= a.fullName %></div><% } %>
                            <div class="mt-0.5 text-sm text-slate-500"><%= a.line1 %></div>
                            <% if (a.line2) { %><div class="text-sm text-slate-500"><%= a.line2 %></div><% } %>
                            <div class="text-sm text-slate-500"><%= a.postalCode %> <%= a.city %></div>
                            <% if (a.phone) { %><div class="mt-1 text-xs text-slate-400"><%= a.phone %></div><% } %>
                          </div>
                        </div>
                        <a href="/compte/adresses?returnTo=%2Fcommande%2Flivraison" class="absolute top-3 right-3 text-slate-400 hover:text-primary transition" title="Modifier" onclick="event.stopPropagation()">
                          <span class="material-symbols-outlined text-[18px]">edit</span>
                        </a>
                      </label>
                    <% }) %>
                  </div>
                <% } %>
              </div>

              <%/* ── Billing Address ─────────────────────────── */%>
              <div class="mt-6 pt-6 border-t border-slate-100">
                <div class="flex items-center gap-3 mb-4">
                  <span class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center flex-shrink-0">
                    <span class="material-symbols-outlined text-slate-500 text-[18px]">receipt_long</span>
                  </span>
                  <h2 class="text-base font-black text-slate-900">Adresse de facturation</h2>
                </div>

                <label class="flex items-center gap-3 cursor-pointer select-none p-3 rounded-lg bg-slate-50 border border-slate-100" for="billingSameAsShipping">
                  <input class="rounded border-slate-300 text-primary focus:ring-primary w-4 h-4" id="billingSameAsShipping" name="billingSameAsShipping" type="checkbox" <%= billingSameAsShipping ? 'checked' : '' %> />
                  <span class="text-sm font-semibold text-slate-700">Identique à l'adresse de livraison</span>
                </label>

                <div class="mt-3 text-sm text-slate-500 flex items-center gap-2" id="billing-same-hint" <%= billingSameAsShipping ? '' : 'style="display:none"' %>>
                  <span class="material-symbols-outlined text-[16px] text-green-500">check_circle</span>
                  La facture sera envoyée à votre adresse de livraison.
                </div>

                <% if (addresses && addresses.length) { %>
                  <div class="mt-3 grid grid-cols-1 md:grid-cols-2 gap-3" id="billing-address-grid" <%= billingSameAsShipping ? 'style="display:none"' : '' %>>
                    <% addresses.forEach((a) => { %>
                      <label class="relative rounded-xl border-2 p-4 cursor-pointer transition-all duration-200 bg-white <%= selectedBillingAddressId === String(a._id) ? 'border-primary bg-primary/5 shadow-sm' : 'border-slate-200 hover:border-slate-300' %>">
                        <div class="flex items-start gap-3">
                          <div class="relative flex-shrink-0 mt-0.5">
                            <input class="peer sr-only" name="billingAddressId" type="radio" value="<%= a._id %>" <%= selectedBillingAddressId === String(a._id) ? 'checked' : '' %> <%= billingSameAsShipping ? 'disabled' : '' %> />
                            <div class="w-5 h-5 rounded-full border-2 border-slate-300 peer-checked:border-primary flex items-center justify-center transition">
                              <div class="w-2.5 h-2.5 rounded-full bg-primary scale-0 peer-checked:scale-100 transition-transform"></div>
                            </div>
                          </div>
                          <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2">
                              <span class="font-bold text-sm text-slate-900 truncate"><%= a.label || 'Adresse' %></span>
                              <% if (a.isDefault) { %>
                                <span class="inline-flex items-center rounded-full bg-primary/10 text-primary px-2 py-0.5 text-[9px] font-bold uppercase tracking-wider flex-shrink-0">Défaut</span>
                              <% } %>
                            </div>
                            <% if (a.fullName) { %><div class="mt-1 text-sm text-slate-700"><%= a.fullName %></div><% } %>
                            <div class="mt-0.5 text-sm text-slate-500"><%= a.line1 %></div>
                            <% if (a.line2) { %><div class="text-sm text-slate-500"><%= a.line2 %></div><% } %>
                            <div class="text-sm text-slate-500"><%= a.postalCode %> <%= a.city %></div>
                          </div>
                        </div>
                      </label>
                    <% }) %>
                  </div>
                <% } else { %>
                  <div class="mt-3 text-sm text-slate-500" id="billing-address-grid" <%= billingSameAsShipping ? 'style="display:none"' : '' %>>Aucune adresse disponible.</div>
                <% } %>
              </div>
            <% } %>

            <%/* ── Navigation Buttons (desktop) ────────────── */%>
            <div class="mt-8 pt-6 border-t border-slate-100 hidden md:flex items-center justify-between">
              <a class="inline-flex items-center gap-2 text-sm font-semibold text-slate-500 hover:text-slate-700 transition" href="/panier">
                <span class="material-symbols-outlined text-[18px]">arrow_back</span>
                Retour au panier
              </a>
              <button class="inline-flex items-center justify-center gap-2 rounded-xl bg-primary text-white px-8 py-3.5 font-black text-sm hover:bg-red-700 transition shadow-lg shadow-primary/20" type="submit">
                Continuer vers le paiement
                <span class="font-normal opacity-80">(<%= (totalCents / 100).toFixed(2).replace('.', ',') %> €)</span>
                <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
              </button>
            </div>
          </form>
        </div>
      </section>

      <%/* ── Sidebar: Order Summary ─────────────────────────── */%>
      <aside class="lg:col-span-4">
        <div class="bg-white rounded-2xl border border-slate-200 p-5 md:p-6 sticky top-24 shadow-sm">
          <div class="flex items-center justify-between">
            <h3 class="font-black text-slate-900">Votre commande</h3>
            <span class="text-xs font-semibold text-slate-400"><%= items.reduce((s, i) => s + i.quantity, 0) %> article<%= items.reduce((s, i) => s + i.quantity, 0) > 1 ? 's' : '' %></span>
          </div>

          <div class="mt-4 space-y-3 max-h-64 overflow-y-auto pr-1">
            <% items.forEach((it) => { %>
              <div class="flex items-center gap-3">
                <div class="relative w-14 h-14 rounded-lg overflow-hidden bg-slate-50 flex items-center justify-center flex-shrink-0 border border-slate-100">
                  <% if (it.product.imageUrl) { %>
                    <img alt="<%= it.product.name %>" class="w-full h-full object-cover" src="<%= it.product.imageUrl %>" loading="lazy" />
                  <% } else { %>
                    <span class="material-symbols-outlined text-slate-300">inventory_2</span>
                  <% } %>
                  <span class="absolute -top-1 -right-1 w-5 h-5 rounded-full bg-slate-700 text-white text-[10px] font-bold flex items-center justify-center"><%= it.quantity %></span>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="text-sm font-semibold text-slate-900 truncate"><%= it.product.name %></div>
                  <% if (it.optionsSummary) { %>
                    <div class="text-xs text-slate-400 truncate"><%= it.optionsSummary %></div>
                  <% } %>
                </div>
                <div class="text-sm font-bold text-slate-900 whitespace-nowrap"><%= (it.lineTotalCents / 100).toFixed(2).replace('.', ',') %> €</div>
              </div>
            <% }) %>
          </div>

          <div class="mt-4 pt-4 border-t border-slate-100 space-y-2 text-sm">
            <div class="flex items-center justify-between">
              <span class="text-slate-500">Sous-total</span>
              <span class="font-semibold text-slate-700"><%= ((typeof itemsSubtotalCents !== 'undefined' ? itemsSubtotalCents : itemsTotalCents) / 100).toFixed(2).replace('.', ',') %> €</span>
            </div>

            <% if (typeof clientDiscountCents !== 'undefined' && clientDiscountCents > 0) { %>
              <div class="flex items-center justify-between text-green-600">
                <span>Remise client (<%= typeof clientDiscountPercent !== 'undefined' ? String(clientDiscountPercent).replace('.', ',') : '' %>%)</span>
                <span class="font-semibold">- <%= (clientDiscountCents / 100).toFixed(2).replace('.', ',') %> €</span>
              </div>
            <% } %>

            <% if (typeof promoDiscountCents !== 'undefined' && promoDiscountCents > 0) { %>
              <div class="flex items-center justify-between text-green-600">
                <span>Code promo<% if (typeof promoCode !== 'undefined' && promoCode) { %> (<%= promoCode %>)<% } %></span>
                <span class="font-semibold">- <%= (promoDiscountCents / 100).toFixed(2).replace('.', ',') %> €</span>
              </div>
            <% } %>

            <% if ((typeof clientDiscountCents !== 'undefined' && clientDiscountCents > 0) || (typeof promoDiscountCents !== 'undefined' && promoDiscountCents > 0)) { %>
              <div class="flex items-center justify-between">
                <span class="text-slate-500">Sous-total après remise</span>
                <span class="font-semibold text-slate-700"><%= ((typeof itemsTotalAfterDiscountCents !== 'undefined' ? itemsTotalAfterDiscountCents : itemsTotalCents) / 100).toFixed(2).replace('.', ',') %> €</span>
              </div>
            <% } %>

            <div class="flex items-center justify-between">
              <span class="text-slate-500">Livraison</span>
              <span class="font-semibold <%= shippingCostCents === 0 ? 'text-green-600' : 'text-slate-700' %>"><%= shippingCostCents === 0 ? 'Gratuit' : (shippingCostCents / 100).toFixed(2).replace('.', ',') + ' €' %></span>
            </div>
          </div>

          <div class="mt-4 pt-4 border-t-2 border-slate-200 flex items-center justify-between">
            <span class="font-black text-slate-900">Total TTC</span>
            <span class="text-primary font-black text-xl"><%= (totalCents / 100).toFixed(2).replace('.', ',') %> €</span>
          </div>

          <div class="mt-4 flex items-center gap-2 text-xs text-slate-400">
            <span class="material-symbols-outlined text-[14px]">lock</span>
            Paiement 100% sécurisé
          </div>
        </div>
      </aside>
    </div>
  </div>
</main>

<%/* ── Sticky Mobile CTA (above mobile bottom nav ~70px) ──── */%>
<div class="md:hidden fixed bottom-[70px] inset-x-0 bg-white border-t border-slate-200 px-4 py-3 shadow-[0_-4px_20px_rgba(0,0,0,0.08)] z-40">
  <div class="flex items-center justify-between mb-2">
    <span class="text-sm font-semibold text-slate-600">Total TTC</span>
    <span class="text-lg font-black text-primary"><%= (totalCents / 100).toFixed(2).replace('.', ',') %> €</span>
  </div>
  <button form="shipping-form" class="w-full rounded-xl bg-primary text-white py-3 font-black text-sm hover:bg-red-700 transition flex items-center justify-center gap-2" type="submit">
    Continuer vers le paiement
    <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
  </button>
</div>
<div class="md:hidden h-40"></div><%/* spacer for sticky bar + bottom nav */%>

<%/* ── Add Address Modal ───────────────────────────────────── */%>
<% if (!guestCheckout) { %>
<div id="add-address-modal" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" id="modal-backdrop"></div>
  <div class="absolute inset-y-0 right-0 w-full max-w-lg bg-white shadow-2xl transform translate-x-full transition-transform duration-300 ease-out flex flex-col" id="modal-panel">
    <div class="flex items-center justify-between p-5 border-b border-slate-100">
      <h3 class="text-lg font-black text-slate-900">Nouvelle adresse</h3>
      <button type="button" id="close-modal" class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center hover:bg-slate-200 transition">
        <span class="material-symbols-outlined text-slate-500 text-[20px]">close</span>
      </button>
    </div>

    <form action="/commande/livraison/adresse" class="flex-1 overflow-y-auto p-5" method="POST" id="add-address-form">
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-semibold text-slate-700" for="modal-label">Nom de l'adresse</label>
          <input class="mt-1.5 w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm focus:border-primary focus:ring-1 focus:ring-primary transition" id="modal-label" name="label" type="text" placeholder="Ex : Maison, Bureau, Atelier..." value="<%= form ? form.label : '' %>" />
        </div>

        <div>
          <label class="block text-sm font-semibold text-slate-700" for="modal-fullName">Nom complet</label>
          <input class="mt-1.5 w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm focus:border-primary focus:ring-1 focus:ring-primary transition" id="modal-fullName" name="fullName" type="text" placeholder="Jean Dupont" value="<%= form ? form.fullName : '' %>" />
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-semibold text-slate-700" for="modal-phone">Téléphone</label>
            <input class="mt-1.5 w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm focus:border-primary focus:ring-1 focus:ring-primary transition" id="modal-phone" name="phone" type="tel" placeholder="06 12 34 56 78" value="<%= form ? form.phone : '' %>" />
          </div>
          <div>
            <label class="block text-sm font-semibold text-slate-700" for="modal-country">Pays</label>
            <input class="mt-1.5 w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm focus:border-primary focus:ring-1 focus:ring-primary transition" id="modal-country" name="country" type="text" value="<%= form ? form.country : 'France' %>" />
          </div>
        </div>

        <div>
          <label class="block text-sm font-semibold text-slate-700" for="modal-line1">Adresse *</label>
          <input class="mt-1.5 w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm focus:border-primary focus:ring-1 focus:ring-primary transition" id="modal-line1" name="line1" required type="text" placeholder="12 rue de la Paix" value="<%= form ? form.line1 : '' %>" />
        </div>

        <div>
          <label class="block text-sm font-semibold text-slate-700" for="modal-line2">Complément d'adresse</label>
          <input class="mt-1.5 w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm focus:border-primary focus:ring-1 focus:ring-primary transition" id="modal-line2" name="line2" type="text" placeholder="Bâtiment, étage, code..." value="<%= form ? form.line2 : '' %>" />
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-semibold text-slate-700" for="modal-postalCode">Code postal *</label>
            <input class="mt-1.5 w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm focus:border-primary focus:ring-1 focus:ring-primary transition" id="modal-postalCode" name="postalCode" required type="text" placeholder="75001" maxlength="5" value="<%= form ? form.postalCode : '' %>" data-autocomplete-postal />
          </div>
          <div>
            <label class="block text-sm font-semibold text-slate-700" for="modal-city">Ville *</label>
            <input class="mt-1.5 w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm focus:border-primary focus:ring-1 focus:ring-primary transition" id="modal-city" name="city" required type="text" placeholder="Paris" value="<%= form ? form.city : '' %>" data-autocomplete-city />
          </div>
        </div>

        <label class="flex items-center gap-2 cursor-pointer select-none">
          <input class="rounded border-slate-300 text-primary focus:ring-primary w-4 h-4" id="modal-isDefault" name="isDefault" type="checkbox" <%= form && form.isDefault ? 'checked' : '' %> />
          <span class="text-sm font-semibold text-slate-700">Définir comme adresse par défaut</span>
        </label>
      </div>

      <% if (!dbConnected) { %>
        <div class="mt-5 rounded-lg border border-amber-200 bg-amber-50 p-3 text-amber-800 text-sm flex items-center gap-2">
          <span class="material-symbols-outlined text-[16px]">warning</span>
          Mode démo — impossible d'enregistrer l'adresse.
        </div>
      <% } %>

      <button class="mt-6 w-full rounded-xl bg-primary text-white py-3 font-black text-sm hover:bg-red-700 transition flex items-center justify-center gap-2" type="submit">
        <span class="material-symbols-outlined text-[18px]">add</span>
        Ajouter l'adresse
      </button>
    </form>
  </div>
</div>
<% } %>

<%- include('../partials/footer') %>

<%/* ── Scripts ─────────────────────────────────────────────── */%>
<script>
(function () {
  /* Shipping method label styling */
  var labels = document.querySelectorAll('[data-shipping-label]');
  function updateShippingStyles() {
    labels.forEach(function (label) {
      var radio = label.querySelector('input[type="radio"]');
      if (!radio) return;
      if (radio.checked) {
        label.classList.remove('border-slate-200', 'hover:border-slate-300');
        label.classList.add('border-primary', 'bg-primary/5');
      } else {
        label.classList.remove('border-primary', 'bg-primary/5');
        label.classList.add('border-slate-200', 'hover:border-slate-300');
      }
    });
  }
  labels.forEach(function (l) {
    var r = l.querySelector('input[type="radio"]');
    if (r) r.addEventListener('change', updateShippingStyles);
  });
  updateShippingStyles();

  /* Address card styling */
  var addrLabels = document.querySelectorAll('[data-address-label]');
  function updateAddressStyles() {
    addrLabels.forEach(function (label) {
      var radio = label.querySelector('input[type="radio"]');
      if (!radio) return;
      if (radio.checked) {
        label.classList.remove('border-slate-200', 'hover:border-slate-300', 'bg-white');
        label.classList.add('border-primary', 'bg-primary/5', 'shadow-sm');
      } else {
        label.classList.remove('border-primary', 'bg-primary/5', 'shadow-sm');
        label.classList.add('border-slate-200', 'hover:border-slate-300', 'bg-white');
      }
    });
  }
  addrLabels.forEach(function (l) {
    var r = l.querySelector('input[type="radio"]');
    if (r) r.addEventListener('change', updateAddressStyles);
  });
  updateAddressStyles();
})();
</script>

<script>
(function () {
  /* Modal for add address */
  var modal = document.getElementById('add-address-modal');
  var panel = document.getElementById('modal-panel');
  var backdrop = document.getElementById('modal-backdrop');
  var openBtn = document.getElementById('open-add-address');
  var closeBtn = document.getElementById('close-modal');
  if (!modal || !openBtn) return;

  function openModal() {
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(function () {
      panel.classList.remove('translate-x-full');
      panel.classList.add('translate-x-0');
    });
  }

  function closeModal() {
    panel.classList.remove('translate-x-0');
    panel.classList.add('translate-x-full');
    document.body.style.overflow = '';
    setTimeout(function () { modal.classList.add('hidden'); }, 300);
  }

  openBtn.addEventListener('click', openModal);
  if (closeBtn) closeBtn.addEventListener('click', closeModal);
  if (backdrop) backdrop.addEventListener('click', closeModal);

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
  });
})();
</script>

<script>
(function () {
  /* Billing same as shipping */
  var checkbox = document.getElementById('billingSameAsShipping');
  var grid = document.getElementById('billing-address-grid');
  var hint = document.getElementById('billing-same-hint');
  var shippingRadios = document.querySelectorAll('input[type="radio"][name="addressId"]');
  if (!checkbox) return;

  function getSelectedShippingId() {
    var sel = document.querySelector('input[type="radio"][name="addressId"]:checked');
    return sel ? sel.value : null;
  }

  function syncBillingToShipping() {
    if (!grid) return;
    var sid = getSelectedShippingId();
    if (!sid) return;
    var match = grid.querySelector('input[type="radio"][name="billingAddressId"][value="' + sid + '"]');
    if (match) match.checked = true;
  }

  function update() {
    var same = checkbox.checked;
    if (hint) hint.style.display = same ? '' : 'none';
    if (grid) {
      grid.style.display = same ? 'none' : '';
      var radios = grid.querySelectorAll('input[type="radio"][name="billingAddressId"]');
      radios.forEach(function (r) { r.disabled = same; });
      if (!same) {
        var checked = grid.querySelector('input[type="radio"][name="billingAddressId"]:checked');
        if (!checked) {
          var first = grid.querySelector('input[type="radio"][name="billingAddressId"]');
          if (first) first.checked = true;
        }
      } else {
        syncBillingToShipping();
      }
    }
  }

  checkbox.addEventListener('change', update);
  shippingRadios.forEach(function (r) {
    r.addEventListener('change', function () {
      if (checkbox.checked) syncBillingToShipping();
    });
  });
  update();
})();
</script>

<script>
(function () {
  /* Postal code → city auto-completion (API geo.api.gouv.fr) */
  document.querySelectorAll('[data-autocomplete-postal]').forEach(function (postalInput) {
    var form = postalInput.closest('form');
    if (!form) return;
    var cityInput = form.querySelector('[data-autocomplete-city]');
    if (!cityInput) return;

    postalInput.addEventListener('input', function () {
      var code = postalInput.value.trim();
      if (code.length !== 5 || !/^\d{5}$/.test(code)) return;

      fetch('https://geo.api.gouv.fr/communes?codePostal=' + code + '&fields=nom&limit=5')
        .then(function (res) { return res.ok ? res.json() : []; })
        .then(function (data) {
          if (data.length === 1) {
            cityInput.value = data[0].nom;
          } else if (data.length > 1) {
            /* If multiple cities, fill with first and let user change */
            cityInput.value = data[0].nom;
          }
        })
        .catch(function () { /* silently ignore */ });
    });
  });
})();
</script>
