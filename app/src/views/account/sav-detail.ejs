<%- include('../partials/head') %>
<link rel="stylesheet" href="/css/sav.css?v=5">
<%- include('../partials/header') %>

<main class="flex-1">
  <div class="mx-auto max-w-[1440px] px-4 md:px-10 py-6 sm:py-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8">
      <aside class="lg:col-span-3">
        <%- include('./_sidebar', { active: 'sav' }) %>
      </aside>

      <section class="lg:col-span-9 space-y-4">
        <a href="/compte/sav" class="text-sm text-slate-500 hover:text-slate-900">← Mes demandes SAV</a>

        <% if (!ticket) { %>
          <div class="rounded-2xl border border-amber-200 bg-amber-50 p-6 text-amber-900">
            <h1 class="text-xl font-bold">Dossier introuvable</h1>
            <p class="mt-2 text-sm">Ce dossier n'existe pas ou n'est pas associé à votre compte.</p>
          </div>
        <% } else { %>
          <%- include('../sav/_detail', {
            ticket: ticket,
            STATUTS_LABELS: STATUTS_LABELS,
            postUrl: '/compte/sav/' + encodeURIComponent(ticket.numero) + '/messages',
            sent: (typeof sent !== 'undefined' && sent) || (locals.query && locals.query.sent === '1'),
            error: (typeof error !== 'undefined' ? error : null)
          }) %>
        <% } %>
      </section>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
