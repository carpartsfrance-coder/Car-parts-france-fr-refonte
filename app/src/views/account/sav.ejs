<%- include('../partials/head') %>
<link rel="stylesheet" href="/css/sav.css?v=4">
<%- include('../partials/header') %>

<main class="flex-1">
  <div class="mx-auto max-w-[1440px] px-4 md:px-10 py-6 sm:py-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8">
      <aside class="lg:col-span-3">
        <%- include('./_sidebar', { active: 'sav' }) %>
      </aside>

      <section class="lg:col-span-9 space-y-6">
        <div class="flex items-end justify-between gap-4">
          <div>
            <div class="text-2xl md:text-3xl font-black text-slate-900">Mes demandes SAV</div>
            <div class="mt-1 text-sm text-slate-600">Suivez l'avancement de vos dossiers Service Après-Vente.</div>
          </div>
          <a href="/sav" class="inline-flex items-center gap-2 rounded-xl bg-primary hover:bg-primary-hover text-white font-semibold px-4 py-2.5">
            <span class="material-symbols-outlined">add</span>
            Ouvrir une demande
          </a>
        </div>

        <% var f = (typeof filter !== 'undefined' && filter) || 'tous'; %>
        <div class="flex items-center gap-2 text-sm">
          <a href="/compte/sav?filter=tous"   class="px-3 py-1.5 rounded-full <%= f === 'tous'    ? 'bg-slate-900 text-white' : 'bg-slate-100 text-slate-700 hover:bg-slate-200' %>">Tous</a>
          <a href="/compte/sav?filter=ouverts" class="px-3 py-1.5 rounded-full <%= f === 'ouverts' ? 'bg-slate-900 text-white' : 'bg-slate-100 text-slate-700 hover:bg-slate-200' %>">En cours</a>
          <a href="/compte/sav?filter=clos"    class="px-3 py-1.5 rounded-full <%= f === 'clos'    ? 'bg-slate-900 text-white' : 'bg-slate-100 text-slate-700 hover:bg-slate-200' %>">Clos</a>
        </div>

        <% if (!tickets || !tickets.length) { %>
          <div class="rounded-2xl border border-slate-200 bg-white p-10 text-center text-slate-500">
            <span class="material-symbols-outlined text-5xl text-slate-300">build_circle</span>
            <div class="mt-2 font-semibold">Aucun dossier SAV pour le moment.</div>
            <a href="/sav" class="mt-3 inline-block text-primary underline">Ouvrir une demande</a>
          </div>
        <% } else { %>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <% tickets.forEach(function(t) {
                 var sm = STATUTS_LABELS[t.statut] || [t.statut, 'bg-slate-100 text-slate-700'];
                 var hasUnread = t.lastAdminMessageAt && (!t.lastClientReadAt || new Date(t.lastAdminMessageAt) > new Date(t.lastClientReadAt)); %>
              <a href="/compte/sav/<%= encodeURIComponent(t.numero) %>" class="block rounded-2xl border <%= hasUnread ? 'border-primary ring-1 ring-primary/20' : 'border-slate-200' %> bg-white p-4 hover:border-primary hover:shadow-md transition">
                <div class="flex items-baseline justify-between">
                  <span class="font-mono font-bold text-slate-900"><%= t.numero %></span>
                  <span class="text-xs text-slate-500"><%= new Date(t.createdAt).toLocaleDateString('fr-FR') %></span>
                </div>
                <% if (hasUnread) { %>
                  <div class="mt-1 inline-flex items-center gap-1 rounded-full bg-primary/10 text-primary px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide">
                    ● Nouvelle réponse
                  </div>
                <% } %>
                <div class="mt-1 text-sm text-slate-700"><%= t.pieceType %></div>
                <% if (t.vehicule && (t.vehicule.marque || t.vehicule.modele)) { %>
                  <div class="text-xs text-slate-500"><%= [t.vehicule.marque, t.vehicule.modele, t.vehicule.annee].filter(Boolean).join(' ') %></div>
                <% } %>
                <div class="mt-3 flex items-center justify-between">
                  <span class="px-2 py-0.5 rounded-full text-[11px] font-semibold <%= sm[1] %>"><%= sm[0] %></span>
                  <span class="text-xs text-primary font-semibold">Voir le détail →</span>
                </div>
              </a>
            <% }) %>
          </div>
        <% } %>
      </section>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
