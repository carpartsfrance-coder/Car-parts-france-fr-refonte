<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="flex-1">
  <div class="mx-auto max-w-[1440px] px-4 md:px-10 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <aside class="lg:col-span-3">
        <%- include('./_sidebar', { active: 'commandes' }) %>
      </aside>

      <section class="lg:col-span-9 space-y-8">
        <div class="bg-white rounded-2xl border border-slate-200 p-6">
          <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">
            <div class="flex items-start gap-4">
              <a class="w-10 h-10 rounded-xl border border-slate-200 hover:bg-slate-50 transition flex items-center justify-center" href="/compte/commandes">
                <span class="material-symbols-outlined text-slate-500">arrow_back</span>
              </a>
              <div>
                <div class="text-2xl md:text-3xl font-black text-slate-900">Commande <span class="text-slate-900"><%= order.number %></span></div>
                <div class="mt-1 text-sm text-slate-500">Passée le <%= order.dateTime || order.date %></div>
              </div>
            </div>

            <div class="flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-end">
              <% if (order.hasInvoice && order.invoiceUrl) { %>
                <a class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-3 text-xs font-black uppercase tracking-wider text-slate-700 hover:bg-slate-50 transition" href="<%= order.invoiceUrl %>" target="_blank" rel="noopener">
                  Facture PDF
                </a>
              <% } %>

              <form action="/compte/commandes/<%= order.id %>/racheter" method="POST">
                <button class="inline-flex items-center justify-center rounded-xl bg-primary px-5 py-3 text-xs font-black uppercase tracking-wider text-white hover:bg-red-700 transition" type="submit">
                  Racheter les articles
                </button>
              </form>
            </div>
          </div>

          <div class="mt-8 rounded-2xl <%= order.statusBgClass || 'bg-blue-600' %> p-6 text-white">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
              <div class="flex items-start gap-3">
                <% if (order.statusIcon) { %>
                  <span class="material-symbols-outlined text-2xl text-white/80 mt-1"><%= order.statusIcon %></span>
                <% } %>
                <div>
                  <div class="text-[10px] font-black uppercase tracking-widest text-white/70">Statut actuel</div>
                  <div class="mt-2 text-xl md:text-2xl font-black"><%= order.statusTitle || ('Statut : ' + order.status) %></div>
                  <div class="mt-1 text-sm text-white/90"><%= order.statusSubtitle || '' %></div>
                </div>
              </div>
              <div class="flex flex-col sm:flex-row gap-2">
                <% if (order.statusKey === 'pending_payment') { %>
                  <% if (order.paymentRetryUrl) { %>
                    <a class="inline-flex items-center justify-center rounded-xl bg-white px-5 py-3 text-xs font-black uppercase tracking-wider text-amber-700 hover:bg-slate-50 transition" href="<%= order.paymentRetryUrl %>">
                      <span class="material-symbols-outlined mr-2 text-base">payment</span>
                      Réessayer le paiement
                    </a>
                  <% } %>
                <% } else if (order.statusKey === 'cancelled') { %>
                  <form action="/compte/commandes/<%= order.id %>/racheter" method="POST">
                    <button class="inline-flex items-center justify-center rounded-xl bg-white px-5 py-3 text-xs font-black uppercase tracking-wider text-red-700 hover:bg-slate-50 transition" type="submit">
                      <span class="material-symbols-outlined mr-2 text-base">refresh</span>
                      Recommander
                    </button>
                  </form>
                <% } else if (order.orderType === 'exchange_cloning') { %>
                  <% if (['pending_label', 'label_sent', 'client_piece_in_transit', 'client_piece_received', 'cloning_in_progress', 'cloning_done'].includes(order.cloningStatus) && order.statusKey !== 'shipped' && order.statusKey !== 'delivered') { %>
                    <a class="inline-flex items-center justify-center rounded-xl bg-white px-5 py-3 text-xs font-black uppercase tracking-wider text-violet-700 hover:bg-slate-50 transition" href="/compte/commandes/<%= order.id %>/suivi">
                      <span class="material-symbols-outlined mr-2 text-base">timeline</span>
                      Suivre le parcours
                    </a>
                  <% } else { %>
                    <a class="inline-flex items-center justify-center rounded-xl bg-white px-5 py-3 text-xs font-black uppercase tracking-wider text-green-700 hover:bg-slate-50 transition" href="/compte/commandes/<%= order.id %>/suivi">
                      <span class="material-symbols-outlined mr-2 text-base">local_shipping</span>
                      Suivre le colis
                    </a>
                  <% } %>
                  <% if (order.cloningStatus === 'client_piece_in_transit' && order.cloningTracking && order.cloningTracking.trackingUrl) { %>
                    <a class="inline-flex items-center justify-center rounded-xl bg-white/20 px-5 py-3 text-xs font-black uppercase tracking-wider text-white hover:bg-white/30 transition" href="<%= order.cloningTracking.trackingUrl %>" target="_blank" rel="noopener">
                      <span class="material-symbols-outlined mr-2 text-base">package_2</span>
                      Suivre mon envoi
                    </a>
                  <% } %>
                <% } else { %>
                  <a class="inline-flex items-center justify-center rounded-xl bg-white px-5 py-3 text-xs font-black uppercase tracking-wider text-blue-700 hover:bg-slate-50 transition" href="/compte/commandes/<%= order.id %>/suivi">
                    <span class="material-symbols-outlined mr-2 text-base">location_on</span>
                    Suivre le colis
                  </a>
                <% } %>
              </div>
            </div>
          </div>

          <%/* ═══════ BLOC PARCOURS CLONAGE ═══════ */ %>
          <% if (order.orderType === 'exchange_cloning') { %>
            <div class="mt-8 rounded-2xl border border-slate-200 overflow-hidden">
              <div class="px-6 py-4 bg-violet-50 border-b border-violet-100 flex items-center gap-3">
                <span class="material-symbols-outlined text-violet-600">science</span>
                <div>
                  <div class="font-black text-violet-900">Service clonage 1:1</div>
                  <div class="text-xs text-violet-600">Votre ancienne pièce est nécessaire pour programmer la nouvelle</div>
                </div>
              </div>
              <div class="p-6 space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                  <div class="rounded-xl border p-4 text-center <%= ['client_piece_received','cloning_in_progress','cloning_done'].includes(order.cloningStatus) || order.statusKey === 'shipped' || order.statusKey === 'delivered' ? 'border-green-200 bg-green-50' : (['label_sent','client_piece_in_transit'].includes(order.cloningStatus) ? 'border-orange-300 bg-orange-50' : 'border-slate-200 bg-slate-50') %>">
                    <div class="w-10 h-10 rounded-full mx-auto flex items-center justify-center <%= ['client_piece_received','cloning_in_progress','cloning_done'].includes(order.cloningStatus) || order.statusKey === 'shipped' || order.statusKey === 'delivered' ? 'bg-green-500 text-white' : (['label_sent','client_piece_in_transit'].includes(order.cloningStatus) ? 'bg-orange-500 text-white' : 'bg-slate-200 text-slate-500') %>">
                      <span class="material-symbols-outlined text-lg">package_2</span>
                    </div>
                    <div class="mt-2 text-xs font-black uppercase tracking-widest text-slate-500">Étape 1</div>
                    <div class="mt-1 text-sm font-bold text-slate-900">Vous nous envoyez votre pièce</div>
                  </div>
                  <div class="rounded-xl border p-4 text-center <%= order.cloningStatus === 'cloning_done' || order.statusKey === 'shipped' || order.statusKey === 'delivered' ? 'border-green-200 bg-green-50' : (order.cloningStatus === 'cloning_in_progress' ? 'border-violet-300 bg-violet-50' : 'border-slate-200 bg-slate-50') %>">
                    <div class="w-10 h-10 rounded-full mx-auto flex items-center justify-center <%= order.cloningStatus === 'cloning_done' || order.statusKey === 'shipped' || order.statusKey === 'delivered' ? 'bg-green-500 text-white' : (order.cloningStatus === 'cloning_in_progress' ? 'bg-violet-500 text-white' : 'bg-slate-200 text-slate-500') %>">
                      <span class="material-symbols-outlined text-lg">memory</span>
                    </div>
                    <div class="mt-2 text-xs font-black uppercase tracking-widest text-slate-500">Étape 2</div>
                    <div class="mt-1 text-sm font-bold text-slate-900">Nous clonons les données</div>
                  </div>
                  <div class="rounded-xl border p-4 text-center <%= order.statusKey === 'shipped' || order.statusKey === 'delivered' ? 'border-green-200 bg-green-50' : 'border-slate-200 bg-slate-50' %>">
                    <div class="w-10 h-10 rounded-full mx-auto flex items-center justify-center <%= order.statusKey === 'shipped' || order.statusKey === 'delivered' ? 'bg-green-500 text-white' : 'bg-slate-200 text-slate-500' %>">
                      <span class="material-symbols-outlined text-lg">local_shipping</span>
                    </div>
                    <div class="mt-2 text-xs font-black uppercase tracking-widest text-slate-500">Étape 3</div>
                    <div class="mt-1 text-sm font-bold text-slate-900">Nous vous expédions la pièce</div>
                  </div>
                </div>

                <% if (['label_sent', 'client_piece_in_transit'].includes(order.cloningStatus)) { %>
                  <div class="rounded-2xl border-2 border-orange-300 bg-orange-50 p-5">
                    <div class="flex items-center gap-2 mb-3">
                      <span class="material-symbols-outlined text-orange-600">priority_high</span>
                      <div class="font-black text-orange-900">Action requise : envoyez votre ancienne pièce</div>
                    </div>
                    <div class="space-y-3 text-sm text-slate-700">
                      <div class="flex items-start gap-3">
                        <span class="material-symbols-outlined text-orange-500 flex-shrink-0">print</span>
                        <div><strong>1. Imprimez l'étiquette</strong> que vous avez reçue par email.
                          <% if (order.cloningLabel) { %>
                            <a href="<%= order.cloningLabel.url %>" class="text-primary font-bold hover:underline ml-1" target="_blank" rel="noopener">Retélécharger l'étiquette</a>
                          <% } %>
                        </div>
                      </div>
                      <div class="flex items-start gap-3">
                        <span class="material-symbols-outlined text-orange-500 flex-shrink-0">inventory_2</span>
                        <div><strong>2. Emballez soigneusement</strong> votre pièce dans un sachet antistatique, entourée de mousse ou papier bulle, dans un carton rigide.</div>
                      </div>
                      <div class="flex items-start gap-3">
                        <span class="material-symbols-outlined text-orange-500 flex-shrink-0">local_shipping</span>
                        <div><strong>3. Collez l'étiquette</strong> UPS sur le carton et déposez-le dans un
                          <a href="https://www.ups.com/dropoff?loc=fr_FR" class="text-primary font-bold hover:underline" target="_blank" rel="noopener">Point Relais UPS</a>.
                        </div>
                      </div>
                    </div>
                    <% if (order.cloningDates.labelSentAt) { %>
                      <div class="mt-3 text-xs text-slate-500">Étiquette envoyée le <%= order.cloningDates.labelSentAt %></div>
                    <% } %>
                  </div>
                <% } %>

                <% if (order.cloningStatus === 'client_piece_in_transit' && order.cloningTracking && order.cloningTracking.trackingNumber) { %>
                  <div class="rounded-xl border border-blue-200 bg-blue-50 p-4">
                    <div class="flex items-center justify-between">
                      <div>
                        <div class="text-xs font-black uppercase tracking-widest text-blue-500">Suivi de votre envoi</div>
                        <div class="mt-1 font-bold text-slate-900"><%= order.cloningTracking.carrier || 'UPS' %> — <%= order.cloningTracking.trackingNumber %></div>
                      </div>
                      <% if (order.cloningTracking.trackingUrl) { %>
                        <a class="inline-flex items-center gap-1 rounded-xl bg-blue-600 px-4 py-2 text-xs font-black text-white hover:bg-blue-700 transition" href="<%= order.cloningTracking.trackingUrl %>" target="_blank" rel="noopener">
                          <span class="material-symbols-outlined text-sm">open_in_new</span>Suivre
                        </a>
                      <% } %>
                    </div>
                  </div>
                <% } %>

                <% if (order.cloningStatus === 'cloning_in_progress') { %>
                  <div class="rounded-xl border border-violet-200 bg-violet-50 p-4 flex items-center gap-4">
                    <div class="w-12 h-12 rounded-full bg-violet-100 flex items-center justify-center flex-shrink-0">
                      <span class="material-symbols-outlined text-violet-600 animate-pulse">memory</span>
                    </div>
                    <div>
                      <div class="font-black text-violet-900">Clonage en cours</div>
                      <div class="text-sm text-slate-600">Nos techniciens lisent les données de votre pièce et les programment sur votre nouvelle mécatronique. Délai moyen : 2-5 jours ouvrés.</div>
                      <% if (order.cloningDates.cloningStartedAt) { %>
                        <div class="mt-1 text-xs text-slate-500">Démarré le <%= order.cloningDates.cloningStartedAt %></div>
                      <% } %>
                    </div>
                  </div>
                <% } %>

                <% if (order.cloningStatus === 'cloning_done' && order.statusKey !== 'shipped' && order.statusKey !== 'delivered') { %>
                  <div class="rounded-xl border border-green-200 bg-green-50 p-4 flex items-center gap-4">
                    <div class="w-12 h-12 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0">
                      <span class="material-symbols-outlined text-green-600">check_circle</span>
                    </div>
                    <div>
                      <div class="font-black text-green-900">Clonage terminé avec succès !</div>
                      <div class="text-sm text-slate-600">Votre pièce programmée sera expédiée sous 24-48h. Vous recevrez un email avec le numéro de suivi.</div>
                    </div>
                  </div>
                <% } %>

                <% if (order.cloningStatus === 'cloning_failed') { %>
                  <div class="rounded-xl border-2 border-red-300 bg-red-50 p-4 flex items-start gap-4">
                    <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0">
                      <span class="material-symbols-outlined text-red-600">error</span>
                    </div>
                    <div>
                      <div class="font-black text-red-900">Un problème a été détecté</div>
                      <div class="text-sm text-slate-700 mt-1">Nos techniciens ont rencontré un problème lors du clonage de votre pièce. Notre équipe vous contactera rapidement pour discuter des options disponibles.</div>
                      <div class="mt-3">
                        <a class="inline-flex items-center gap-1 rounded-xl bg-primary px-4 py-2 text-xs font-black text-white hover:bg-red-700 transition" href="https://sav.carpartsfrance.fr/" target="_blank" rel="noopener">
                          <span class="material-symbols-outlined text-sm">support_agent</span>
                          Contacter le support
                        </a>
                      </div>
                    </div>
                  </div>
                <% } %>
              </div>
            </div>
          <% } %>

          <%/* ═══════ DOCUMENTS TÉLÉCHARGEABLES ═══════ */ %>
          <% if (order.cloningLabel || order.returnLabel || order.shippingLabel) { %>
            <div class="mt-8 rounded-2xl border border-slate-200 p-6">
              <div class="text-[10px] font-black uppercase tracking-widest text-slate-400">Vos documents</div>
              <div class="mt-4 space-y-3">
                <% if (order.cloningLabel) { %>
                  <a href="<%= order.cloningLabel.url %>" target="_blank" rel="noopener" class="flex items-center gap-4 p-4 rounded-xl border border-purple-200 bg-purple-50 hover:bg-purple-100 transition">
                    <div class="w-10 h-10 rounded-xl bg-purple-100 flex items-center justify-center flex-shrink-0">
                      <span class="material-symbols-outlined text-purple-600">science</span>
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="text-sm font-black text-purple-900">Étiquette de récupération (clonage)</div>
                      <div class="text-xs text-purple-600">Imprimez et collez sur votre colis pour nous envoyer votre pièce</div>
                      <% if (order.cloningLabel.uploadedAt) { %>
                        <div class="text-[10px] text-slate-400 mt-1">Ajoutée le <%= order.cloningLabel.uploadedAt %></div>
                      <% } %>
                    </div>
                    <span class="material-symbols-outlined text-purple-400 flex-shrink-0">download</span>
                  </a>
                <% } %>
                <% if (order.returnLabel) { %>
                  <a href="<%= order.returnLabel.url %>" target="_blank" rel="noopener" class="flex items-center gap-4 p-4 rounded-xl border border-orange-200 bg-orange-50 hover:bg-orange-100 transition">
                    <div class="w-10 h-10 rounded-xl bg-orange-100 flex items-center justify-center flex-shrink-0">
                      <span class="material-symbols-outlined text-orange-600">assignment_return</span>
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="text-sm font-black text-orange-900">Bon de retour (consigne)</div>
                      <div class="text-xs text-orange-600">Pour retourner votre ancienne pièce dans le délai imparti</div>
                      <% if (order.returnLabel.uploadedAt) { %>
                        <div class="text-[10px] text-slate-400 mt-1">Ajouté le <%= order.returnLabel.uploadedAt %></div>
                      <% } %>
                    </div>
                    <span class="material-symbols-outlined text-orange-400 flex-shrink-0">download</span>
                  </a>
                <% } %>
                <% if (order.shippingLabel) { %>
                  <a href="<%= order.shippingLabel.url %>" target="_blank" rel="noopener" class="flex items-center gap-4 p-4 rounded-xl border border-blue-200 bg-blue-50 hover:bg-blue-100 transition">
                    <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center flex-shrink-0">
                      <span class="material-symbols-outlined text-blue-600">local_shipping</span>
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="text-sm font-black text-blue-900">Étiquette d'expédition</div>
                      <div class="text-xs text-blue-600">Suivi de l'envoi de votre commande</div>
                      <% if (order.shippingLabel.uploadedAt) { %>
                        <div class="text-[10px] text-slate-400 mt-1">Ajoutée le <%= order.shippingLabel.uploadedAt %></div>
                      <% } %>
                    </div>
                    <span class="material-symbols-outlined text-blue-400 flex-shrink-0">download</span>
                  </a>
                <% } %>
              </div>
            </div>
          <% } %>

          <% if (order.consigne && order.consigne.hasConsigne) { %>
            <div class="mt-8 rounded-2xl border border-slate-200 p-6">
              <div class="flex items-start justify-between gap-6">
                <div>
                  <div class="text-[10px] font-black uppercase tracking-widest text-slate-400">Consigne (ancienne pièce)</div>
                  <div class="mt-2 font-black text-slate-900">Retour obligatoire pour conserver la garantie</div>
                  <div class="mt-1 text-sm text-slate-600">La consigne n’est pas encaissée. Si l’ancienne pièce n’est pas reçue avant l’échéance, la garantie est annulée et le montant devient dû.</div>
                </div>
                <% if (order.consigne.hasOverdue) { %>
                  <div class="text-right">
                    <div class="text-xs font-black uppercase tracking-widest text-red-700">En retard</div>
                    <div class="mt-2 font-black text-red-700"><%= order.consigne.totalDue %></div>
                  </div>
                <% } %>
              </div>

              <div class="mt-5 space-y-3">
                <% (order.consigne.lines || []).forEach((l) => { %>
                  <div class="rounded-2xl border border-slate-200 bg-white p-4">
                    <div class="flex items-start justify-between gap-4">
                      <div class="min-w-0">
                        <div class="font-black text-slate-900 truncate"><%= l.name %></div>
                        <% if (l.sku) { %><div class="mt-1 text-xs text-slate-500">Réf : <span class="font-black text-slate-700"><%= l.sku %></span></div><% } %>
                        <div class="mt-2 text-xs text-slate-600">Quantité : <span class="font-black text-slate-700"><%= l.quantity %></span> • Total consigne : <span class="font-black text-slate-700"><%= l.total %></span></div>
                        <% if (l.isReceived) { %>
                          <div class="mt-2 text-xs font-black uppercase tracking-widest text-green-700">Reçue</div>
                        <% } else if (l.isOverdue) { %>
                          <div class="mt-2 text-xs font-black uppercase tracking-widest text-red-700">En retard (garantie annulée)</div>
                        <% } else if (l.daysLeft !== null) { %>
                          <div class="mt-2 text-xs font-black uppercase tracking-widest text-amber-800">Jours restants : <%= l.daysLeft %></div>
                        <% } else { %>
                          <div class="mt-2 text-xs font-black uppercase tracking-widest text-slate-700">Échéance calculée après livraison</div>
                        <% } %>
                      </div>
                      <div class="text-right">
                        <% if (l.dueAt) { %><div class="text-xs text-slate-500">Échéance</div><div class="text-xs font-black text-slate-900"><%= l.dueAt %></div><% } %>
                      </div>
                    </div>
                  </div>
                <% }) %>
              </div>

              <% if (order.consigne.hasOverdue) { %>
                <div class="mt-5 rounded-xl border border-red-200 bg-red-50 p-4 text-red-900">
                  <div class="font-black">Montant de consigne dû : <%= order.consigne.totalDue %></div>
                  <div class="mt-1 text-xs">Contactez-nous si vous avez besoin d’aide pour le renvoi.</div>
                </div>
              <% } %>
            </div>
          <% } %>

          <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="rounded-2xl border border-slate-200 p-6">
              <div class="flex items-center gap-2 text-xs font-black uppercase tracking-widest text-slate-400">
                <span class="material-symbols-outlined text-base text-primary">local_shipping</span>
                Livraison
              </div>
              <% if (order.shippingAddress) { %>
                <div class="mt-4">
                  <div class="font-black text-slate-900"><%= order.shippingMethodLabel || 'Livraison' %></div>
                  <% if (order.shippingAddress.fullName) { %><div class="mt-1 text-sm font-semibold text-slate-700"><%= order.shippingAddress.fullName %></div><% } %>
                  <div class="mt-2 text-sm text-slate-600"><%= order.shippingAddress.line1 %></div>
                  <% if (order.shippingAddress.line2) { %><div class="text-sm text-slate-600"><%= order.shippingAddress.line2 %></div><% } %>
                  <div class="text-sm text-slate-600"><%= order.shippingAddress.postalCode %> <%= order.shippingAddress.city %></div>
                  <div class="text-sm text-slate-600"><%= order.shippingAddress.country %></div>
                  <% if (order.shippingAddress.phone) { %><div class="mt-1 text-xs text-slate-500">Téléphone : <%= order.shippingAddress.phone %></div><% } %>
                </div>
              <% } else { %>
                <div class="mt-4 text-sm text-slate-600">Non renseignée</div>
              <% } %>
            </div>

            <div class="rounded-2xl border border-slate-200 p-6">
              <div class="flex items-center gap-2 text-xs font-black uppercase tracking-widest text-slate-400">
                <span class="material-symbols-outlined text-base text-primary">receipt_long</span>
                Facturation
              </div>
              <% if (order.billingAddress) { %>
                <div class="mt-4">
                  <div class="font-black text-slate-900"><%= order.billingAddress.label || 'Adresse de facturation' %></div>
                  <% if (order.billingAddress.fullName) { %><div class="mt-1 text-sm font-semibold text-slate-700"><%= order.billingAddress.fullName %></div><% } %>
                  <div class="mt-2 text-sm text-slate-600"><%= order.billingAddress.line1 %></div>
                  <% if (order.billingAddress.line2) { %><div class="text-sm text-slate-600"><%= order.billingAddress.line2 %></div><% } %>
                  <div class="text-sm text-slate-600"><%= order.billingAddress.postalCode %> <%= order.billingAddress.city %></div>
                  <div class="text-sm text-slate-600"><%= order.billingAddress.country %></div>
                  <% if (order.billingAddress.phone) { %><div class="mt-1 text-xs text-slate-500">Téléphone : <%= order.billingAddress.phone %></div><% } %>
                </div>
              <% } else { %>
                <div class="mt-4 text-sm text-slate-600">Non renseignée</div>
              <% } %>
            </div>
          </div>

          <div class="mt-8 rounded-2xl border border-slate-200 overflow-hidden">
            <div class="px-6 py-4 bg-slate-50 flex items-center justify-between">
              <div class="font-black text-slate-900">Articles commandés (<%= order.items ? order.items.length : 0 %>)</div>
              <div class="text-xs font-black uppercase tracking-widest text-slate-400">Détail</div>
            </div>

            <% if (order.items && order.items.length) { %>
              <div class="p-6 space-y-4">
                <% order.items.forEach((it) => { %>
                  <div class="rounded-2xl border border-slate-200 bg-white p-4 flex items-center gap-4">
                    <div class="w-16 h-16 rounded-2xl bg-slate-50 overflow-hidden flex items-center justify-center flex-shrink-0">
                      <% if (it.imageUrl) { %>
                        <img alt="<%= it.name %>" class="w-full h-full object-cover" src="<%= it.imageUrl %>" />
                      <% } else { %>
                        <span class="material-symbols-outlined text-slate-400">inventory_2</span>
                      <% } %>
                    </div>

                    <div class="flex-1 min-w-0">
                      <div class="flex items-start justify-between gap-4">
                        <div class="min-w-0">
                          <div class="font-black text-slate-900 truncate"><%= it.name %></div>
                          <% if (it.sku) { %>
                            <div class="mt-1 text-xs text-slate-500">Réf : <%= it.sku %></div>
                          <% } %>
                          <% if (it.optionsSummary) { %>
                            <div class="mt-1 text-xs text-slate-500"><%= it.optionsSummary %></div>
                          <% } %>
                          <div class="mt-2 flex items-center gap-2">
                            <% if (it.inStock === true) { %>
                              <span class="inline-flex items-center rounded-full bg-green-50 text-green-700 px-3 py-1 text-[10px] font-black uppercase tracking-widest">En stock</span>
                            <% } else if (it.inStock === false) { %>
                              <span class="inline-flex items-center rounded-full bg-amber-50 text-amber-800 px-3 py-1 text-[10px] font-black uppercase tracking-widest">Stock limité</span>
                            <% } %>
                            <span class="text-xs text-slate-500">Quantité : <span class="font-black text-slate-700"><%= it.quantity %></span></span>
                          </div>
                        </div>

                        <div class="text-right flex-shrink-0">
                          <div class="font-black text-slate-900"><%= it.lineTotal %></div>
                          <div class="mt-1 text-xs text-slate-500">PU : <%= it.unitPrice %></div>
                        </div>
                      </div>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <div class="p-6 text-slate-600">Aucun article.</div>
            <% } %>
          </div>

          <div class="mt-8 grid grid-cols-1 lg:grid-cols-12 gap-6">
            <div class="lg:col-span-7 rounded-2xl border border-slate-200 p-6 bg-slate-50">
              <div class="font-black text-slate-900">Besoin d'aide avec cette commande ?</div>
              <div class="mt-2 text-sm text-slate-600">Si vous rencontrez un problème, notre support peut vous aider rapidement.</div>
              <div class="mt-5 flex flex-col sm:flex-row gap-3">
                <a class="inline-flex items-center justify-center rounded-xl bg-white border border-slate-200 px-4 py-3 text-xs font-black uppercase tracking-wider text-slate-700 hover:bg-slate-50 transition" href="https://sav.carpartsfrance.fr/" target="_blank" rel="noopener">
                  Contacter le support
                </a>
              </div>
            </div>

            <div class="lg:col-span-5 rounded-2xl border border-slate-200 p-6">
              <div class="space-y-3 text-sm">
                <div class="flex items-center justify-between">
                  <div class="text-slate-500">Sous-total HT</div>
                  <div class="font-black text-slate-900"><%= order.ht %></div>
                </div>
                <div class="flex items-center justify-between">
                  <div class="text-slate-500">TVA (20%)</div>
                  <div class="font-black text-slate-900"><%= order.vat %></div>
                </div>
                <% if (typeof order.clientDiscountCents !== 'undefined' && order.clientDiscountCents > 0) { %>
                  <div class="flex items-center justify-between">
                    <div class="text-slate-500">Remise compte (<%= typeof order.clientDiscountPercent !== 'undefined' ? String(order.clientDiscountPercent).replace('.', ',') : '' %>%)</div>
                    <div class="font-black text-slate-900">- <%= (order.clientDiscountCents / 100).toFixed(2).replace('.', ',') %> €</div>
                  </div>
                <% } %>
                <% if (typeof order.promoDiscountCents !== 'undefined' && order.promoDiscountCents > 0) { %>
                  <div class="flex items-center justify-between">
                    <div class="text-slate-500">Code promo <%= order.promoCode ? '(' + order.promoCode + ')' : '' %></div>
                    <div class="font-black text-slate-900">- <%= (order.promoDiscountCents / 100).toFixed(2).replace('.', ',') %> €</div>
                  </div>
                <% } %>
                <% if ((typeof order.clientDiscountCents !== 'undefined' && order.clientDiscountCents > 0) || (typeof order.promoDiscountCents !== 'undefined' && order.promoDiscountCents > 0)) { %>
                  <div class="flex items-center justify-between">
                    <div class="text-slate-500">Sous-total après remise</div>
                    <div class="font-black text-slate-900"><%= typeof order.itemsTotalAfterDiscount !== 'undefined' ? order.itemsTotalAfterDiscount : order.itemsSubtotal %></div>
                  </div>
                <% } %>
                <div class="flex items-center justify-between">
                  <div class="text-slate-500">Frais de livraison (<%= order.shippingMethodLabel || 'Livraison' %>)</div>
                  <div class="font-black <%= order.shippingCostCents === 0 ? 'text-green-600' : 'text-slate-900' %>">
                    <%= order.shippingCostCents === 0 ? 'OFFERT' : order.shippingCost %>
                  </div>
                </div>
              </div>

              <div class="mt-6 pt-6 border-t border-slate-200 flex items-center justify-between">
                <div class="font-black text-slate-900">Total TTC</div>
                <div class="text-primary font-black text-2xl"><%= order.total %></div>
              </div>

              <form action="/compte/commandes/<%= order.id %>/racheter" class="mt-6" method="POST">
                <button class="w-full inline-flex items-center justify-center rounded-xl bg-primary px-5 py-3 text-xs font-black uppercase tracking-wider text-white hover:bg-red-700 transition" type="submit">
                  Racheter les articles
                </button>
              </form>
            </div>
          </div>

          <% if (!dbConnected) { %>
            <div class="mt-8 rounded-xl border border-amber-200 bg-amber-50 p-4 text-amber-900">
              <div class="font-bold">Mode démo</div>
              <div class="mt-1 text-sm">La base de données est indisponible : impossible d’afficher le détail réel.</div>
            </div>
          <% } %>
        </div>
      </section>
    </div>
  </div>
</main>

<% if (order.statusKey === 'paid' || order.statusKey === 'processing' || order.statusKey === 'shipped' || order.statusKey === 'delivered' || order.statusKey === 'completed') { %>
<script>
(function() {
  // Ne fire qu'une seule fois par commande via sessionStorage
  var purchaseKey = 'cpf_purchase_tracked_<%= order.id %>';
  if (window.sessionStorage) {
    try {
      if (sessionStorage.getItem(purchaseKey)) return;
      sessionStorage.setItem(purchaseKey, '1');
    } catch(e) {}
  }

  // === 1. DataLayer push pour GTM (GA4 + Google Ads via GTM) ===
  window.dataLayer = window.dataLayer || [];
  window.dataLayer.push({ ecommerce: null });

  window.dataLayer.push({
    event: 'purchase',
    ecommerce: {
      transaction_id: '<%= order.number %>',
      value: <%= (order.totalCents / 100).toFixed(2) %>,
      tax: <%= (order.vatCents / 100).toFixed(2) %>,
      shipping: <%= (order.shippingCostCents / 100).toFixed(2) %>,
      currency: '<%= order.currency || "EUR" %>',
      items: [
        <% if (order.items && order.items.length) { %>
          <% order.items.forEach(function(it, idx) { %>
            {
              item_id: '<%= (it.sku || it.productId || "").replace(/\x27/g, "\\\'" ) %>',
              item_name: '<%= (it.name || "").replace(/\x27/g, "\\\'" ) %>',
              price: <%= it.unitPriceCents ? (it.unitPriceCents / 100).toFixed(2) : 0 %>,
              quantity: <%= it.quantity || 1 %>
            }<%= idx < order.items.length - 1 ? ',' : '' %>
          <% }); %>
        <% } %>
      ]
    },
    value: <%= (order.totalCents / 100).toFixed(2) %>,
    tax: <%= (order.vatCents / 100).toFixed(2) %>,
    shipping: <%= (order.shippingCostCents / 100).toFixed(2) %>,
    currency: '<%= order.currency || "EUR" %>',
    transaction_id: '<%= order.number %>'
  });

})();
</script>
<% } %>

<%- include('../partials/footer') %>
