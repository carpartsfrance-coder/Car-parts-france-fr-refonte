<%- include('./partials/head') %>

<div class="flex-1 flex items-center justify-center px-4 py-10">
  <div class="w-full max-w-md">
    <div class="text-center">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-primary text-white">
        <span class="material-symbols-outlined text-3xl">admin_panel_settings</span>
      </div>
      <div class="mt-4 text-2xl font-semibold text-slate-900">Connexion Admin</div>
      <div class="mt-1 text-sm text-slate-500">Accès réservé à l’équipe CarParts France.</div>
    </div>

    <% if (typeof successMessage !== 'undefined' && successMessage) { %>
      <div class="mt-6 rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-emerald-900">
        <div class="font-bold">OK</div>
        <div class="mt-1 text-sm"><%= successMessage %></div>
      </div>
    <% } %>

    <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
      <div class="mt-6 rounded-xl border border-red-200 bg-red-50 p-4 text-red-900">
        <div class="font-bold">Erreur</div>
        <div class="mt-1 text-sm"><%= errorMessage %></div>
      </div>
    <% } %>

    <% if (typeof isDevFallback !== 'undefined' && isDevFallback) { %>
      <div class="mt-6 rounded-xl border border-amber-200 bg-amber-50 p-4 text-amber-900">
        <div class="font-bold">Mode développement (fallback)</div>
        <div class="mt-1 text-sm">Base de données indisponible. Identifiants de secours :</div>
        <div class="mt-3 text-xs font-semibold uppercase tracking-widest text-amber-800/80">Email</div>
        <div class="mt-1 text-sm font-semibold"><%= devFallbackEmail %></div>
        <div class="mt-3 text-xs font-semibold uppercase tracking-widest text-amber-800/80">Mot de passe</div>
        <div class="mt-1 text-sm font-semibold"><%= devFallbackPassword %></div>
      </div>
    <% } %>

    <% if (typeof isDevMode !== 'undefined' && isDevMode && !(typeof isDevFallback !== 'undefined' && isDevFallback)) { %>
      <div class="mt-6 rounded-xl border border-amber-200 bg-amber-50 p-4 text-amber-900">
        <div class="font-bold">Mode développement</div>
        <div class="mt-1 text-sm">Comptes de test disponibles (ne pas utiliser en production).</div>
        <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
          <!-- Owner -->
          <div class="rounded-xl border border-purple-200 bg-purple-50 p-3">
            <div class="flex items-center gap-2 mb-2">
              <span class="bg-purple-100 text-purple-700 text-xs px-2 py-0.5 rounded-full font-semibold">Propriétaire</span>
            </div>
            <div class="text-xs text-purple-800/70 mb-1">Accès complet</div>
            <div class="text-xs font-semibold text-purple-900">admin@carpartsfrance.fr</div>
            <div class="text-xs font-semibold text-purple-900">admin12345</div>
          </div>
          <!-- Employé -->
          <div class="rounded-xl border border-green-200 bg-green-50 p-3">
            <div class="flex items-center gap-2 mb-2">
              <span class="bg-green-100 text-green-700 text-xs px-2 py-0.5 rounded-full font-semibold">Employé</span>
            </div>
            <div class="text-xs text-green-800/70 mb-1">Accès sans KPI financiers</div>
            <div class="text-xs font-semibold text-green-900">employe@test.fr</div>
            <div class="text-xs font-semibold text-green-900">employe12345</div>
          </div>
        </div>
      </div>
    <% } %>

    <form action="/admin/connexion" class="mt-6 rounded-2xl border border-slate-200 bg-white p-6" method="POST">
      <input name="returnTo" type="hidden" value="<%= typeof returnTo !== 'undefined' ? returnTo : '/admin' %>" />
      <input name="website" type="text" value="" autocomplete="off" tabindex="-1" aria-hidden="true" class="hidden" />

      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-slate-500" for="email">Email</label>
          <input class="mt-2 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold focus:ring-primary" id="email" name="email" placeholder="admin@carpartsfrance.fr" type="email" value="<%= typeof email !== 'undefined' ? email : '' %>" />
        </div>

        <div>
          <label class="block text-sm font-medium text-slate-500" for="password">Mot de passe</label>
          <input class="mt-2 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold focus:ring-primary" id="password" name="password" placeholder="••••••••" type="password" />
        </div>
      </div>

      <button class="btn btn-primary btn-block mt-6" type="submit">
        Se connecter
      </button>

      <div class="mt-4 text-center text-sm">
        <a class="font-bold text-primary hover:underline" href="/admin/reinitialiser">Mot de passe oublié ?</a>
      </div>

      <div class="mt-4 text-xs text-slate-500">
        Les accès back-office sont désormais gérés depuis la base de données et administrables dans les paramètres du back-office.
      </div>
    </form>
  </div>
</div>

<%- include('./partials/footer') %>
