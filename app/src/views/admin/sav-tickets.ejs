<%- include('./partials/head') %>
<link rel="stylesheet" href="/css/sav.css">
<%- include('./partials/sidebar', { active: 'sav' }) %>

<main class="flex-1 lg:pl-72 sav-module" data-sav-token="<%= savApiToken %>">
  <div class="px-6 lg:px-10 py-8">

    <div class="flex items-start justify-between gap-4 mb-6">
      <div>
        <div class="text-2xl md:text-3xl font-semibold text-slate-900">Tickets SAV</div>
        <div class="mt-1 text-sm text-slate-500">Liste filtrable — j/k pour naviguer, Entrée pour ouvrir</div>
      </div>
      <a href="/admin/sav" class="btn btn-secondary">← Dashboard</a>
    </div>

    <!-- Filtres -->
    <form id="sav-filters" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3 mb-4">
      <input type="text" name="search" placeholder="N° / email / VIN" class="rounded-xl border border-slate-300 px-3 py-2 text-sm">
      <select name="statut" class="rounded-xl border border-slate-300 px-3 py-2 text-sm">
        <option value="">Tous statuts</option>
        <% ['ouvert','pre_qualification','en_attente_documents','retour_demande','en_transit_retour','recu_atelier','en_analyse','analyse_terminee','en_attente_decision_client','resolu_garantie','resolu_facture','clos','refuse'].forEach(function(s){ %>
          <option value="<%= s %>"><%= s %></option>
        <% }); %>
      </select>
      <select name="pieceType" class="rounded-xl border border-slate-300 px-3 py-2 text-sm">
        <option value="">Tous types</option>
        <% ['mecatronique_dq200','mecatronique_dq250','mecatronique_dq381','mecatronique_dq500','boite_transfert','pont','differentiel','haldex','reducteur','cardan','autre'].forEach(function(t){ %>
          <option value="<%= t %>"><%= t %></option>
        <% }); %>
      </select>
      <label class="flex items-center gap-2 text-sm">
        <input type="checkbox" name="sla_depasse" value="true" class="rounded text-primary"> SLA dépassé
      </label>
      <button type="submit" class="btn btn-primary">Filtrer</button>
    </form>

    <div id="sav-tickets-error" class="hidden rounded-xl border border-red-200 bg-red-50 p-3 text-sm text-red-800 mb-3"></div>

    <div class="rounded-2xl border border-slate-200 bg-white overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-slate-50 text-left">
          <tr>
            <th class="px-4 py-3 font-semibold text-slate-600">N°</th>
            <th class="px-4 py-3 font-semibold text-slate-600">Client</th>
            <th class="px-4 py-3 font-semibold text-slate-600">Pièce</th>
            <th class="px-4 py-3 font-semibold text-slate-600">Véhicule</th>
            <th class="px-4 py-3 font-semibold text-slate-600">Statut</th>
            <th class="px-4 py-3 font-semibold text-slate-600">SLA</th>
            <th class="px-4 py-3 font-semibold text-slate-600">Ouvert le</th>
          </tr>
        </thead>
        <tbody id="sav-tickets-tbody" class="divide-y divide-slate-100">
          <tr><td colspan="7" class="px-4 py-10 text-center text-slate-500">Chargement…</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</main>

<script src="/js/sav-admin.js" defer></script>
<%- include('./partials/footer') %>
