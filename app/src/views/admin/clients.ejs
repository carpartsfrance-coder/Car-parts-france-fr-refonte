<%- include('./partials/head') %>

<%- include('./partials/sidebar', { active: 'clients' }) %>

<main class="flex-1">
  <div class="px-6 lg:px-10 py-8">
    <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">
      <div>
        <%- include('./partials/breadcrumb', { breadcrumbs: [{label: 'Clients'}] }) %>
        <div class="text-2xl md:text-3xl font-semibold text-slate-900">Clients</div>
        <div class="mt-1 text-sm text-slate-500">Liste des clients (particuliers et professionnels).</div>
      </div>
    </div>

    <form action="/admin/clients" class="sticky top-0 z-30 mt-6 bg-white/98 backdrop-blur rounded-2xl border border-slate-200 p-4 shadow-lg shadow-slate-200/70" method="GET">
      <div class="flex flex-col xl:flex-row xl:items-center gap-4">
        <div class="flex-1">
          <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">search</span>
            <input class="w-full rounded-2xl border border-slate-200 bg-white pl-10 pr-4 py-3 text-sm font-semibold text-slate-900 placeholder:text-slate-400" name="q" placeholder="Rechercher: email, prénom, nom, société..." type="text" value="<%= filters && filters.q ? filters.q : '' %>" />
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-3">
          <select class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-bold text-slate-900" name="type">
            <option value="">Tous les clients</option>
            <option value="particulier" <%= filters && filters.type === 'particulier' ? 'selected' : '' %>>Particulier</option>
            <option value="pro" <%= filters && filters.type === 'pro' ? 'selected' : '' %>>Professionnel</option>
          </select>

          <select class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-bold text-slate-900" name="period">
            <option value="">Toutes périodes</option>
            <option value="7d" <%= filters && filters.period === '7d' ? 'selected' : '' %>>7 jours</option>
            <option value="30d" <%= filters && filters.period === '30d' ? 'selected' : '' %>>30 jours</option>
            <option value="90d" <%= filters && filters.period === '90d' ? 'selected' : '' %>>90 jours</option>
            <option value="365d" <%= filters && filters.period === '365d' ? 'selected' : '' %>>12 mois</option>
          </select>

          <button class="btn btn-secondary" type="submit">
            Filtrer
          </button>
        </div>
      </div>
    </form>

    <div class="mt-8 bg-white rounded-2xl border border-slate-200 overflow-hidden">
      <div class="px-6 py-4 bg-slate-50 flex items-center justify-between">
        <div class="font-semibold text-slate-900">Clients</div>
        <% if (typeof pagination !== 'undefined' && pagination && pagination.totalItems) { %>
          <div class="text-xs font-bold text-slate-500">
            <%= pagination.from %>–<%= pagination.to %> sur <%= pagination.totalItems %>
          </div>
        <% } %>
      </div>

      <% if (clients && clients.length) { %>
        <%
          const clSort = filters.sort || 'created';
          const clOrder = filters.order || 'desc';
          function clSortUrl(field) {
            const nextOrder = (clSort === field && clOrder === 'asc') ? 'desc' : 'asc';
            const p = [];
            if (filters.q) p.push('q=' + encodeURIComponent(filters.q));
            if (filters.type) p.push('type=' + encodeURIComponent(filters.type));
            if (filters.period) p.push('period=' + encodeURIComponent(filters.period));
            p.push('sort=' + field, 'order=' + nextOrder);
            return '/admin/clients?' + p.join('&');
          }
          function clSortIcon(field) {
            if (clSort !== field) return 'unfold_more';
            return clOrder === 'asc' ? 'arrow_upward' : 'arrow_downward';
          }
        %>
        <div class="overflow-x-auto">
          <table class="w-full text-left admin-table">
            <thead>
              <tr class="text-xs font-semibold text-slate-400 uppercase tracking-widest bg-white">
                <th class="px-6 py-4 th-sortable <%= clSort === 'name' ? 'sort-active' : '' %>">
                  <a href="<%= clSortUrl('name') %>" style="color:inherit;text-decoration:none;display:inline-flex;align-items:center;gap:2px;">
                    Client<span class="sort-icon material-symbols-outlined"><%= clSortIcon('name') %></span>
                  </a>
                </th>
                <th class="px-6 py-4">Email</th>
                <th class="px-6 py-4 th-sortable <%= clSort === 'type' ? 'sort-active' : '' %>">
                  <a href="<%= clSortUrl('type') %>" style="color:inherit;text-decoration:none;display:inline-flex;align-items:center;gap:2px;">
                    Type<span class="sort-icon material-symbols-outlined"><%= clSortIcon('type') %></span>
                  </a>
                </th>
                <th class="px-6 py-4 th-sortable <%= clSort === 'created' ? 'sort-active' : '' %>">
                  <a href="<%= clSortUrl('created') %>" style="color:inherit;text-decoration:none;display:inline-flex;align-items:center;gap:2px;">
                    Créé<span class="sort-icon material-symbols-outlined"><%= clSortIcon('created') %></span>
                  </a>
                </th>
                <th class="px-6 py-4 text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% clients.forEach((c) => { %>
                <tr>
                  <td class="px-6 py-4 font-semibold text-slate-900">
                    <div class="flex items-center gap-1.5">
                      <%= c.name %>
                      <% if (c.overdueReturnCount > 0) { %>
                        <span class="relative group cursor-default">
                          <span class="inline-flex items-center gap-0.5 text-[10px] font-bold px-1.5 py-0.5 rounded-full bg-red-50 text-red-600 border border-red-200">
                            <span class="material-symbols-outlined" style="font-size:12px">warning</span>Retour en retard
                          </span>
                          <span class="pointer-events-none absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-56 rounded-xl border border-red-200 bg-white p-3 shadow-xl opacity-0 group-hover:opacity-100 transition z-50 text-left">
                            <span class="block text-[11px] font-bold text-red-700"><%= c.overdueReturnCount %> commande<%= c.overdueReturnCount > 1 ? 's' : '' %> avec retour en retard</span>
                            <span class="block mt-1 text-[10px] text-red-500"><%= c.overdueReturnDays %> jour<%= c.overdueReturnDays > 1 ? 's' : '' %> de retard</span>
                          </span>
                        </span>
                      <% } %>
                      <% if (c.notesCount > 0) { %>
                        <span class="relative group cursor-default">
                          <span class="material-symbols-outlined text-base <%= c.hasImportantNote ? 'text-red-500' : 'text-slate-400' %>">comment</span>
                          <span class="pointer-events-none absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-64 rounded-xl border border-slate-200 bg-white p-3 shadow-xl opacity-0 group-hover:opacity-100 transition z-50 text-left">
                            <span class="block text-[11px] font-semibold text-slate-400 uppercase tracking-wider"><%= c.notesCount %> note<%= c.notesCount > 1 ? 's' : '' %></span>
                            <% if (c.lastNotePreview) { %>
                              <span class="block mt-1 text-xs text-slate-700 font-normal leading-relaxed"><%= c.lastNotePreview %><%= c.lastNotePreview.length >= 100 ? '...' : '' %></span>
                              <span class="block mt-1 text-[10px] text-slate-400 font-normal"><%= c.lastNoteAuthor %> &middot; <%= c.lastNoteDate %></span>
                            <% } %>
                          </span>
                        </span>
                      <% } %>
                    </div>
                  </td>
                  <td class="px-6 py-4 text-sm text-slate-500"><%= c.email %></td>
                  <td class="px-6 py-4">
                    <span class="badge <%= c.accountType === 'pro' ? 'badge-pro' : 'badge-particulier' %>">
                      <%= c.accountType === 'pro' ? 'PRO' : 'PARTICULIER' %>
                    </span>
                  </td>
                  <td class="px-6 py-4 text-sm text-slate-500"><%= c.createdAt %></td>
                  <td class="px-6 py-4 text-right">
                    <% if (c.id) { %>
                      <a class="btn btn-ghost" href="/admin/clients/<%= c.id %>">
                        <span class="material-symbols-outlined mr-2 text-base">visibility</span>
                        Détails
                      </a>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <div class="px-6 py-4 border-t border-slate-100 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div class="text-xs font-semibold uppercase tracking-widest text-slate-400">
            <% if (typeof pagination !== 'undefined' && pagination) { %>
              Affichage <%= pagination.from %>-<%= pagination.to %> sur <%= pagination.totalItems %>
            <% } else { %>
              Affichage 1-<%= clients.length %> sur <%= clients.length %>
            <% } %>
          </div>

          <% 
            const qVal = filters && filters.q ? String(filters.q) : '';
            const typeVal = filters && filters.type ? String(filters.type) : '';
            const periodVal = filters && filters.period ? String(filters.period) : '';
            const extraQuery = [
              qVal ? `q=${encodeURIComponent(qVal)}` : '',
              typeVal ? `type=${encodeURIComponent(typeVal)}` : '',
              periodVal ? `period=${encodeURIComponent(periodVal)}` : '',
            ].filter(Boolean).join('&');
            const withExtra = extraQuery ? `&${extraQuery}` : '';
          %>

          <% if (typeof pagination !== 'undefined' && pagination && pagination.totalPages > 1) { %>
            <div class="flex items-center justify-end gap-2">
              <a class="w-9 h-9 inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white hover:bg-slate-50 transition <%= pagination.hasPrev ? '' : 'opacity-40 pointer-events-none' %>" href="?page=<%= pagination.prevPage %><%= withExtra %>" aria-label="Page précédente">
                <span class="material-symbols-outlined text-slate-500">chevron_left</span>
              </a>

              <% const startPage = Math.max(1, pagination.page - 2); %>
              <% const endPage = Math.min(pagination.totalPages, pagination.page + 2); %>
              <% for (let p = startPage; p <= endPage; p += 1) { %>
                <a class="w-9 h-9 inline-flex items-center justify-center rounded-xl border text-xs font-semibold <%= p === pagination.page ? 'bg-primary text-white border-primary' : 'bg-white text-slate-500 border-slate-200 hover:bg-slate-50' %>" href="?page=<%= p %><%= withExtra %>"><%= p %></a>
              <% } %>

              <a class="w-9 h-9 inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white hover:bg-slate-50 transition <%= pagination.hasNext ? '' : 'opacity-40 pointer-events-none' %>" href="?page=<%= pagination.nextPage %><%= withExtra %>" aria-label="Page suivante">
                <span class="material-symbols-outlined text-slate-500">chevron_right</span>
              </a>
            </div>
          <% } %>
        </div>
      <% } else if (!dbConnected) { %>
        <div class="px-6 py-4 space-y-3">
          <% for (let i = 0; i < 5; i++) { %>
            <div class="animate-pulse bg-gray-200 h-12 rounded-xl"></div>
          <% } %>
        </div>
      <% } else { %>
        <div class="text-center py-12">
          <span class="material-symbols-outlined text-6xl text-slate-400">group</span>
          <p class="text-lg font-semibold text-slate-500 mt-4">Aucun client</p>
          <p class="text-slate-400">Les clients apparaitront ici.</p>
        </div>
      <% } %>
    </div>

    <% if (!dbConnected) { %>
      <div class="mt-8 rounded-xl border border-amber-200 bg-amber-50 p-4 text-amber-900">
        <div class="font-bold">Mode démo</div>
        <div class="mt-1 text-sm">La base de données est indisponible : la liste des clients n’est pas disponible.</div>
      </div>
    <% } %>
  </div>
</main>

<%- include('./partials/footer') %>
