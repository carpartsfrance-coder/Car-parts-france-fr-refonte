            const type = document.createElement('span');
            type.className = `inline-flex items-center rounded-full px-2 py-1 text-[10px] font-semibold uppercase tracking-widest ${template && template.type === 'text' ? 'bg-sky-50 text-sky-700' : 'bg-violet-50 text-violet-700'}`;
