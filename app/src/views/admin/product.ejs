        function applyGeneratedDraft(data) {
          const draft = data && data.draft ? data.draft : null;
          if (!draft) throw new Error('Brouillon IA introuvable.');

          setInputValue('name', draft.name);
          setInputValue('slug', draft.slug);
          setInputValue('brand', draft.brand);
          setInputValue('category', draft.category);
          setInputValue('shippingDelayText', draft.shippingDelayText);
          setInputValue('specType', draft.specType);
          setInputValue('specProgrammation', draft.specProgrammation);
          setInputValue('badgeTopLeft', draft.badgeTopLeft);
          setInputValue('badgeCondition', draft.badgeCondition);
          setInputValue('shortDescription', draft.shortDescription);
          setInputValue('description', draft.description);
          setInputValue('compatibleReferences', draft.compatibleReferences);
          setInputValue('metaTitle', draft.metaTitle);
          setInputValue('metaDescription', draft.metaDescription);

          if (typeof syncSpecsFromKeyFields === 'function') syncSpecsFromKeyFields();

          if (compatField && typeof draft.compatibility === 'string') {
            compatField.value = draft.compatibility;
            aiTouchedFields.add('compatibility');
            validatedFields.delete('compatibility');
            compatItems = parseCompatibility();
            selectedMake = compatItems.length ? (compatItems[0].make || '') : '';
            if (compatMakeSelect) compatMakeSelect.value = selectedMake || '';
            renderCompatibilityUI();
