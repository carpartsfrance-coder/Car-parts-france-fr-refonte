        function setInputValue(id, value) {
          const el = document.getElementById(id);
          const safeValue = typeof value === 'string' || typeof value === 'number' || typeof value === 'boolean'
            ? String(value)
            : '';
          const nextValue = safeValue.trim();
          if (!el || !nextValue) return;

          aiTouchedFields.add(id);
          validatedFields.delete(id);

          if (el.tagName === 'SELECT') {
            const existing = Array.from(el.options || []).find((option) => String(option.value || '').toLowerCase() === nextValue.toLowerCase());
            if (existing) {
              el.value = existing.value;
            } else {
              const temp = document.createElement('option');
              temp.value = nextValue;
              temp.textContent = nextValue;
              el.appendChild(temp);
              el.value = nextValue;
            }
          } else {
            el.value = safeValue;
          }

          dispatchFieldUpdates(el);
        }

