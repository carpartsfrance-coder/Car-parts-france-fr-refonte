    <script id="compatIndexJson" type="application/json"><%- JSON.stringify((typeof compatIndex !== 'undefined' && compatIndex) ? compatIndex : { makes: [], modelsByMake: {} }) %></script>

    <script id="productOptionTemplatesJson" type="application/json"><%- JSON.stringify((typeof productOptionTemplates !== 'undefined' && productOptionTemplates) ? productOptionTemplates : []) %></script>

    <script id="seoAssistantSeed" type="application/json"><%- JSON.stringify({
      baseUrl: (typeof seoAssistant !== 'undefined' && seoAssistant && seoAssistant.computed && seoAssistant.computed.baseUrl) ? seoAssistant.computed.baseUrl : '',
      productId: productId ? String(productId) : 'ID',
    }) %></script>

    <script src="/js/sortable.min.js"></script>

    <script>
      (function () {
        /* Local aliases — btn-loading.js is loaded in footer */
        const btnSetLoading   = function (b, t) { if (window.btnSetLoading)   window.btnSetLoading(b, t);   else if (b) b.disabled = true; };
        const btnResetLoading = function (b)    { if (window.btnResetLoading) window.btnResetLoading(b);    else if (b) b.disabled = false; };

        const fileInput = document.getElementById('image');
        const addNewBtn = document.getElementById('mediaAddNew');
        const uploadBtn = document.getElementById('mediaUploadBtn');
        const grid = document.getElementById('mediaGrid');
        const galleryField = document.getElementById('galleryUrls');
        const galleryTypesField = document.getElementById('galleryTypes');
        const canUseMedia = !!(fileInput && addNewBtn && uploadBtn && grid && galleryField && galleryTypesField);

        const selected = [];

        const VIDEO_MIMES = new Set(['video/mp4', 'video/webm', 'video/quicktime']);
        const MAX_IMAGE_BYTES = 5 * 1024 * 1024;
        const MAX_VIDEO_BYTES = 50 * 1024 * 1024;
        const isVideoFile = (f) => !!(f && f.type && VIDEO_MIMES.has(String(f.type).toLowerCase()));
        const isImageFile = (f) => !!(f && f.type && String(f.type).toLowerCase().startsWith('image/'));
        const isAcceptedFile = (f) => isImageFile(f) || isVideoFile(f);

        const sameFile = (a, b) => a && b && a.name === b.name && a.size === b.size && a.lastModified === b.lastModified;
        const getMediaTiles = () => Array.from(grid.querySelectorAll('[data-kind]')).filter((el) => el && !el.id);
        const syncGalleryFieldFromGrid = () => {
          const galleryTiles = getMediaTiles().filter((el) => el.getAttribute('data-kind') === 'gallery');
          const orderedGalleryUrls = galleryTiles
            .map((el) => String(el.getAttribute('data-url') || '').trim())
            .filter(Boolean);
          const orderedGalleryTypes = galleryTiles
            .map((el) => (el.getAttribute('data-type') === 'video' ? 'video' : 'image'));
          galleryField.value = orderedGalleryUrls.join('\n');
          galleryTypesField.value = orderedGalleryTypes.join('\n');
          refreshFieldReviewPanel();
        };
        const syncPreviewOrderFromGrid = () => {
          const previewTiles = getMediaTiles().filter((el) => el.getAttribute('data-kind') === 'preview');
          const nextSelected = previewTiles
            .map((el) => {
              const idx = Number(el.getAttribute('data-preview-idx'));
              return Number.isFinite(idx) && idx >= 0 && idx < selected.length ? selected[idx] : null;
            })
            .filter(Boolean);

          selected.splice(0, selected.length, ...nextSelected);
          previewTiles.forEach((el, i) => el.setAttribute('data-preview-idx', String(i)));
          syncInputFiles();
        };
        const syncMediaOrder = () => {
          syncGalleryFieldFromGrid();
          syncPreviewOrderFromGrid();
        };
        const moveTile = (tile, direction) => {
          if (!tile || !grid || !uploadBtn) return;
          const kind = tile.getAttribute('data-kind');
          if (!kind || kind === 'main') return;

          const movableTiles = getMediaTiles().filter((el) => {
            const currentKind = el.getAttribute('data-kind');
            return currentKind === 'gallery' || currentKind === 'preview';
          });
          const currentIndex = movableTiles.indexOf(tile);
          if (currentIndex < 0) return;

          const targetIndex = direction === 'left' ? currentIndex - 1 : currentIndex + 1;
          if (targetIndex < 0 || targetIndex >= movableTiles.length) return;

          const targetTile = movableTiles[targetIndex];
          if (!targetTile || targetTile === tile) return;

          if (direction === 'left') {
            grid.insertBefore(tile, targetTile);
          } else {
            const nextSibling = targetTile.nextSibling === tile ? tile.nextSibling : targetTile.nextSibling;
            grid.insertBefore(tile, nextSibling || uploadBtn);
          }

          syncMediaOrder();
        };
        const syncInputFiles = () => {
          const dt = new DataTransfer();
          selected.forEach((f) => dt.items.add(f));
          fileInput.files = dt.files;
          refreshFieldReviewPanel();
        };

        const openPicker = () => fileInput.click();
        if (canUseMedia) {
          addNewBtn.addEventListener('click', openPicker);
          uploadBtn.addEventListener('click', openPicker);
        }

        const removeGalleryUrl = (url) => {
          const lines = String(galleryField.value || '')
            .split(/\r?\n/)
            .map((s) => s.trim())
            .filter(Boolean);
          const next = lines.filter((l) => l !== url);
          galleryField.value = next.join('\n');
          refreshFieldReviewPanel();
        };

        if (canUseMedia) {
          grid.addEventListener('click', (e) => {
            const moveBtn = e.target && e.target.closest ? e.target.closest('button[data-action="move-left"], button[data-action="move-right"]') : null;
            if (moveBtn) {
              const tile = moveBtn.closest('[data-kind]');
              if (!tile) return;
              moveTile(tile, moveBtn.getAttribute('data-action') === 'move-left' ? 'left' : 'right');
              return;
            }

            const btn = e.target && e.target.closest ? e.target.closest('button[data-action="remove"]') : null;
            if (!btn) return;
            const tile = btn.closest('[data-kind]');
            if (!tile) return;
            const kind = tile.getAttribute('data-kind');
            const url = tile.getAttribute('data-url') || '';
            const previewIdx = tile.getAttribute('data-preview-idx');
            if (previewIdx !== null && previewIdx !== '') {
              const idx = Number(previewIdx);
              if (Number.isFinite(idx) && idx >= 0 && idx < selected.length) {
                selected.splice(idx, 1);
                syncInputFiles();
              }
            } else if (kind === 'gallery' && url) {
              removeGalleryUrl(url);
            } else if (kind === 'main') {
              const imageUrlField = document.getElementById('imageUrl');
              if (imageUrlField && imageUrlField.value === url) imageUrlField.value = '';
              const removeMainImageField = document.getElementById('removeMainImage');
              if (removeMainImageField) removeMainImageField.value = 'true';
            }
            tile.remove();
            syncMediaOrder();
          });
        }

        const renderPreviewTiles = () => {
          Array.from(grid.querySelectorAll('[data-preview="true"]')).forEach((el) => el.remove());

          const beforeNode = uploadBtn;
          selected.forEach((f, idx) => {
            const url = URL.createObjectURL(f);
            const isVid = isVideoFile(f);
            const wrapper = document.createElement('div');
            wrapper.className = 'relative group aspect-square rounded-lg border border-border-light dark:border-border-dark overflow-hidden bg-white media-tile';
            wrapper.setAttribute('data-kind', 'preview');
            wrapper.setAttribute('data-preview', 'true');
            wrapper.setAttribute('data-preview-idx', String(idx));
            wrapper.setAttribute('data-url', url);
            wrapper.setAttribute('data-type', isVid ? 'video' : 'image');

            let thumb;
            if (isVid) {
              thumb = document.createElement('video');
              thumb.className = 'w-full h-full object-cover';
              thumb.muted = true;
              thumb.playsInline = true;
              thumb.preload = 'metadata';
              const src = document.createElement('source');
              src.src = url;
              src.type = f.type || '';
              thumb.appendChild(src);

              const badge = document.createElement('span');
              badge.className = 'absolute top-1 left-1 bg-black/70 text-white text-[8px] font-bold px-1.5 py-0.5 rounded flex items-center gap-1';
              badge.innerHTML = '<span class="material-symbols-outlined text-[10px] leading-none">play_circle</span>VIDÉO';
              wrapper.appendChild(thumb);
              wrapper.appendChild(badge);
            } else {
              thumb = document.createElement('img');
              thumb.alt = 'Product';
              thumb.className = 'w-full h-full object-cover';
              thumb.src = url;
              wrapper.appendChild(thumb);
            }

            const overlay = document.createElement('div');
            overlay.className = 'absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-2';

            const handleBtn = document.createElement('button');
            handleBtn.type = 'button';
            handleBtn.className = 'p-1.5 bg-white text-slate-900 rounded-full cursor-grab';
            handleBtn.setAttribute('data-action', 'drag-handle');
            handleBtn.setAttribute('title', 'Glisser pour réordonner');
            handleBtn.innerHTML = '<span class="material-symbols-outlined text-sm">drag_indicator</span>';

            const moveLeftBtn = document.createElement('button');
            moveLeftBtn.type = 'button';
            moveLeftBtn.className = 'p-1.5 bg-white text-slate-900 rounded-full';
            moveLeftBtn.setAttribute('data-action', 'move-left');
            moveLeftBtn.setAttribute('title', 'Déplacer à gauche');
            moveLeftBtn.innerHTML = '<span class="material-symbols-outlined text-sm">arrow_back</span>';

            const moveRightBtn = document.createElement('button');
            moveRightBtn.type = 'button';
            moveRightBtn.className = 'p-1.5 bg-white text-slate-900 rounded-full';
            moveRightBtn.setAttribute('data-action', 'move-right');
            moveRightBtn.setAttribute('title', 'Déplacer à droite');
            moveRightBtn.innerHTML = '<span class="material-symbols-outlined text-sm">arrow_forward</span>';

            const delBtn = document.createElement('button');
            delBtn.type = 'button';
