            ? JSON.parse(seoSeedEl.textContent)
            : { baseUrl: '', productId: 'ID' };
        } catch (e) {
          SEO_SEED = { baseUrl: '', productId: 'ID' };
        }

        const productOptionTemplatesEl = document.getElementById('productOptionTemplatesJson');
        let PRODUCT_OPTION_TEMPLATES = [];
        try {
          PRODUCT_OPTION_TEMPLATES = productOptionTemplatesEl && productOptionTemplatesEl.textContent
            ? JSON.parse(productOptionTemplatesEl.textContent)
            : [];
        } catch (e) {
          PRODUCT_OPTION_TEMPLATES = [];
        }

        const DEFAULT_MAKES = [
          'Audi',
