          if (stepsField && typeof draft.reconditioningSteps === 'string') {
            stepsField.value = draft.reconditioningSteps;
            aiTouchedFields.add('reconditioningSteps');
            validatedFields.delete('reconditioningSteps');
            hydrateStepsGridFromField();
          }

          if (optionsField) {
            optionsField.value = typeof draft.optionsJson === 'string' ? draft.optionsJson : '';
            if (String(optionsField.value || '').trim()) {
              aiTouchedFields.add('optionsJson');
              validatedFields.delete('optionsJson');
            }
            if (!String(optionsField.value || '').trim()) {
              productOptionsState = [];
            } else {
              try {
                const parsed = JSON.parse(optionsField.value);
                productOptionsState = Array.isArray(parsed) ? parsed.map((option, index) => createOptionState(option, index)) : [];
              } catch (e) {
                productOptionsState = [];
              }
            }
            renderProductOptionsEditor();
            renderTemplateLibrary();
            syncOptionsField();
