          if (typeof updateSeoAssistant === 'function') updateSeoAssistant();
          renderAiWarnings(Array.isArray(draft.warnings) ? draft.warnings : []);
          if (latestAiDraftJob) latestAiDraftJob.status = 'completed';
          updateAiCancelButton();
          setAiStatus(`Brouillon IA généré${data && data.model ? ' avec ' + data.model : ''}. Relisez puis cliquez sur "Enregistrer" si tout vous convient.`, 'success');
          toast.success('Génération terminée !');
        }

        async function waitForDraftJob(jobId) {
          const maxWaitMs = 10 * 60 * 1000;
          const startedAt = Date.now();
          let attempt = 0;

          while ((Date.now() - startedAt) < maxWaitMs) {
            if (attempt > 0) {
              await sleep(3000);
            }
            attempt += 1;

            const statusResponse = await fetch(`/admin/api/products/generate-draft/${encodeURIComponent(jobId)}`, {
              method: 'GET',
              headers: {
                'Accept': 'application/json',
              },
            });

            const statusData = await statusResponse.json().catch(() => ({}));
            if (!statusResponse.ok || !statusData || statusData.ok !== true) {
              throw new Error(statusData && statusData.error ? statusData.error : 'Impossible de suivre la génération IA.');
            }

            if (statusData.status === 'completed' && statusData.draft) {
              return statusData;
            }

            if (statusData.status === 'failed') {
              throw new Error(statusData.error || 'La génération IA a échoué.');
            }

            if (statusData.status === 'canceled') {
              throw new Error(statusData.error || 'Génération IA arrêtée à la demande.');
            }

            setAiStatus(`Recherche web et génération approfondie en cours… ${attempt > 1 ? 'Toujours en cours, merci de patienter.' : 'La page attend le résultat en arrière-plan.'}`, 'loading');
          }

          throw new Error('La génération IA prend vraiment trop de temps. Réessayez dans quelques instants.');
        }

