        function getFieldReviewValue(def) {
          if (!def) return '';
          if (typeof def.getValue === 'function') return String(def.getValue() || '').trim();
          const el = document.getElementById(def.id);
          if (!el) return '';
          if (el.type === 'checkbox') return el.checked ? 'true' : '';
          return String(el.value || '').trim();
        }

        function findFieldReviewMount(def) {
          if (!def) return null;
          if (def.mountSelector) return document.querySelector(def.mountSelector);
          return document.querySelector(`label[for="${def.id}"]`);
        }

        function getFieldHighlightElement(def) {
          return document.getElementById(def && def.highlightId ? def.highlightId : (def ? def.id : ''));
        }

        function syncFieldReviewInline(def, { hasValue, isAi, isValidated } = {}) {
          const mount = findFieldReviewMount(def);
          if (!mount) return;

          let inline = document.querySelector(`[data-field-review-inline="${def.id}"]`);
          if (!inline) {
            inline = document.createElement('span');
            inline.className = 'field-review-inline';
            inline.setAttribute('data-field-review-inline', def.id);

            const aiBadge = document.createElement('span');
            aiBadge.className = 'hidden rounded-full bg-violet-100 px-1.5 py-0.5 text-[9px] font-semibold uppercase tracking-widest text-violet-700';
            aiBadge.setAttribute('data-field-review-ai-badge', def.id);
            aiBadge.textContent = 'IA';

            const checkbox = document.createElement('input');
            checkbox.type = 'checkbox';
            checkbox.className = 'h-3.5 w-3.5 rounded border-gray-300 text-emerald-600 focus:ring-emerald-500';
            checkbox.title = `Valider ${def.label}`;
            checkbox.setAttribute('data-field-review-checkbox', def.id);
            checkbox.addEventListener('change', () => {
              if (checkbox.checked) validatedFields.add(def.id);
              else validatedFields.delete(def.id);
              refreshFieldReviewPanel();
            });

            inline.appendChild(aiBadge);
            inline.appendChild(checkbox);

            if (mount.tagName === 'LABEL') {
              mount.appendChild(inline);
            } else {
              mount.insertAdjacentElement('afterend', inline);
            }
          }

          const aiBadge = inline.querySelector(`[data-field-review-ai-badge="${def.id}"]`);
          const checkbox = inline.querySelector(`[data-field-review-checkbox="${def.id}"]`);
          if (aiBadge) aiBadge.classList.toggle('hidden', !isAi);
          if (checkbox) {
            checkbox.checked = !!isValidated;
            checkbox.disabled = !hasValue;
          }
          inline.classList.toggle('opacity-50', !hasValue);
        }

        function applyFieldReviewHighlight(def, state) {
          const target = getFieldHighlightElement(def);
          if (!target) return;
          target.classList.remove('field-review-empty', 'field-review-ai', 'field-review-validated');
          if (state === 'empty') target.classList.add('field-review-empty');
          if (state === 'ai') target.classList.add('field-review-ai');
          if (state === 'validated') target.classList.add('field-review-validated');
        }

        function refreshFieldReviewPanel() {
          let emptyCount = 0;
          let aiCount = 0;
          let validatedCount = 0;

          FIELD_REVIEW_DEFS.forEach((def) => {
            const value = getFieldReviewValue(def);
            const hasValue = !!value;
            if (!hasValue) {
              aiTouchedFields.delete(def.id);
              validatedFields.delete(def.id);
            }

            const isAi = hasValue && aiTouchedFields.has(def.id);
            const isValidated = hasValue && validatedFields.has(def.id);

            if (!hasValue) emptyCount += 1;
            if (isAi) aiCount += 1;
            if (isValidated) validatedCount += 1;

            applyFieldReviewHighlight(def, !hasValue ? 'empty' : (isValidated ? 'validated' : (isAi ? 'ai' : 'filled')));
            syncFieldReviewInline(def, { hasValue, isAi, isValidated });
          });

          if (fieldReviewEmptyCount) fieldReviewEmptyCount.textContent = String(emptyCount);
          if (fieldReviewAiCount) fieldReviewAiCount.textContent = String(aiCount);
          if (fieldReviewValidatedCount) fieldReviewValidatedCount.textContent = String(validatedCount);
        }

        const compatIndexEl = document.getElementById('compatIndexJson');
