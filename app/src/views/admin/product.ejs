          PRODUCT_OPTION_TEMPLATES.forEach((template) => {
            const templateId = String(template && template.id ? template.id : '');
            const checked = productOptionsState.some((option) => String(option && option.templateId ? option.templateId : '') === templateId);
            const disabled = template && template.isActive === false && !checked;

            const card = document.createElement('label');
