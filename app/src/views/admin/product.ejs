              const choices = document.createElement('div');
              choices.className = 'mt-2 flex flex-wrap gap-2';
              template.choices.slice(0, 3).forEach((choice) => {
                const badge = document.createElement('span');
                badge.className = 'inline-flex items-center rounded-full bg-slate-100 px-2 py-1 text-[10px] font-bold text-slate-500';
                badge.textContent = choice && choice.label ? choice.label : 'Choix';
                choices.appendChild(badge);
              });
              content.appendChild(choices);
            }

            input.addEventListener('change', () => {
              if (!templateId) return;
              productOptionsState = productOptionsState.filter((option) => String(option && option.templateId ? option.templateId : '') !== templateId);
              if (input.checked) {
                productOptionsState.push(buildOptionStateFromTemplate(template));
              }
              renderProductOptionsEditor();
              renderTemplateLibrary();
              syncOptionsField();
            });

            card.appendChild(input);
            card.appendChild(content);
            templateLibrary.appendChild(card);
          });
        };

        const createField = (labelText, wide) => {
          const wrap = document.createElement('div');
          if (wide) wrap.className = 'md:col-span-2';

          const label = document.createElement('label');
          label.className = 'block text-[11px] font-bold uppercase tracking-widest text-slate-500';
          label.textContent = labelText;
          wrap.appendChild(label);
          return { wrap, label };
        };

        function renderProductOptionsEditor() {
          if (!optionsBuilder) return;
          optionsBuilder.innerHTML = '';

          productOptionsState.forEach((option, index) => {
            const card = document.createElement('div');
            card.className = 'rounded-2xl border border-border-light dark:border-border-dark bg-gray-50 dark:bg-gray-900/50 p-5';

            const header = document.createElement('div');
            header.className = 'flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4';

            const headerLeft = document.createElement('div');
            const title = document.createElement('div');
            title.className = 'text-sm font-bold text-slate-900 dark:text-white';
            title.textContent = option && option.label ? option.label : `Option ${index + 1}`;

            const badges = document.createElement('div');
            badges.className = 'mt-2 flex flex-wrap items-center gap-2';

            const typeBadge = document.createElement('span');
            typeBadge.className = `inline-flex items-center rounded-full px-2 py-1 text-[10px] font-semibold uppercase tracking-widest ${option && option.type === 'text' ? 'bg-sky-50 text-sky-700' : 'bg-violet-50 text-violet-700'}`;
            typeBadge.textContent = option && option.type === 'text' ? 'Texte libre' : 'Liste de choix';
            badges.appendChild(typeBadge);

            if (option && option.templateId) {
              const fromTemplate = document.createElement('span');
              fromTemplate.className = 'inline-flex items-center rounded-full bg-primary/10 px-2 py-1 text-[10px] font-semibold uppercase tracking-widest text-primary';
              fromTemplate.textContent = 'Issue de la bibliothèque';
              badges.appendChild(fromTemplate);
            }

            headerLeft.appendChild(title);
            headerLeft.appendChild(badges);

            const removeBtn = document.createElement('button');
            removeBtn.type = 'button';
            removeBtn.className = 'inline-flex items-center justify-center rounded-lg border border-red-200 bg-white px-4 py-2 text-xs font-bold uppercase tracking-wider text-red-600 hover:bg-red-50 transition';
            removeBtn.innerHTML = '<span class="material-symbols-outlined mr-2 text-sm">delete</span>Retirer';
            removeBtn.addEventListener('click', () => {
              productOptionsState.splice(index, 1);
              renderProductOptionsEditor();
              renderTemplateLibrary();
              syncOptionsField();
            });

            header.appendChild(headerLeft);
            header.appendChild(removeBtn);
            card.appendChild(header);

            const fields = document.createElement('div');
            fields.className = 'mt-5 grid grid-cols-1 md:grid-cols-2 gap-4';

            const labelField = createField('Nom affiché');
            const labelInput = document.createElement('input');
            labelInput.className = 'mt-2 w-full rounded-xl border border-border-light dark:border-border-dark bg-white dark:bg-gray-900 px-4 py-3 text-sm';
            labelInput.type = 'text';
            labelInput.value = option && option.label ? option.label : '';
            labelInput.placeholder = 'Ex: Programmation';
            labelField.wrap.appendChild(labelInput);

            const keyField = createField('Clé technique');
            const keyInput = document.createElement('input');
            keyInput.className = 'mt-2 w-full rounded-xl border border-border-light dark:border-border-dark bg-white dark:bg-gray-900 px-4 py-3 text-sm';
            keyInput.type = 'text';
            keyInput.value = option && option.key ? option.key : '';
            keyInput.placeholder = 'Ex: programmation';
            keyField.wrap.appendChild(keyInput);

            const typeField = createField('Type');
            const typeSelect = document.createElement('select');
            typeSelect.className = 'mt-2 w-full rounded-xl border border-border-light dark:border-border-dark bg-white dark:bg-gray-900 px-4 py-3 text-sm';
            typeSelect.innerHTML = '<option value="choice">Liste de choix</option><option value="text">Texte libre</option>';
            typeSelect.value = option && option.type === 'text' ? 'text' : 'choice';
            typeField.wrap.appendChild(typeSelect);

            const requiredWrap = document.createElement('div');
            requiredWrap.className = 'flex items-end';
            const requiredLabel = document.createElement('label');
            requiredLabel.className = 'inline-flex items-center gap-3 rounded-xl border border-border-light dark:border-border-dark bg-white dark:bg-gray-900 px-4 py-3 text-sm font-semibold text-slate-500 dark:text-gray-200';
            const requiredInput = document.createElement('input');
            requiredInput.className = 'rounded border-gray-300 text-primary focus:ring-primary';
            requiredInput.type = 'checkbox';
            requiredInput.checked = !!(option && option.required);
            const requiredText = document.createElement('span');
            requiredText.textContent = 'Champ obligatoire';
            requiredLabel.appendChild(requiredInput);
            requiredLabel.appendChild(requiredText);
            requiredWrap.appendChild(requiredLabel);

            const placeholderField = createField('Placeholder');
            const placeholderInput = document.createElement('input');
            placeholderInput.className = 'mt-2 w-full rounded-xl border border-border-light dark:border-border-dark bg-white dark:bg-gray-900 px-4 py-3 text-sm';
            placeholderInput.type = 'text';
            placeholderInput.value = option && option.placeholder ? option.placeholder : '';
            placeholderInput.placeholder = 'Ex : Tapez la référence';
            placeholderField.wrap.appendChild(placeholderInput);

            const helpField = createField('Texte d\'aide', true);
            const helpInput = document.createElement('input');
            helpInput.className = 'mt-2 w-full rounded-xl border border-border-light dark:border-border-dark bg-white dark:bg-gray-900 px-4 py-3 text-sm';
            helpInput.type = 'text';
            helpInput.value = option && option.helpText ? option.helpText : '';
            helpInput.placeholder = 'Ex : Choisissez si la pièce doit être programmée';
            helpField.wrap.appendChild(helpInput);

            const priceField = createField('Supplément prix (€)');
            const priceInput = document.createElement('input');
            priceInput.className = 'mt-2 w-full rounded-xl border border-border-light dark:border-border-dark bg-white dark:bg-gray-900 px-4 py-3 text-sm';
            priceInput.type = 'text';
            priceInput.value = formatPriceInputFromCents(option && option.priceDeltaCents ? option.priceDeltaCents : 0);
            priceInput.placeholder = 'Ex: 49,90';
            priceField.wrap.appendChild(priceInput);

            fields.appendChild(labelField.wrap);
            fields.appendChild(keyField.wrap);
            fields.appendChild(typeField.wrap);
            fields.appendChild(requiredWrap);
            fields.appendChild(placeholderField.wrap);
            fields.appendChild(priceField.wrap);
            fields.appendChild(helpField.wrap);
            card.appendChild(fields);

            const choicesWrap = document.createElement('div');
            choicesWrap.className = 'mt-5';
            card.appendChild(choicesWrap);

            const renderChoices = () => {
              choicesWrap.innerHTML = '';
              priceField.wrap.style.display = option && option.type === 'text' ? '' : 'none';
              if (!option || option.type !== 'choice') return;

              const top = document.createElement('div');
              top.className = 'flex items-center justify-between gap-4';

              const titleChoices = document.createElement('div');
              titleChoices.className = 'text-xs font-bold uppercase tracking-widest text-slate-500';
              titleChoices.textContent = 'Choix proposés';
              top.appendChild(titleChoices);

              const addChoiceBtn = document.createElement('button');
              addChoiceBtn.type = 'button';
              addChoiceBtn.className = 'inline-flex items-center justify-center rounded-lg border border-border-light dark:border-border-dark px-4 py-2 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-gray-200 hover:bg-white dark:hover:bg-gray-800 transition';
              addChoiceBtn.innerHTML = '<span class="material-symbols-outlined mr-2 text-sm">add</span>Ajouter un choix';
              addChoiceBtn.addEventListener('click', () => {
                option.choices = Array.isArray(option.choices) ? option.choices : [];
                option.choices.push(createChoiceState({}));
                renderProductOptionsEditor();
                syncOptionsField();
              });
              top.appendChild(addChoiceBtn);
              choicesWrap.appendChild(top);

              const list = document.createElement('div');
              list.className = 'mt-3 space-y-3';

              const choices = Array.isArray(option.choices) && option.choices.length ? option.choices : [createChoiceState({})];
              option.choices = choices;

              choices.forEach((choice, choiceIndex) => {
                const row = document.createElement('div');
                row.className = 'grid grid-cols-1 md:grid-cols-[1fr_150px_150px_auto_auto] gap-3 items-end rounded-xl border border-border-light dark:border-border-dark bg-white dark:bg-gray-900 p-4';

                const choiceLabelField = createField('Libellé');
                const choiceLabelInput = document.createElement('input');
                choiceLabelInput.className = 'mt-2 w-full rounded-xl border border-border-light dark:border-border-dark bg-gray-50 dark:bg-gray-950 px-4 py-3 text-sm';
                choiceLabelInput.type = 'text';
                choiceLabelInput.value = choice && choice.label ? choice.label : '';
                choiceLabelInput.placeholder = 'Ex: Avec programmation';
                choiceLabelField.wrap.appendChild(choiceLabelInput);

                const choiceAbsolutePriceField = createField('Prix final (€)');
                const choiceAbsolutePriceInput = document.createElement('input');
                choiceAbsolutePriceInput.className = 'mt-2 w-full rounded-xl border border-border-light dark:border-border-dark bg-gray-50 dark:bg-gray-950 px-4 py-3 text-sm';
                choiceAbsolutePriceInput.type = 'text';
                choiceAbsolutePriceInput.value = formatPriceInputFromCents(choice && choice.absolutePriceCents);
                choiceAbsolutePriceInput.placeholder = 'Ex: 199,90';
                choiceAbsolutePriceField.wrap.appendChild(choiceAbsolutePriceInput);

                const choicePriceField = createField('Supplément (€)');
                const choicePriceInput = document.createElement('input');
                choicePriceInput.className = 'mt-2 w-full rounded-xl border border-border-light dark:border-border-dark bg-gray-50 dark:bg-gray-950 px-4 py-3 text-sm';
                choicePriceInput.type = 'text';
                choicePriceInput.value = formatPriceInputFromCents(choice && choice.priceDeltaCents ? choice.priceDeltaCents : 0);
                choicePriceInput.placeholder = 'Ex: 49,90';
                choicePriceField.wrap.appendChild(choicePriceInput);

                const removeChoiceBtn = document.createElement('button');
                removeChoiceBtn.type = 'button';
                removeChoiceBtn.className = 'inline-flex items-center justify-center rounded-lg border border-red-200 bg-white px-4 py-3 text-xs font-bold uppercase tracking-wider text-red-600 hover:bg-red-50 transition';
                removeChoiceBtn.textContent = 'Supprimer';
                removeChoiceBtn.addEventListener('click', () => {
                  option.choices.splice(choiceIndex, 1);
                  if (!option.choices.length) option.choices.push(createChoiceState({}));
                  renderProductOptionsEditor();
                  syncOptionsField();
                });

                choiceLabelInput.addEventListener('input', () => {
                  const previousLabel = choice.label || '';
                  choice.label = choiceLabelInput.value;
                  if (!choice.key || choice.key === slugifyOptionKey(previousLabel)) {
                    choice.key = slugifyOptionKey(choice.label);
                  }
                  syncOptionsField();
                });

                choiceAbsolutePriceInput.addEventListener('blur', () => {
                  const parsed = parseOptionalPriceInputToCents(choiceAbsolutePriceInput.value);
                  if (parsed !== null || !String(choiceAbsolutePriceInput.value || '').trim()) {
                    choice.absolutePriceCents = parsed;
                  }
                  choiceAbsolutePriceInput.value = formatPriceInputFromCents(choice.absolutePriceCents);
                  syncOptionsField();
                });

                choicePriceInput.addEventListener('blur', () => {
                  const parsed = parsePriceInputToCents(choicePriceInput.value);
                  if (parsed !== null) choice.priceDeltaCents = parsed;
                  choicePriceInput.value = formatPriceInputFromCents(choice.priceDeltaCents);
                  syncOptionsField();
                });

                const cloningField = document.createElement('div');
                cloningField.className = 'flex flex-col items-center justify-end pb-1';
                const cloningLabel = document.createElement('label');
                cloningLabel.className = 'text-[10px] font-semibold uppercase tracking-widest text-slate-500 mb-2';
                cloningLabel.textContent = 'Clonage';
                const cloningCheckbox = document.createElement('input');
                cloningCheckbox.type = 'checkbox';
                cloningCheckbox.className = 'w-5 h-5 rounded border-slate-300 text-red-600 focus:ring-red-500';
                cloningCheckbox.checked = choice && choice.triggersCloning === true;
                cloningCheckbox.addEventListener('change', () => {
                  choice.triggersCloning = cloningCheckbox.checked;
                  syncOptionsField();
                });
                cloningField.appendChild(cloningLabel);
                cloningField.appendChild(cloningCheckbox);

                row.appendChild(choiceLabelField.wrap);
                row.appendChild(choiceAbsolutePriceField.wrap);
                row.appendChild(choicePriceField.wrap);
                row.appendChild(cloningField);
                row.appendChild(removeChoiceBtn);
                list.appendChild(row);
              });

              choicesWrap.appendChild(list);
            };

            labelInput.addEventListener('input', () => {
              const previousLabel = option.label || '';
              const previousKey = option.key || '';
              option.label = labelInput.value;
              if (!previousKey || previousKey === slugifyOptionKey(previousLabel)) {
                option.key = slugifyOptionKey(option.label);
                keyInput.value = option.key;
              }
              title.textContent = option.label ? option.label : `Option ${index + 1}`;
              syncOptionsField();
            });

            keyInput.addEventListener('input', () => {
              option.key = keyInput.value;
              syncOptionsField();
            });

            typeSelect.addEventListener('change', () => {
              option.type = typeSelect.value === 'text' ? 'text' : 'choice';
              if (option.type === 'choice' && (!Array.isArray(option.choices) || !option.choices.length)) {
                option.choices = [createChoiceState({})];
              }
              if (option.type === 'text') {
                option.choices = [createChoiceState({})];
              }
              renderProductOptionsEditor();
              syncOptionsField();
            });

            requiredInput.addEventListener('change', () => {
              option.required = requiredInput.checked;
              syncOptionsField();
            });

            placeholderInput.addEventListener('input', () => {
              option.placeholder = placeholderInput.value;
              syncOptionsField();
            });

            helpInput.addEventListener('input', () => {
              option.helpText = helpInput.value;
              syncOptionsField();
            });

            priceInput.addEventListener('blur', () => {
              const parsed = parsePriceInputToCents(priceInput.value);
              if (parsed !== null) option.priceDeltaCents = parsed;
              priceInput.value = formatPriceInputFromCents(option.priceDeltaCents);
              syncOptionsField();
            });

            renderChoices();
            optionsBuilder.appendChild(card);
          });

          if (optionsEmpty) optionsEmpty.classList.toggle('hidden', productOptionsState.length > 0);
        }

        if (addCustomOptionBtn) {
          addCustomOptionBtn.addEventListener('click', () => {
            productOptionsState.push(createEmptyOptionState());
            renderProductOptionsEditor();
            renderTemplateLibrary();
            syncOptionsField();
          });
        }

        if (applyOptionsJsonBtn) {
          applyOptionsJsonBtn.addEventListener('click', () => {
            if (!optionsField) return;
            const raw = String(optionsField.value || '').trim();
            if (!raw) {
              productOptionsState = [];
              renderProductOptionsEditor();
              renderTemplateLibrary();
              syncOptionsField();
              return;
            }

            try {
              const parsed = JSON.parse(raw);
              if (!Array.isArray(parsed)) throw new Error('invalid');
              productOptionsState = parsed.map((option, index) => createOptionState(option, index));
              renderProductOptionsEditor();
              renderTemplateLibrary();
              syncOptionsField();
            } catch (e) {
              toast.error('Le JSON des options est invalide.');
            }
          });
        }

        renderProductOptionsEditor();
        renderTemplateLibrary();
        syncOptionsField();

        const parseSteps = () => {
          const lines = parseLinesValue(stepsField ? stepsField.value : '');
          const out = [];
          lines.forEach((line) => {
            const idx = line.indexOf(':');
            if (idx === -1) return;
            const title = line.slice(0, idx).trim();
            const description = line.slice(idx + 1).trim();
            if (!title && !description) return;
            out.push({ title, description });
          });
          while (out.length < 4) out.push({ title: '', description: '' });
          return out.slice(0, 4);
        };

        const syncStepsField = () => {
          if (!stepsField || !stepsGrid) return;
          const blocks = Array.from(stepsGrid.querySelectorAll('[data-step]'));
          const lines = blocks
            .map((b) => {
              const sel = b.querySelector('[data-step-title-select]');
              const custom = b.querySelector('[data-step-title-custom]');
              const selValue = sel && sel.value ? String(sel.value) : '';
              const t = selValue === '__custom__'
                ? ((custom || {}).value || '')
                : selValue;
              const d = (b.querySelector('[data-step-description]') || {}).value || '';
              const title = String(t).trim();
              const desc = String(d).trim();
              if (!title && !desc) return '';
              return `${title}: ${desc}`.trim();
            })
            .filter(Boolean);
          stepsField.value = lines.join('\n');
          refreshFieldReviewPanel();
        };

        if (stepsGrid && stepsField) {
          const STEP_PRESETS = {
            Diagnostic: 'Contrôle visuel et lecture des défauts initiaux.',
            Nettoyage: 'Démontage complet et nettoyage ultrason.',
            Remplacement: 'Électrovannes, joints et capteurs critiques changés.',
            'Test Banc': 'Simulation conditions réelles et programmation.',
          };

          const applyStepTitle = (block, title) => {
            const sel = block ? block.querySelector('[data-step-title-select]') : null;
            const custom = block ? block.querySelector('[data-step-title-custom]') : null;
            const exists = sel ? Array.from(sel.options || []).some((o) => o && o.value === title) : false;

            if (!sel) return;

            if (exists || title === '') {
              sel.value = title;
              if (custom) {
                custom.classList.add('hidden');
                custom.value = '';
              }
              return;
            }

            sel.value = '__custom__';
            if (custom) {
              custom.classList.remove('hidden');
              custom.value = title;
            }
          };

          const applyPresetSteps = () => {
            const blocks = Array.from(stepsGrid.querySelectorAll('[data-step]'));
            const titles = ['Diagnostic', 'Nettoyage', 'Remplacement', 'Test Banc'];

            blocks.slice(0, 4).forEach((b, i) => {
              const title = titles[i] || '';
              applyStepTitle(b, title);
              const d = b.querySelector('[data-step-description]');
              if (d) d.value = STEP_PRESETS[title] || '';
            });

            syncStepsField();
          };

          const stepsPrefillBtn = document.getElementById('stepsPrefillBtn');
          if (stepsPrefillBtn) {
            stepsPrefillBtn.addEventListener('click', () => {
              const current = String(stepsField.value || '').trim();
              if (current) {
                const ok = window.confirm('Remplacer les étapes déjà remplies par le modèle (4 étapes) ?');
                if (!ok) return;
              }
              applyPresetSteps();
            });
          }

          hydrateStepsGridFromField = function () {
            const initial = parseSteps();
            const blocks = Array.from(stepsGrid.querySelectorAll('[data-step]'));
            blocks.forEach((b, i) => {
              const sel = b.querySelector('[data-step-title-select]');
              const custom = b.querySelector('[data-step-title-custom]');
              const d = b.querySelector('[data-step-description]');
              const initialTitle = initial[i] ? String(initial[i].title || '').trim() : '';

              if (sel) {
                const exists = Array.from(sel.options || []).some((o) => o && o.value === initialTitle);
                if (exists || initialTitle === '') {
                  sel.value = initialTitle;
                  if (custom) custom.classList.add('hidden');
                } else {
                  sel.value = '__custom__';
                  if (custom) {
                    custom.classList.remove('hidden');
                    custom.value = initialTitle;
                  }
                }
              }
              if (d) d.value = initial[i] ? initial[i].description : '';
            });
          };

          hydrateStepsGridFromField();
          stepsGrid.addEventListener('input', syncStepsField);
          stepsGrid.addEventListener('change', (e) => {
            const target = e && e.target ? e.target : null;
            if (!target) return;
            if (target.matches && target.matches('[data-step-title-select]')) {
              const block = target.closest('[data-step]');
              if (!block) return;
              const custom = block.querySelector('[data-step-title-custom]');
              if (!custom) return;
              if (String(target.value) === '__custom__') custom.classList.remove('hidden');
              else custom.classList.add('hidden');

              const selectedTitle = String(target.value || '').trim();
              const descField = block.querySelector('[data-step-description]');
              const currentDesc = descField ? String(descField.value || '').trim() : '';
              if (descField && !currentDesc && STEP_PRESETS[selectedTitle]) {
                descField.value = STEP_PRESETS[selectedTitle];
              }

              syncStepsField();
            }
          });
        }

        const parseCompatibility = () => {
          const lines = parseLinesValue(compatField ? compatField.value : '');
          return lines
            .map((line) => {
              const parts = line.split('|').map((p) => String(p || '').trim());
              return {
                make: parts[0] || '',
                model: parts[1] || '',
                years: parts[2] || '',
                engine: parts[3] || '',
              };
            })
            .filter((x) => x.make || x.model || x.years || x.engine);
        };

        const syncCompatibilityField = (items) => {
          if (!compatField) return;
          compatField.value = items
            .map((x) => `${x.make} | ${x.model} | ${x.years} | ${x.engine}`.trim())
            .join('\n');

          if (typeof updateSeoAssistant === 'function') updateSeoAssistant();
          refreshFieldReviewPanel();
        };

        let compatItems = parseCompatibility();
        let selectedMake = compatItems.length ? (compatItems[0].make || '') : '';

        const makeList = () => {
          const fromData = compatItems.map((x) => x.make).filter(Boolean);
          const fromServer = SERVER_COMPAT_INDEX && Array.isArray(SERVER_COMPAT_INDEX.makes) ? SERVER_COMPAT_INDEX.makes : [];
          const all = Array.from(new Set([...DEFAULT_MAKES, ...fromServer, ...fromData])).sort((a, b) => String(a).localeCompare(String(b), 'fr'));
          return all;
        };

        const resolveMakeKey = (value) => {
          const raw = String(value || '').trim();
          if (!raw) return '';
          const low = raw.toLowerCase();
          const all = makeList();
          const exact = all.find((m) => String(m).toLowerCase() === low);
          return exact || raw;
        };

        const setSelectMakeOptions = (select, values) => {
          if (!select) return;
          const current = select.value;
          select.innerHTML = '';

          const placeholder = document.createElement('option');
          placeholder.value = '';
          placeholder.textContent = 'Choisir une marque...';
          select.appendChild(placeholder);

          values.forEach((v) => {
            const o = document.createElement('option');
            o.value = v;
            o.textContent = v;
            select.appendChild(o);
          });

          const custom = document.createElement('option');
          custom.value = '__custom__';
          custom.textContent = 'Autre (nouvelle marque)';
          select.appendChild(custom);

          if (current) select.value = current;
        };

        const setSelectModelOptions = (select, values) => {
          if (!select) return;
          const current = select.value;
          select.innerHTML = '';

          const placeholder = document.createElement('option');
          placeholder.value = '';
          placeholder.textContent = 'Choisir un modèle...';
          select.appendChild(placeholder);

          values.forEach((v) => {
            const o = document.createElement('option');
            o.value = v;
            o.textContent = v;
            select.appendChild(o);
          });

          const custom = document.createElement('option');
          custom.value = '__custom__';
          custom.textContent = 'Autre (nouveau modèle)';
          select.appendChild(custom);

          if (current) select.value = current;
        };

        const modelsForMake = (mk) => {
          const fromData = compatItems
            .filter((x) => x.make && mk && x.make === mk && x.model)
            .map((x) => x.model);
          const fromServer = SERVER_COMPAT_INDEX && SERVER_COMPAT_INDEX.modelsByMake && SERVER_COMPAT_INDEX.modelsByMake[mk]
            ? SERVER_COMPAT_INDEX.modelsByMake[mk]
            : [];
          const all = Array.from(new Set([...(Array.isArray(fromServer) ? fromServer : []), ...fromData]))
            .sort((a, b) => String(a).localeCompare(String(b), 'fr'));
          return all;
        };

        const renderModelsList = () => {
          if (!compatModels || !compatModelsLabel) return;
          compatModelsLabel.textContent = selectedMake ? `Compatible Models (${selectedMake})` : 'Compatible Models';
          compatModels.innerHTML = '';
          const models = compatItems.filter((x) => (selectedMake ? x.make === selectedMake : true));
          models.forEach((x, idx) => {
            const card = document.createElement('div');
