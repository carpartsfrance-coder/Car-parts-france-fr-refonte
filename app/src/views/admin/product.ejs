        // Drag-and-drop dropzone on the media grid
        if (canUseMedia) {
          let dragDepth = 0;
          const isFileDrag = (e) => {
            if (!e || !e.dataTransfer) return false;
            const types = e.dataTransfer.types;
            if (!types) return false;
            for (let i = 0; i < types.length; i++) {
              if (types[i] === 'Files') return true;
            }
            return false;
          };

          grid.addEventListener('dragenter', (e) => {
            if (!isFileDrag(e)) return;
            e.preventDefault();
            dragDepth++;
            grid.classList.add('is-dropzone-active');
          });
          grid.addEventListener('dragover', (e) => {
            if (!isFileDrag(e)) return;
            e.preventDefault();
            try { e.dataTransfer.dropEffect = 'copy'; } catch (_) {}
          });
          grid.addEventListener('dragleave', (e) => {
            if (!isFileDrag(e)) return;
            dragDepth = Math.max(0, dragDepth - 1);
            if (dragDepth === 0) grid.classList.remove('is-dropzone-active');
          });
          grid.addEventListener('drop', (e) => {
            if (!isFileDrag(e)) return;
            e.preventDefault();
            dragDepth = 0;
            grid.classList.remove('is-dropzone-active');
            const dropped = e.dataTransfer && e.dataTransfer.files;
            if (dropped && dropped.length) ingestFiles(dropped);
          });
