        ];

        const parseLinesValue = (value) => String(value || '').split(/\r?\n/).map((s) => s.trim()).filter(Boolean);

        const specsField = document.getElementById('specs');
        const specTypeInput = document.getElementById('specType');
        const specProgrammationInput = document.getElementById('specProgrammation');

        const parseSpecPairs = (value) => {
          const lines = parseLinesValue(value);
          const pairs = [];

          lines.forEach((line) => {
            const sepIndex = line.indexOf(':') >= 0
              ? line.indexOf(':')
              : (line.indexOf('=') >= 0 ? line.indexOf('=') : line.indexOf('|'));
            if (sepIndex <= 0) return;

            const label = line.slice(0, sepIndex).trim();
            const val = line.slice(sepIndex + 1).trim();
            if (!label || !val) return;

            pairs.push({ label, value: val });
          });

          return pairs;
        };

        const upsertSpec = (pairs, key, displayLabel, value) => {
          const k = String(key || '').toLowerCase();
          const v = String(value || '').trim();
          const idx = pairs.findIndex((p) => p && p.label && String(p.label).trim().toLowerCase() === k);

          if (!v) {
            if (idx >= 0) pairs.splice(idx, 1);
            return;
          }

          if (idx >= 0) pairs[idx].value = v;
          else pairs.push({ label: displayLabel, value: v });
        };

        const syncSpecsFromKeyFields = () => {
          if (!specsField) return;
          const pairs = parseSpecPairs(specsField.value);
          if (specTypeInput) upsertSpec(pairs, 'type', 'Type', specTypeInput.value);
          if (specProgrammationInput) upsertSpec(pairs, 'programmation', 'Programmation', specProgrammationInput.value);
          specsField.value = pairs.map((p) => `${p.label}: ${p.value}`.trim()).filter(Boolean).join('\n');
        };

        if (specsField && (specTypeInput || specProgrammationInput)) {
          if (specTypeInput) specTypeInput.addEventListener('input', syncSpecsFromKeyFields);
          if (specProgrammationInput) specProgrammationInput.addEventListener('input', syncSpecsFromKeyFields);
          syncSpecsFromKeyFields();
        }

        const slugifyOptionKey = (value) => {
          let s = String(value || '');
          try {
            s = s.normalize('NFD').replace(/[\u0300-\u036f]/g, '');
          } catch (e) {}
          return s
            .toLowerCase()
            .trim()
            .replace(/[^a-z0-9]+/g, '-')
            .replace(/^-+/, '')
            .replace(/-+$/, '');
        };

        const parsePriceInputToCents = (value) => {
          const trimmed = String(value || '').trim();
          if (!trimmed) return 0;
          const normalized = trimmed.replace(/€/g, '').replace(/\s+/g, '').replace(',', '.');
          const num = Number(normalized);
          if (!Number.isFinite(num) || num < 0) return null;
          return Math.round(num * 100);
        };

        const formatPriceInputFromCents = (value) => {
          const cents = Number(value);
          if (!Number.isFinite(cents) || cents <= 0) return '';
          return (cents / 100).toFixed(2).replace('.', ',');
        };

        const parseOptionalPriceInputToCents = (value) => {
          const trimmed = String(value || '').trim();
          if (!trimmed) return null;
          return parsePriceInputToCents(trimmed);
        };

        const normalizeOptionalStoredPriceCents = (value) => {
          if (value === null || typeof value === 'undefined') return null;
          const trimmed = String(value).trim();
          if (!trimmed) return null;
          const parsed = Number(trimmed);
          return Number.isFinite(parsed) && parsed > 0 ? Math.round(parsed) : null;
        };

        const createChoiceState = (choice) => ({
          key: String(choice && choice.key ? choice.key : '').trim(),
          label: String(choice && choice.label ? choice.label : '').trim(),
          priceDeltaCents: Number.isFinite(Number(choice && choice.priceDeltaCents)) ? Math.round(Number(choice.priceDeltaCents)) : 0,
          absolutePriceCents: normalizeOptionalStoredPriceCents(choice && choice.absolutePriceCents),
          triggersCloning: choice && choice.triggersCloning === true,
        });

        const createEmptyOptionState = () => ({
          templateId: '',
          key: '',
          label: '',
          type: 'choice',
          required: false,
          placeholder: '',
          helpText: '',
          priceDeltaCents: 0,
          choices: [createChoiceState({})],
        });

        const normalizeOptionState = (option, index) => {
          const src = option && typeof option === 'object' ? option : {};
          const label = String(src.label || '').trim();
          const rawKey = slugifyOptionKey(String(src.key || '').trim());
          if (!label && !rawKey) return null;
          const key = rawKey || slugifyOptionKey(label) || `option-${index + 1}`;

          const type = String(src.type || '') === 'text' ? 'text' : 'choice';
          const normalized = {
            templateId: String(src.templateId || '').trim(),
            key,
            label: label || key,
            type,
            required: src.required === true,
            placeholder: String(src.placeholder || '').trim(),
            helpText: String(src.helpText || '').trim(),
            priceDeltaCents: Number.isFinite(Number(src.priceDeltaCents)) ? Math.round(Number(src.priceDeltaCents)) : 0,
            choices: [],
          };

          if (type === 'choice') {
            normalized.choices = Array.isArray(src.choices)
              ? src.choices.map(createChoiceState).filter((choice, choiceIndex) => {
                  const choiceLabel = String(choice.label || '').trim();
                  choice.key = slugifyOptionKey(choice.key || choiceLabel || `choix-${choiceIndex + 1}`);
                  return !!choiceLabel;
                })
              : [];
            normalized.priceDeltaCents = 0;
          } else {
            normalized.choices = [];
          }

          return normalized;
        };

        const createOptionState = (option, index) => {
          const normalized = normalizeOptionState(option, index);
          if (!normalized) return createEmptyOptionState();
          return {
            templateId: normalized.templateId,
            key: normalized.key,
            label: normalized.label,
            type: normalized.type,
            required: normalized.required,
            placeholder: normalized.placeholder,
            helpText: normalized.helpText,
            priceDeltaCents: normalized.priceDeltaCents,
            choices: normalized.type === 'choice' && normalized.choices.length ? normalized.choices.map(createChoiceState) : [createChoiceState({})],
