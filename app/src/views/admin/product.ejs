<%- include('./partials/head') %>

<%- include('./partials/sidebar', { active: 'catalog' }) %>

<style>
  .field-review-empty {
    border-color: rgb(252 165 165) !important;
    background-color: rgb(254 242 242) !important;
    box-shadow: 0 0 0 3px rgba(252, 165, 165, 0.18);
  }

  .field-review-ai {
    border-color: rgb(167 139 250) !important;
    background-color: rgb(245 243 255) !important;
    box-shadow: 0 0 0 3px rgba(167, 139, 250, 0.18);
  }

  .field-review-validated {
    border-color: rgb(74 222 128) !important;
    background-color: rgb(240 253 244) !important;
    box-shadow: 0 0 0 3px rgba(74, 222, 128, 0.18);
  }

  .field-review-inline {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-left: 0.5rem;
    vertical-align: middle;
  }

  /* Drag-and-drop visual feedback on the media grid */
  #mediaGrid.is-dropzone-active {
    outline: 2px dashed rgb(59 130 246);
    outline-offset: 4px;
    background-color: rgba(59, 130, 246, 0.06);
    border-radius: 0.75rem;
  }
  .media-tile.sortable-ghost {
    opacity: 0.4;
  }
  .media-tile.sortable-chosen {
    cursor: grabbing !important;
  }
  .media-tile [data-action="drag-handle"] {
    cursor: grab;
  }
  .media-tile.sortable-drag {
    cursor: grabbing !important;
  }
</style>

<main class="flex-1 relative">
  <% const pageTitle = mode === 'new' ? 'New Product' : 'Edit Product'; %>
  <% const productName = form && form.name ? form.name : (mode === 'new' ? 'New product' : 'Product'); %>
  <% const liveUrl = mode === 'edit' && productId ? ('/produits/' + productId) : null; %>
  <% const currentAiDraftJob = typeof latestAiDraftJob !== 'undefined' ? latestAiDraftJob : null; %>
  <% const singleAiProfiles = typeof aiSingleProfiles !== 'undefined' && Array.isArray(aiSingleProfiles) && aiSingleProfiles.length ? aiSingleProfiles : [
    { key: 'single_standard', label: 'Standard', description: 'Bonne qualité avec un budget plus raisonnable.', defaultModel: 'gpt-4.1' },
    { key: 'single_balanced', label: 'Avancé', description: 'gpt-5.4 plus qualitatif que Standard, sans aller aussi loin que Premium.', defaultModel: 'gpt-5.4' },
    { key: 'single_premium', label: 'Premium', description: 'Recherche plus approfondie.', defaultModel: 'gpt-5.4' },
  ]; %>
  <% const defaultSingleAiProfileKey = typeof defaultAiSingleProfileKey !== 'undefined' && defaultAiSingleProfileKey ? defaultAiSingleProfileKey : 'single_premium'; %>
  <% const currentAiDraftJobEncoded = encodeURIComponent(JSON.stringify(currentAiDraftJob || null)); %>
  <% const galleryPreview = (form && form.galleryUrls ? String(form.galleryUrls).split(/\r?\n/).map((s) => s.trim()).filter(Boolean) : []).slice(0, 5); %>
  <% const specsText = form && typeof form.specs !== 'undefined' ? String(form.specs || '') : ''; %>
  <% const findSpecValue = (label) => {
    const target = String(label || '').trim().toLowerCase();
    if (!target) return '';
    const lines = String(specsText || '').split(/\r?\n/).map((s) => s.trim()).filter(Boolean);
    for (const line of lines) {
      const sepIndex = line.indexOf(':') >= 0 ? line.indexOf(':') : (line.indexOf('=') >= 0 ? line.indexOf('=') : line.indexOf('|'));
      if (sepIndex <= 0) continue;
      const rawLabel = line.slice(0, sepIndex).trim().toLowerCase();
      if (rawLabel !== target) continue;
      return line.slice(sepIndex + 1).trim();
    }
    return '';
  }; %>
  <% const specTypeValue = findSpecValue('type'); %>
  <% const specProgrammationValue = findSpecValue('programmation'); %>
  <div id="adminProductRuntimeData" class="hidden" data-product-id="<%= typeof productId !== 'undefined' ? productId : '' %>" data-latest-ai-draft-job="<%= currentAiDraftJobEncoded %>"></div>

  <header class="bg-surface-light dark:bg-surface-dark border-b border-border-light dark:border-border-dark sticky top-0 z-50">
    <div class="px-8 py-4 flex items-center justify-between">
      <div>
        <%- include('./partials/breadcrumb', { breadcrumbs: [{label: 'Produits', url: '/admin/catalogue'}, {label: productName}] }) %>
        <h1 class="text-xl font-bold text-slate-900 dark:text-white"><%= productName %></h1>
      </div>

      <div class="flex items-center gap-3">
        <button class="px-4 py-2 text-sm font-semibold border border-border-light dark:border-border-dark rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition-all flex items-center gap-2" type="button" <%= liveUrl ? '' : 'disabled' %> onclick="if (this.disabled) return; window.open('<%= liveUrl || '' %>', '_blank', 'noopener');">
          <span class="material-symbols-outlined text-lg">visibility</span>
          Voir en ligne
        </button>

        <button class="btn btn-primary" form="productForm" type="submit" <%= dbConnected ? '' : 'disabled' %>>
          <span class="material-symbols-outlined text-lg">save</span>
          Enregistrer
        </button>
      </div>
    </div>
  </header>

  <!-- Product Stepper -->
  <nav id="product-stepper" class="bg-white border-b border-slate-200 sticky z-40 overflow-x-auto" style="top:0">
    <div class="flex items-center min-w-max">
      <button class="stepper-step stepper-step--active" data-target="section-essential" type="button">
        <span class="stepper-check material-symbols-outlined">check_circle</span>
        <span class="stepper-dot"></span>
        <span>1. Infos essentielles</span>
      </button>
      <button class="stepper-step" data-target="section-description" type="button">
        <span class="stepper-check material-symbols-outlined">check_circle</span>
        <span class="stepper-dot"></span>
        <span>2. Description</span>
      </button>
      <button class="stepper-step" data-target="section-media" type="button">
        <span class="stepper-check material-symbols-outlined">check_circle</span>
        <span class="stepper-dot"></span>
        <span>3. Médias</span>
      </button>
      <button class="stepper-step" data-target="section-compat" type="button">
        <span class="stepper-check material-symbols-outlined">check_circle</span>
        <span class="stepper-dot"></span>
        <span>4. Compatibilité</span>
      </button>
      <button class="stepper-step" data-target="section-seo" type="button">
        <span class="stepper-check material-symbols-outlined">check_circle</span>
        <span class="stepper-dot"></span>
        <span>5. SEO</span>
      </button>
      <button class="stepper-step" data-target="section-options" type="button">
        <span class="stepper-check material-symbols-outlined">check_circle</span>
        <span class="stepper-dot"></span>
        <span>6. Options avancées</span>
      </button>
    </div>
  </nav>

  <%- include('./partials/skeleton-product') %>

  <div class="p-8 max-w-6xl mx-auto space-y-8">
    <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
      <div class="rounded-xl border border-red-200 bg-red-50 p-4 text-red-900">
        <div class="font-bold">Erreur</div>
        <div class="mt-1 text-sm"><%= errorMessage %></div>
      </div>
    <% } %>

    <% if (!dbConnected) { %>
      <div class="rounded-xl border border-amber-200 bg-amber-50 p-4 text-amber-900">
        <div class="font-bold">Mode démo</div>
        <div class="mt-1 text-sm">La base de données est indisponible : vous ne pouvez pas enregistrer de produit.</div>
      </div>
    <% } %>

    <div class="rounded-xl border border-sky-200 bg-sky-50 p-4 text-sky-900">
      <div class="font-bold">Aide rapide pour créer un produit</div>
      <div class="mt-2 text-sm space-y-1">
        <div><span class="font-bold text-red-600">*</span> = champ obligatoire pour créer le produit.</div>
        <div><span class="inline-flex items-center rounded-full bg-red-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-red-700">Obligatoire</span> = nécessaire pour enregistrer le produit.</div>
        <div><span class="inline-flex items-center rounded-full bg-emerald-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-emerald-700">Recommandé</span> = fortement conseillé pour une fiche produit complète.</div>
        <div><span class="inline-flex items-center rounded-full bg-slate-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-slate-500">Optionnel</span> = utile selon le produit, mais non bloquant.</div>
        <div>Minimum demandé aujourd'hui : <span class="font-semibold">Nom du produit</span> et <span class="font-semibold">Prix</span>.</div>
        <div>Si vous laissez le <span class="font-semibold">slug</span> vide, il sera créé automatiquement à partir du nom du produit.</div>
        <div>Les autres champs peuvent être remplis maintenant ou plus tard pour améliorer la fiche produit.</div>
      </div>
    </div>

    <div class="rounded-xl border border-violet-200 bg-violet-50 p-4 text-violet-950">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
        <div>
          <div class="font-bold">Assistant IA pour pré-remplir la fiche</div>
          <div class="mt-2 text-sm space-y-1">
            <div>1. Renseignez au minimum le nom du produit ou la référence.</div>
            <div>2. Ajoutez des notes si vous voulez orienter la recherche.</div>
            <div>3. Cliquez sur <span class="font-semibold">Générer avec l'IA</span> : la page se remplit, mais rien n'est enregistré automatiquement.</div>
          </div>
        </div>

        <div class="flex flex-wrap items-center gap-3">
          <button class="btn btn-primary" id="aiGenerateBtn" type="button">
            <span class="material-symbols-outlined mr-2 text-lg">auto_awesome</span>
            Générer avec l'IA
          </button>
          <button class="<%= currentAiDraftJob && (currentAiDraftJob.status === 'queued' || currentAiDraftJob.status === 'processing') ? '' : 'hidden ' %>inline-flex items-center justify-center rounded-lg border border-amber-200 bg-amber-50 px-4 py-2 text-sm font-bold text-amber-900 shadow-sm transition hover:bg-amber-100 disabled:opacity-60" id="aiCancelBtn" type="button">
            <span class="material-symbols-outlined mr-2 text-lg">stop_circle</span>
            Arrêter l'IA
          </button>
        </div>
      </div>

      <div class="mt-4 grid gap-4 lg:grid-cols-[minmax(0,320px)_1fr] lg:items-start">
        <div>
          <label class="block text-xs font-medium uppercase tracking-widest text-violet-900" for="aiProfile">Mode IA</label>
          <select class="mt-2 w-full rounded-lg border border-violet-200 bg-white/90 px-4 py-3 text-sm text-slate-900 focus:border-violet-400 focus:ring-violet-400" id="aiProfile">
            <% singleAiProfiles.forEach((profile) => { %>
              <option value="<%= profile.key %>" <%= profile.key === defaultSingleAiProfileKey ? 'selected' : '' %>><%= profile.label %> — <%= profile.defaultModel %></option>
            <% }) %>
          </select>
          <div class="mt-2 text-xs text-violet-900/75">Standard = plus rapide. Avancé = gpt-5.4 équilibré. Premium = le plus approfondi, mais aussi le plus lent.</div>
        </div>

        <div>
          <label class="block text-xs font-medium uppercase tracking-widest text-violet-900" for="aiSourceNotes">Notes complémentaires pour l'IA</label>
          <textarea class="mt-2 w-full rounded-lg border border-violet-200 bg-white/90 px-4 py-3 text-sm text-slate-900 focus:border-violet-400 focus:ring-violet-400" id="aiSourceNotes" rows="4" placeholder="Ex : calculateur moteur Bosch pour Audi A3 2.0 TDI, priorité SEO, style rassurant, éviter les affirmations non vérifiées."></textarea>
        </div>
      </div>

      <div class="mt-3 text-sm text-violet-900/80" id="aiGenerateStatus">L'IA utilisera le nom du produit, la référence, la marque, la catégorie et les notes ci-dessus.</div>

      <div class="mt-3 hidden rounded-lg border border-amber-200 bg-amber-50 p-3 text-amber-900" id="aiGenerateWarnings"></div>

      <% if (currentAiDraftJob) { %>
        <div class="mt-4 rounded-lg border border-white/70 bg-white/80 p-4 text-slate-900">
          <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
            <div>
              <div class="font-bold">Dernier brouillon IA enregistré</div>
              <div class="mt-2 text-sm space-y-1">
                <div>
                  Statut :
                  <% if (currentAiDraftJob.status === 'completed') { %>
                    <span class="font-semibold text-emerald-700">prêt à relire</span>
                  <% } else if (currentAiDraftJob.status === 'processing') { %>
                    <span class="font-semibold text-violet-700">génération en cours</span>
                  <% } else if (currentAiDraftJob.status === 'queued') { %>
                    <span class="font-semibold text-sky-700">en file d'attente</span>
                  <% } else if (currentAiDraftJob.status === 'canceled') { %>
                    <span class="font-semibold text-slate-500">arrêtée</span>
                  <% } else if (currentAiDraftJob.status === 'failed') { %>
                    <span class="font-semibold text-red-700">en erreur</span>
                  <% } else { %>
                    <span class="font-semibold"><%= currentAiDraftJob.status || 'inconnu' %></span>
                  <% } %>
                </div>
                <% if (currentAiDraftJob.createdAtLabel) { %>
                  <div>Demandé le <span class="font-semibold"><%= currentAiDraftJob.createdAtLabel %></span></div>
                <% } %>
                <% if (currentAiDraftJob.completedAtLabel) { %>
                  <div>Terminé le <span class="font-semibold"><%= currentAiDraftJob.completedAtLabel %></span></div>
                <% } %>
                <% if (currentAiDraftJob.model) { %>
                  <div>Modèle : <span class="font-semibold"><%= currentAiDraftJob.model %></span></div>
                <% } %>
                <% if (currentAiDraftJob.profileLabel) { %>
                  <div>Mode IA : <span class="font-semibold"><%= currentAiDraftJob.profileLabel %></span></div>
                <% } %>
                <% if (currentAiDraftJob.status === 'processing' || currentAiDraftJob.status === 'queued') { %>
                  <div class="text-slate-500">Recharge cette page dans quelques instants pour récupérer le brouillon automatiquement préparé en arrière-plan.</div>
                <% } %>
                <% if ((currentAiDraftJob.status === 'failed' || currentAiDraftJob.status === 'canceled') && currentAiDraftJob.errorMessage) { %>
                  <div class="text-red-700"><%= currentAiDraftJob.errorMessage %></div>
                <% } %>
              </div>
            </div>

            <% if (currentAiDraftJob.status === 'completed' && currentAiDraftJob.hasDraft) { %>
              <button class="inline-flex items-center justify-center rounded-lg border border-violet-200 bg-violet-100 px-4 py-2 text-sm font-bold text-violet-900 transition hover:bg-violet-200" id="applyLatestAiDraftBtn" type="button">
                <span class="material-symbols-outlined mr-2 text-lg">download</span>
                Appliquer le dernier brouillon IA
              </button>
            <% } %>
          </div>
        </div>
      <% } %>
    </div>

    <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-emerald-950" id="fieldReviewPanel">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
        <div>
          <div class="font-bold">Suivi simple de la fiche produit</div>
          <div class="mt-2 text-sm space-y-1">
            <div>Les champs encore vides ressortent en rouge.</div>
            <div>Les champs remplis par l'IA reçoivent un badge <span class="font-semibold">IA</span>.</div>
            <div>Vous pouvez cocher <span class="font-semibold">Validé</span> après relecture pour vous repérer facilement.</div>
          </div>
        </div>

        <div class="grid grid-cols-3 gap-2 text-center text-xs font-semibold uppercase tracking-widest">
          <div class="rounded-lg border border-red-200 bg-white px-3 py-2 text-red-700">
            <div>À remplir</div>
            <div class="mt-1 text-lg" id="fieldReviewEmptyCount">0</div>
          </div>
          <div class="rounded-lg border border-violet-200 bg-white px-3 py-2 text-violet-700">
            <div>IA</div>
            <div class="mt-1 text-lg" id="fieldReviewAiCount">0</div>
          </div>
          <div class="rounded-lg border border-emerald-200 bg-white px-3 py-2 text-emerald-700">
            <div>Validés</div>
            <div class="mt-1 text-lg" id="fieldReviewValidatedCount">0</div>
          </div>
        </div>
      </div>

      <div class="mt-3 text-xs text-emerald-900/80">Les mini coches sont maintenant directement affichées à côté des champs et blocs importants.</div>
    </div>

    <div class="mt-4 rounded-lg border border-sky-200 bg-white/70 px-4 py-3 text-sm">
      <div class="font-bold text-sky-900">Ordre conseillé pour un novice</div>
      <div class="mt-2 grid grid-cols-1 md:grid-cols-3 gap-2 text-sky-900/90">
        <div><span class="font-semibold">1.</span> Informations essentielles</div>
        <div><span class="font-semibold">2.</span> Description produit</div>
        <div><span class="font-semibold">3.</span> Médias</div>
        <div><span class="font-semibold">4.</span> Compatibilité véhicule</div>
        <div><span class="font-semibold">5.</span> SEO</div>
        <div><span class="font-semibold">6.</span> Options et réglages avancés</div>
      </div>
    </div>

    <form id="productForm" action="<%= mode === 'new' ? '/admin/catalogue/nouveau' : ('/admin/catalogue/' + productId) %>" enctype="multipart/form-data" method="POST" class="flex flex-col gap-8">
      <section id="section-essential" class="order-1 bg-surface-light dark:bg-surface-dark rounded-xl border border-border-light dark:border-border-dark shadow-sm">
        <div class="p-6 border-b border-border-light dark:border-border-dark flex items-center justify-between">
          <div>
            <h2 class="font-bold flex items-center gap-2">
              <span class="material-symbols-outlined text-slate-400">info</span>
              Étape 1 · Informations essentielles
              <span class="inline-flex items-center rounded-full bg-red-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-red-700">Obligatoire</span>
            </h2>
            <div class="mt-2 text-xs text-slate-500">Commence par cette section : c'est ici que se trouvent les champs minimums pour créer le produit.</div>
          </div>
        </div>

        <div class="p-6 grid grid-cols-1 md:grid-cols-4 gap-6">
          <div class="md:col-span-2 md:order-1">
            <label class="block text-xs font-medium text-slate-500 uppercase mb-2" for="name">Nom du produit <span class="text-red-600">*</span></label>
            <input class="w-full bg-gray-50 dark:bg-gray-900 border-border-light dark:border-border-dark rounded-lg py-2.5 px-4 text-sm focus:ring-primary focus:border-primary" id="name" name="name" required type="text" value="<%= form && form.name ? form.name : '' %>" data-validate />
            <div class="mt-2 text-xs text-slate-500">Obligatoire pour créer le produit.</div>
          </div>

          <div class="md:order-2">
            <label class="block text-xs font-medium text-slate-500 uppercase mb-2" for="price">Prix (€) <span class="text-red-600">*</span></label>
            <input class="w-full bg-gray-50 dark:bg-gray-900 border-border-light dark:border-border-dark rounded-lg py-2.5 px-4 text-sm focus:ring-primary focus:border-primary" id="price" name="price" placeholder="Ex: 199,90" required type="text" value="<%= form && form.price ? form.price : '' %>" data-validate data-min="0.01" data-error="Prix requis, doit être supérieur à 0" />
            <div class="mt-2 text-xs text-slate-500">Obligatoire pour créer le produit.</div>
          </div>

          <div class="md:order-3">
            <label class="block text-xs font-medium text-slate-500 uppercase mb-2" for="category">Catégorie</label>
            <% if (typeof categories !== 'undefined' && categories && categories.length) { %>
              <select class="w-full bg-gray-50 dark:bg-gray-900 border-border-light dark:border-border-dark rounded-lg py-2.5 px-4 text-sm focus:ring-primary focus:border-primary" id="category" name="category">
                <option value="">Autre</option>
                <% categories.forEach((c) => { %>
                  <option value="<%= c.name %>" <%= form && form.category === c.name ? 'selected' : '' %>><%= c.name %></option>
                <% }) %>
              </select>
            <% } else { %>
              <input class="w-full bg-gray-50 dark:bg-gray-900 border-border-light dark:border-border-dark rounded-lg py-2.5 px-4 text-sm focus:ring-primary focus:border-primary" id="category" name="category" placeholder="Ex: Freinage" type="text" value="<%= form && form.category ? form.category : '' %>" />
            <% } %>
            <div class="mt-2 text-xs text-slate-500">Recommandé pour bien classer le produit dans le catalogue.</div>
          </div>

          <div class="md:order-4">
            <label class="block text-xs font-medium text-slate-500 uppercase mb-2" for="brand">Marque</label>
            <input class="w-full bg-gray-50 dark:bg-gray-900 border-border-light dark:border-border-dark rounded-lg py-2.5 px-4 text-sm focus:ring-primary focus:border-primary" id="brand" name="brand" type="text" value="<%= form && form.brand ? form.brand : '' %>" />
            <div class="mt-2 text-xs text-slate-500">Recommandé pour aider la recherche et la compréhension du produit.</div>
          </div>

          <div class="md:col-span-2 md:order-5">
            <label class="block text-xs font-medium text-slate-500 uppercase mb-2" for="slug">Slug (URL)</label>
            <input class="w-full bg-gray-50 dark:bg-gray-900 border-border-light dark:border-border-dark rounded-lg py-2.5 px-4 text-sm focus:ring-primary focus:border-primary" id="slug" name="slug" placeholder="Ex: moteur-complet-porsche-cayenne" type="text" value="<%= form && typeof form.slug !== 'undefined' ? (form.slug || '') : '' %>" />
            <div class="mt-2 text-xs text-slate-500">Optionnel. Si vous ne le remplissez pas, il sera généré automatiquement.</div>
          </div>

          <div class="md:order-6">
            <label class="block text-xs font-medium text-slate-500 uppercase mb-2" for="sku">SKU</label>
            <input class="w-full bg-gray-50 dark:bg-gray-900 border-border-light dark:border-border-dark rounded-lg py-2.5 px-4 text-sm focus:ring-primary focus:border-primary" id="sku" name="sku" type="text" value="<%= form && form.sku ? form.sku : '' %>" data-validate data-pattern="^[A-Za-z0-9_.:-]*$" data-error="Lettres, chiffres, - ou _ uniquement" />
            <div class="mt-2 text-xs text-slate-500">Recommandé si vous gérez beaucoup de produits.</div>
          </div>

          <div class="md:order-7">
            <label class="block text-xs font-medium text-slate-500 uppercase mb-2" for="stockQty">Stock</label>
            <input class="w-full bg-gray-50 dark:bg-gray-900 border-border-light dark:border-border-dark rounded-lg py-2.5 px-4 text-sm focus:ring-primary focus:border-primary" id="stockQty" name="stockQty" placeholder="Laisse vide si non géré" type="number" min="0" value="<%= form && typeof form.stockQty !== 'undefined' ? form.stockQty : '' %>" />
          </div>

          <div class="flex items-center gap-3 md:col-span-4 md:order-8">
            <input class="rounded border-gray-300 text-primary focus:ring-primary" id="inStock" name="inStock" type="checkbox" <%= form && form.inStock ? 'checked' : '' %> />
            <label class="text-sm font-semibold text-slate-500 dark:text-gray-300" for="inStock">Produit en stock</label>
          </div>

          <div class="md:order-9">
            <label class="block text-xs font-medium text-slate-500 uppercase mb-2" for="shippingDelayText">Délai d'expédition (affiché sur la fiche produit)</label>
            <input class="w-full bg-gray-50 dark:bg-gray-900 border-border-light dark:border-border-dark rounded-lg py-2.5 px-4 text-sm focus:ring-primary focus:border-primary" id="shippingDelayText" name="shippingDelayText" placeholder="Ex: Expédition sous 24/48h • Expédition sous 3 jours • Sur commande" type="text" value="<%= form && typeof form.shippingDelayText !== 'undefined' ? form.shippingDelayText : '' %>" />
          </div>

          <div class="md:order-10">
            <label class="block text-xs font-medium text-slate-500 uppercase mb-2" for="shippingClassId">Classe d'expédition</label>
            <% if (typeof shippingClasses !== 'undefined' && shippingClasses && shippingClasses.length) { %>
              <select class="w-full bg-gray-50 dark:bg-gray-900 border-border-light dark:border-border-dark rounded-lg py-2.5 px-4 text-sm focus:ring-primary focus:border-primary" id="shippingClassId" name="shippingClassId">
                <option value="">Par défaut</option>
                <% shippingClasses.forEach((c) => { %>
                  <% const optLabel = `${c.name || ''}${c.isDefault ? ' (défaut)' : ''}${c.isActive === false ? ' (inactive)' : ''}`; %>
                  <option value="<%= c.id %>" <%= form && form.shippingClassId === c.id ? 'selected' : '' %>><%= optLabel %></option>
                <% }) %>
              </select>
            <% } else { %>
              <input class="w-full bg-gray-50 dark:bg-gray-900 border-border-light dark:border-border-dark rounded-lg py-2.5 px-4 text-sm opacity-70" disabled id="shippingClassId" name="shippingClassId" placeholder="Par défaut" type="text" value="Par défaut" />
            <% } %>
          </div>

          <div class="md:order-11">
            <label class="block text-xs font-medium text-slate-500 uppercase mb-2" for="compareAtPrice">Prix barré</label>
            <input class="w-full bg-gray-50 dark:bg-gray-900 border-border-light dark:border-border-dark rounded-lg py-2.5 px-4 text-sm focus:ring-primary focus:border-primary" id="compareAtPrice" name="compareAtPrice" placeholder="Ex: 249,90" type="text" value="<%= form && form.compareAtPrice ? form.compareAtPrice : '' %>" />
          </div>

          <div class="md:col-span-4 md:order-12">
            <label class="block text-xs font-medium text-slate-500 uppercase mb-2" for="compatibleReferences">Références compatibles (1 par ligne)</label>
            <textarea class="w-full bg-gray-50 dark:bg-gray-900 border-border-light dark:border-border-dark rounded-lg py-2.5 px-4 text-sm focus:ring-primary focus:border-primary min-h-[90px]" id="compatibleReferences" name="compatibleReferences" placeholder="Ex: 0281011234 (une par ligne)"><%= form && typeof form.compatibleReferences !== 'undefined' ? form.compatibleReferences : '' %></textarea>
          </div>

          <div class="md:col-span-4 md:order-13">
            <div class="flex items-center gap-3">
              <input class="rounded border-gray-300 text-primary focus:ring-primary" id="consigneEnabled" name="consigneEnabled" type="checkbox" <%= form && form.consigneEnabled ? 'checked' : '' %> />
              <label class="text-sm font-semibold text-slate-500 dark:text-gray-300" for="consigneEnabled">Activer la consigne (ancienne pièce à retourner)</label>
            </div>
            <div class="mt-4 grid grid-cols-1 md:grid-cols-4 gap-6">
              <div>
                <label class="block text-xs font-medium text-slate-500 uppercase mb-2" for="consigneAmount">Montant consigne (€)</label>
                <input class="w-full bg-gray-50 dark:bg-gray-900 border-border-light dark:border-border-dark rounded-lg py-2.5 px-4 text-sm focus:ring-primary focus:border-primary" id="consigneAmount" name="consigneAmount" placeholder="Ex: 150,00" type="text" value="<%= form && typeof form.consigneAmount !== 'undefined' ? form.consigneAmount : '' %>" />
              </div>
              <div>
                <label class="block text-xs font-medium text-slate-500 uppercase mb-2" for="consigneDelayDays">Délai retour (jours)</label>
                <input class="w-full bg-gray-50 dark:bg-gray-900 border-border-light dark:border-border-dark rounded-lg py-2.5 px-4 text-sm focus:ring-primary focus:border-primary" id="consigneDelayDays" name="consigneDelayDays" type="number" min="0" max="3650" value="<%= form && typeof form.consigneDelayDays !== 'undefined' ? form.consigneDelayDays : '30' %>" />
              </div>
            </div>
          </div>

        </div>
      </section>

      <input id="videoUrl" name="videoUrl" type="hidden" value="<%= form && form.videoUrl ? form.videoUrl : '' %>" />
      <textarea id="specs" name="specs" class="hidden"><%= form && form.specs ? form.specs : '' %></textarea>

      <section id="section-media" class="order-3 bg-surface-light dark:bg-surface-dark rounded-xl border border-border-light dark:border-border-dark shadow-sm">
        <div class="p-6 border-b border-border-light dark:border-border-dark flex items-center justify-between">
          <div>
            <h2 class="font-bold flex items-center gap-2">
              <span class="material-symbols-outlined text-slate-400">imagesmode</span>
              Étape 3 · Médias
              <span class="inline-flex items-center rounded-full bg-red-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-red-700">Obligatoire</span>
            </h2>
            <div class="mt-2 text-xs text-slate-500">Une image principale est obligatoire pour enregistrer le produit.</div>
          </div>
          <button class="text-primary text-sm font-bold flex items-center gap-1 hover:underline" id="mediaAddNew" type="button">
            <span class="material-symbols-outlined text-lg">add_a_photo</span>
            Ajouter
          </button>
        </div>

        <div class="p-6">
          <div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-6 gap-4" id="mediaGrid">
            <% if (form && form.imageUrl) { %>
              <div class="relative group aspect-square rounded-lg border border-primary overflow-hidden bg-white" data-kind="main" data-url="<%= form.imageUrl %>">
                <img alt="Product" class="w-full h-full object-cover" src="<%= form.imageUrl %>" />
                <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-2">
                  <button class="p-1.5 bg-white text-slate-900 rounded-full hover:text-primary" type="button" title="Image principale fixe"><span class="material-symbols-outlined text-sm">star</span></button>
                  <button class="p-1.5 bg-white text-slate-900 rounded-full hover:text-red-600" type="button" data-action="remove"><span class="material-symbols-outlined text-sm">delete</span></button>
                </div>
                <span class="absolute top-1 left-1 bg-primary text-white text-[8px] font-bold px-1.5 py-0.5 rounded">PRINCIPALE</span>
              </div>
            <% } %>

            <%
              const __galleryUrlsArr = (form && form.galleryUrls) ? String(form.galleryUrls).split(/\r?\n/).map((s) => s.trim()).filter(Boolean) : [];
              const __galleryTypesArr = (form && form.galleryTypes) ? String(form.galleryTypes).split(/\r?\n/).map((s) => s.trim().toLowerCase()) : [];
              __galleryUrlsArr.forEach((u, __i) => {
                const __t = (__galleryTypesArr[__i] === 'video') ? 'video' : 'image';
            %>
              <div class="relative group aspect-square rounded-lg border border-border-light dark:border-border-dark overflow-hidden bg-white media-tile" data-kind="gallery" data-url="<%= u %>" data-type="<%= __t %>">
                <% if (__t === 'video') { %>
                  <video class="w-full h-full object-cover" muted playsinline preload="metadata">
                    <source src="<%= u %>" />
                  </video>
                  <span class="absolute top-1 left-1 bg-black/70 text-white text-[8px] font-bold px-1.5 py-0.5 rounded flex items-center gap-1">
                    <span class="material-symbols-outlined text-[10px] leading-none">play_circle</span>VIDÉO
                  </span>
                <% } else { %>
                  <img alt="Product" class="w-full h-full object-cover" src="<%= u %>" />
                <% } %>
                <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-2">
                  <button class="p-1.5 bg-white text-slate-900 rounded-full cursor-grab" type="button" data-action="drag-handle" title="Glisser pour réordonner"><span class="material-symbols-outlined text-sm">drag_indicator</span></button>
                  <button class="p-1.5 bg-white text-slate-900 rounded-full" type="button" data-action="move-left" title="Déplacer à gauche"><span class="material-symbols-outlined text-sm">arrow_back</span></button>
                  <button class="p-1.5 bg-white text-slate-900 rounded-full" type="button" data-action="move-right" title="Déplacer à droite"><span class="material-symbols-outlined text-sm">arrow_forward</span></button>
                  <button class="p-1.5 bg-white text-slate-900 rounded-full" type="button" data-action="remove"><span class="material-symbols-outlined text-sm">delete</span></button>
                </div>
              </div>
            <% }) %>

            <button class="aspect-square rounded-lg border-2 border-dashed border-border-light dark:border-border-dark flex flex-col items-center justify-center text-slate-400 hover:border-primary hover:text-primary transition-all" id="mediaUploadBtn" type="button">
              <span class="material-symbols-outlined text-3xl mb-1">add</span>
              <span class="text-[10px] font-bold">AJOUTER</span>
            </button>
          </div>

          <div class="mt-4 text-xs text-slate-500">Glissez-déposez vos fichiers (images ou vidéos) sur la grille, ou cliquez sur « Ajouter ». Vous pouvez réordonner par glisser-déposer ou avec les flèches. Vidéos : MP4 / WEBM / MOV (50 Mo max). Images : 5 Mo max.</div>

          <input id="image" name="image" accept="image/*,video/mp4,video/webm,video/quicktime" type="file" multiple class="hidden" />
          <input id="imageUrl" name="imageUrl" type="hidden" value="<%= form && form.imageUrl ? form.imageUrl : '' %>" />
          <input id="removeMainImage" name="removeMainImage" type="hidden" value="false" />
          <textarea id="galleryUrls" name="galleryUrls" class="hidden"><%= form && form.galleryUrls ? form.galleryUrls : '' %></textarea>
          <textarea id="galleryTypes" name="galleryTypes" class="hidden"><%= form && form.galleryTypes ? form.galleryTypes : '' %></textarea>
        </div>
      </section>

      <section id="section-description" class="order-2 bg-surface-light dark:bg-surface-dark rounded-xl border border-border-light dark:border-border-dark shadow-sm overflow-hidden">
        <div class="p-6 border-b border-border-light dark:border-border-dark flex items-center justify-between">
          <div>
            <h2 class="font-bold flex items-center gap-2">
              <span class="material-symbols-outlined text-slate-400">description</span>
              Étape 2 · Description du produit
              <span class="inline-flex items-center rounded-full bg-red-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-red-700">Obligatoire</span>
            </h2>
            <div class="mt-2 text-xs text-slate-500">Tous les champs de cette section sont obligatoires.</div>
          </div>
        </div>

        <div class="p-6 space-y-6">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="bg-gray-50 dark:bg-gray-900/50 p-4 rounded-xl border border-border-light dark:border-border-dark flex flex-col items-center text-center">
              <div class="w-10 h-10 rounded-full bg-white dark:bg-gray-800 shadow-sm flex items-center justify-center mb-2">
                <span class="material-symbols-outlined">settings_input_component</span>
              </div>
              <span class="text-[10px] uppercase font-bold tracking-wider text-slate-400 mb-1">Badge haut</span>
              <span class="text-sm font-semibold"><%= form && form.badgeTopLeft ? form.badgeTopLeft : '—' %></span>
            </div>
            <div class="bg-gray-50 dark:bg-gray-900/50 p-4 rounded-xl border border-border-light dark:border-border-dark flex flex-col items-center text-center">
              <div class="w-10 h-10 rounded-full bg-white dark:bg-gray-800 shadow-sm flex items-center justify-center mb-2">
                <span class="material-symbols-outlined">history</span>
              </div>
              <span class="text-[10px] uppercase font-bold tracking-wider text-slate-400 mb-1">État</span>
              <span class="text-sm font-semibold"><%= form && form.badgeCondition ? form.badgeCondition : '—' %></span>
            </div>
            <div class="bg-gray-50 dark:bg-gray-900/50 p-4 rounded-xl border border-border-light dark:border-border-dark flex flex-col items-center text-center">
              <div class="w-10 h-10 rounded-full bg-white dark:bg-gray-800 shadow-sm flex items-center justify-center mb-2">
                <span class="material-symbols-outlined">cable</span>
              </div>
              <span class="text-[10px] uppercase font-bold tracking-wider text-slate-400 mb-1">SKU</span>
              <span class="text-sm font-semibold"><%= form && form.sku ? form.sku : '—' %></span>
            </div>
            <div class="bg-gray-50 dark:bg-gray-900/50 p-4 rounded-xl border border-border-light dark:border-border-dark flex flex-col items-center text-center">
              <div class="w-10 h-10 rounded-full bg-white dark:bg-gray-800 shadow-sm flex items-center justify-center mb-2">
                <span class="material-symbols-outlined">verified</span>
              </div>
              <span class="text-[10px] uppercase font-bold tracking-wider text-slate-400 mb-1">Catégorie</span>
              <span class="text-sm font-semibold"><%= form && form.category ? form.category : '—' %></span>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-xs font-medium text-slate-500 uppercase mb-2" for="specType">Type (Caractéristiques principales) <span class="text-red-600">*</span></label>
              <input class="w-full bg-gray-50 dark:bg-gray-900 border-border-light dark:border-border-dark rounded-lg py-2.5 px-4 text-sm focus:ring-primary focus:border-primary" id="specType" name="specType" required type="text" placeholder="Ex: Boîte de vitesses" value="<%= specTypeValue %>" />
            </div>
            <div>
              <label class="block text-xs font-medium text-slate-500 uppercase mb-2" for="specProgrammation">Programmation (Caractéristiques principales) <span class="text-red-600">*</span></label>
              <input class="w-full bg-gray-50 dark:bg-gray-900 border-border-light dark:border-border-dark rounded-lg py-2.5 px-4 text-sm focus:ring-primary focus:border-primary" id="specProgrammation" name="specProgrammation" required type="text" placeholder="Ex: Oui / Non / À coder" value="<%= specProgrammationValue %>" />
            </div>
            <div>
              <label class="block text-xs font-medium text-slate-500 uppercase mb-2" for="badgeTopLeft">Garantie (affiché sur la fiche produit) <span class="text-red-600">*</span></label>
              <input class="w-full bg-gray-50 dark:bg-gray-900 border-border-light dark:border-border-dark rounded-lg py-2.5 px-4 text-sm focus:ring-primary focus:border-primary" id="badgeTopLeft" name="badgeTopLeft" placeholder="Ex: Garantie 24 mois" required type="text" value="<%= form && form.badgeTopLeft ? form.badgeTopLeft : '' %>" />
            </div>
            <div>
              <label class="block text-xs font-medium text-slate-500 uppercase mb-2" for="badgeCondition">État (affiché sur la fiche produit) <span class="text-red-600">*</span></label>
              <input class="w-full bg-gray-50 dark:bg-gray-900 border-border-light dark:border-border-dark rounded-lg py-2.5 px-4 text-sm focus:ring-primary focus:border-primary" id="badgeCondition" name="badgeCondition" placeholder="Ex: Reconditionné" required type="text" value="<%= form && form.badgeCondition ? form.badgeCondition : '' %>" />
            </div>
          </div>

          <div>
            <label class="block text-xs font-medium text-slate-500 uppercase mb-2" for="shortDescription">Résumé <span class="text-red-600">*</span></label>
            <textarea class="w-full bg-gray-50 dark:bg-gray-900 border-border-light dark:border-border-dark rounded-lg py-2.5 px-4 text-sm focus:ring-primary focus:border-primary resize-none" id="shortDescription" name="shortDescription" required rows="2"><%= form && form.shortDescription ? form.shortDescription : '' %></textarea>
            <div class="mt-2 text-xs text-slate-500">Obligatoire : un résumé court et clair visible rapidement par le client.</div>
          </div>

          <div class="border border-border-light dark:border-border-dark rounded-lg overflow-hidden">
            <div class="bg-gray-50 dark:bg-gray-800/50 px-4 py-2 border-b border-border-light dark:border-border-dark flex gap-2">
              <button class="p-1 hover:bg-white dark:hover:bg-gray-700 rounded" type="button"><span class="material-symbols-outlined text-lg">format_bold</span></button>
              <button class="p-1 hover:bg-white dark:hover:bg-gray-700 rounded" type="button"><span class="material-symbols-outlined text-lg">format_italic</span></button>
              <button class="p-1 hover:bg-white dark:hover:bg-gray-700 rounded" type="button"><span class="material-symbols-outlined text-lg">format_list_bulleted</span></button>
              <div class="w-px h-6 bg-border-light dark:bg-border-dark mx-1"></div>
              <button class="p-1 hover:bg-white dark:hover:bg-gray-700 rounded" type="button"><span class="material-symbols-outlined text-lg">link</span></button>
            </div>
            <textarea class="w-full bg-transparent border-none focus:ring-0 p-4 text-sm resize-none" id="description" name="description" placeholder="Description du produit..." required rows="8"><%= form && form.description ? form.description : '' %></textarea>
          </div>
        </div>
      </section>

      <section id="section-options" class="order-6 bg-surface-light dark:bg-surface-dark rounded-xl border border-border-light dark:border-border-dark shadow-sm overflow-hidden">
        <div class="p-6 border-b border-border-light dark:border-border-dark flex items-center justify-between">
          <div>
            <h2 class="font-bold flex items-center gap-2">
              <span class="material-symbols-outlined text-slate-400">tune</span>
              Étape 6 · Options / Variantes
              <span class="inline-flex items-center rounded-full bg-slate-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-slate-500">Optionnel</span>
            </h2>
            <div class="mt-2 text-xs text-slate-500">À utiliser seulement si le client doit choisir une variante, une programmation, une consigne ou un complément.</div>
          </div>

          <a class="inline-flex items-center justify-center rounded-lg border border-border-light dark:border-border-dark px-4 py-2 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-800 transition" href="/admin/catalogue/options">
            <span class="material-symbols-outlined mr-2 text-sm">inventory</span>
            Bibliothèque d'options
          </a>
        </div>

        <div class="p-6 space-y-6">
          <div class="rounded-2xl border border-border-light dark:border-border-dark bg-gray-50 dark:bg-gray-900/50 p-5">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
              <div>
                <div class="text-sm font-bold text-slate-900 dark:text-white">Options réutilisables</div>
                <div class="mt-1 text-xs text-slate-500">Créez vos options une fois dans la bibliothèque, puis appliquez-les ici en un clic.</div>
              </div>
              <a class="inline-flex items-center justify-center rounded-lg bg-white dark:bg-gray-800 border border-border-light dark:border-border-dark px-4 py-2 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 transition" href="/admin/catalogue/options">
                <span class="material-symbols-outlined mr-2 text-sm">settings</span>
                Gérer la bibliothèque
              </a>
            </div>

            <% if (productOptionTemplates && productOptionTemplates.length) { %>
              <div class="mt-4 grid grid-cols-1 lg:grid-cols-2 gap-3" id="templateLibrary"></div>
            <% } else { %>
              <div class="mt-4 rounded-xl border border-dashed border-border-light dark:border-border-dark bg-white dark:bg-gray-900 px-4 py-4 text-sm text-slate-500">
                Aucune option réutilisable pour le moment. Créez-les depuis la bibliothèque, puis revenez ici.
              </div>
            <% } %>
          </div>

          <div class="rounded-2xl border border-border-light dark:border-border-dark bg-white dark:bg-gray-950/40 p-5">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
              <div>
                <div class="text-sm font-bold text-slate-900 dark:text-white">Options de ce produit</div>
                <div class="mt-1 text-xs text-slate-500">Vous pouvez ajouter une option manuelle ou partir d'une option réutilisable.</div>
              </div>

              <button class="btn btn-secondary" id="addCustomOptionBtn" type="button">
                <span class="material-symbols-outlined mr-2 text-sm">add</span>
                Ajouter une option
              </button>
            </div>

            <div class="mt-4 space-y-4" id="productOptionsBuilder"></div>
            <div class="mt-4 rounded-xl border border-dashed border-border-light dark:border-border-dark bg-gray-50 dark:bg-gray-900/50 px-4 py-4 text-sm text-slate-500" id="productOptionsEmpty">
              Aucune option pour ce produit pour le moment.
            </div>
          </div>

          <details class="rounded-2xl border border-border-light dark:border-border-dark bg-gray-50 dark:bg-gray-900/50 overflow-hidden">
            <summary class="cursor-pointer px-5 py-4 text-sm font-bold text-slate-900 dark:text-white">Mode expert (JSON)</summary>
            <div class="border-t border-border-light dark:border-border-dark p-5 space-y-4">
              <div class="text-xs text-slate-500">Si besoin, vous pouvez toujours modifier le JSON brut puis recharger l'éditeur visuel.</div>
              <label class="block text-xs font-medium text-slate-500 uppercase" for="optionsJson">Options (JSON)</label>
              <textarea class="w-full bg-white dark:bg-gray-900 border-border-light dark:border-border-dark rounded-lg py-2.5 px-4 text-sm focus:ring-primary focus:border-primary font-mono min-h-[220px]" id="optionsJson" name="optionsJson" placeholder='[{"key":"programmation","label":"Programmation","type":"choice","required":true,"choices":[{"key":"avec","label":"Avec programmation","priceDeltaCents":5000},{"key":"sans","label":"Sans programmation","priceDeltaCents":0}]}]'><%= form && typeof form.optionsJson !== 'undefined' ? form.optionsJson : '' %></textarea>
              <div class="flex justify-end">
                <button class="inline-flex items-center justify-center rounded-lg border border-border-light dark:border-border-dark px-4 py-2 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-gray-200 hover:bg-white dark:hover:bg-gray-800 transition" id="applyOptionsJsonBtn" type="button">
                  Recharger depuis le JSON
                </button>
              </div>
            </div>
          </details>
        </div>
      </section>

      <section class="order-7 bg-surface-light dark:bg-surface-dark rounded-xl border border-border-light dark:border-border-dark shadow-sm">
        <div class="p-6 border-b border-border-light dark:border-border-dark flex items-center justify-between gap-4">
          <div>
            <h2 class="font-bold flex items-center gap-2">
              <span class="material-symbols-outlined text-slate-400">autorenew</span>
              Étape 7 · Étapes de reconditionnement
              <span class="inline-flex items-center rounded-full bg-slate-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-slate-500">Optionnel</span>
            </h2>
            <div class="mt-2 text-xs text-slate-500">Utile si vous voulez détailler le processus de reconditionnement ou de contrôle qualité.</div>
          </div>

          <button class="px-4 py-2 text-xs font-bold bg-gray-900 dark:bg-white dark:text-gray-900 text-white rounded-lg flex items-center gap-1 hover:bg-black transition-colors" id="stepsPrefillBtn" type="button">
            <span class="material-symbols-outlined text-sm">auto_fix</span>
            Pré-remplir (4 étapes)
          </button>
        </div>

        <div class="p-6 grid grid-cols-1 md:grid-cols-4 gap-6" id="stepsGrid">
          <% for (let i = 1; i <= 4; i += 1) { %>
            <div class="space-y-3" data-step>
              <div class="flex items-center justify-between">
                <span class="text-[10px] font-bold text-slate-400 uppercase">Step <%= i %></span>
