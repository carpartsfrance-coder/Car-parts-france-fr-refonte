<%- include('./partials/head') %>

<%- include('./partials/sidebar', { active: 'analytics' }) %>

<main class="flex-1 min-w-0 relative">
  <div class="px-6 lg:px-10 py-8">

    <nav class="breadcrumb">
      <a class="breadcrumb__link" href="/admin">Accueil</a>
      <span class="breadcrumb__sep material-symbols-outlined">chevron_right</span>
      <span class="breadcrumb__current">Analytics</span>
    </nav>

    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">
      <div>
        <div class="text-2xl md:text-3xl font-semibold text-slate-900">Analytics</div>
        <div class="mt-1 text-sm text-slate-500">Comportement visiteurs et conversion</div>
      </div>
      <% var isCustom = customFrom && customTo; %>
      <div class="flex items-center gap-2 relative">
        <a href="/admin/analytics?days=7" class="btn <%= !isCustom && days === 7 ? 'btn-primary' : 'btn-secondary' %>">7j</a>
        <a href="/admin/analytics?days=30" class="btn <%= !isCustom && days === 30 ? 'btn-primary' : 'btn-secondary' %>">30j</a>
        <a href="/admin/analytics?days=90" class="btn <%= !isCustom && days === 90 ? 'btn-primary' : 'btn-secondary' %>">90j</a>
        <button type="button" id="customDateBtn" class="btn <%= isCustom ? 'btn-primary' : 'btn-secondary' %> flex items-center gap-1.5">
          <span class="material-symbols-outlined" style="font-size:16px">date_range</span>
          <% if (isCustom) { %>
            <%= customFrom.slice(8) + '/' + customFrom.slice(5,7) %> - <%= customTo.slice(8) + '/' + customTo.slice(5,7) %>
          <% } else { %>
            Personnalise
          <% } %>
        </button>
        <!-- Date picker dropdown -->
        <div id="customDatePicker" class="hidden absolute right-0 top-full mt-2 z-50 bg-white rounded-xl border border-slate-200 shadow-lg p-4 w-72">
          <form id="customDateForm" method="GET" action="/admin/analytics">
            <div class="text-sm font-semibold text-slate-700 mb-3">Periode personnalisee</div>
            <div class="space-y-3">
              <div>
                <label class="text-xs text-slate-500 mb-1 block">Du</label>
                <input type="date" name="from" id="customDateFrom" value="<%= customFrom %>" max="<%= new Date().toISOString().slice(0,10) %>" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary" required />
              </div>
              <div>
                <label class="text-xs text-slate-500 mb-1 block">Au</label>
                <input type="date" name="to" id="customDateTo" value="<%= customTo %>" max="<%= new Date().toISOString().slice(0,10) %>" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary" required />
              </div>
            </div>
            <div class="flex items-center gap-2 mt-4">
              <button type="submit" class="btn btn-primary flex-1 text-sm">Appliquer</button>
              <button type="button" id="customDateCancel" class="btn btn-secondary text-sm">Annuler</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <%
      function renderTrend(t) {
        if (!t || t.delta === undefined) return '';
        if (t.delta === null) return '<div class="flex items-center gap-1 mt-1.5"><span class="inline-flex items-center gap-0.5 text-xs font-medium text-blue-600"><span class="material-symbols-outlined" style="font-size:14px">new_releases</span> Nouveau</span></div>';
        if (t.delta === 0) return '<div class="flex items-center gap-1 mt-1.5"><span class="text-xs text-slate-400">= stable</span></div>';
        var isUp = t.delta > 0;
        var color = isUp ? 'text-green-600' : 'text-red-500';
        var icon = isUp ? 'trending_up' : 'trending_down';
        return '<div class="flex items-center gap-1 mt-1.5"><span class="inline-flex items-center gap-0.5 text-xs font-medium ' + color + '"><span class="material-symbols-outlined" style="font-size:14px">' + icon + '</span>' + t.label + '%</span><span class="text-xs text-slate-400">vs periode prec.</span></div>';
      }
    %>

    <!-- KPI Cards -->
    <div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-6">
      <div class="kpi-card min-w-0 overflow-hidden">
        <div class="kpi-card__header">
          <div class="kpi-card__icon bg-blue-50 text-blue-600">
            <span class="material-symbols-outlined">visibility</span>
          </div>
        </div>
        <div class="kpi-card__label">Pages vues</div>
        <div class="kpi-card__value"><%= totalPageviews.toLocaleString('fr-FR') %></div>
        <%- renderTrend(trends.pageviews) %>
      </div>

      <div class="kpi-card min-w-0 overflow-hidden">
        <div class="kpi-card__header">
          <div class="kpi-card__icon bg-green-50 text-green-600">
            <span class="material-symbols-outlined">group</span>
          </div>
        </div>
        <div class="kpi-card__label">Sessions uniques</div>
        <div class="kpi-card__value"><%= totalSessions.toLocaleString('fr-FR') %></div>
        <%- renderTrend(trends.sessions) %>
      </div>

      <div class="kpi-card min-w-0 overflow-hidden">
        <div class="kpi-card__header">
          <div class="kpi-card__icon bg-purple-50 text-purple-600">
            <span class="material-symbols-outlined">search</span>
          </div>
        </div>
        <div class="kpi-card__label">Recherches</div>
        <div class="kpi-card__value"><%= totalSearches.toLocaleString('fr-FR') %></div>
        <%- renderTrend(trends.searches) %>
      </div>
    </div>

    <!-- Commercial KPI Cards -->
    <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="kpi-card min-w-0 overflow-hidden">
        <div class="kpi-card__header">
          <div class="kpi-card__icon bg-violet-50 text-violet-600">
            <span class="material-symbols-outlined">euro_symbol</span>
          </div>
        </div>
        <div class="kpi-card__label">Chiffre d'affaires</div>
        <div class="kpi-card__value"><%= commercialKpis.revenue.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %> &euro;</div>
        <%- renderTrend(trends.revenue) %>
      </div>

      <div class="kpi-card min-w-0 overflow-hidden">
        <div class="kpi-card__header">
          <div class="kpi-card__icon bg-orange-50 text-orange-600">
            <span class="material-symbols-outlined">shopping_bag</span>
          </div>
        </div>
        <div class="kpi-card__label">Commandes</div>
        <div class="kpi-card__value"><%= commercialKpis.orderCount.toLocaleString('fr-FR') %></div>
        <%- renderTrend(trends.orderCount) %>
      </div>

      <div class="kpi-card min-w-0 overflow-hidden">
        <div class="kpi-card__header">
          <div class="kpi-card__icon bg-teal-50 text-teal-600">
            <span class="material-symbols-outlined">shopping_cart</span>
          </div>
        </div>
        <div class="kpi-card__label">Panier moyen</div>
        <div class="kpi-card__value"><%= commercialKpis.avgBasket.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %> &euro;</div>
        <%- renderTrend(trends.avgBasket) %>
      </div>

      <div class="kpi-card min-w-0 overflow-hidden">
        <div class="kpi-card__header">
          <div class="kpi-card__icon bg-green-50 text-green-600">
            <span class="material-symbols-outlined">trending_up</span>
          </div>
        </div>
        <div class="kpi-card__label">Taux de conversion</div>
        <div class="kpi-card__value"><%= commercialKpis.conversionRate.toFixed(1) %>%</div>
        <%- renderTrend(trends.conversionRate) %>
      </div>
    </div>

    <!-- Traffic chart + Device breakdown -->
    <div class="mt-8 grid grid-cols-1 xl:grid-cols-3 gap-8">

      <!-- Traffic chart (2/3) -->
      <div class="xl:col-span-2 bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="px-6 py-5 border-b border-slate-100">
          <h2 class="text-lg font-semibold text-slate-900 flex items-center gap-2">
            <span class="material-symbols-outlined text-blue-600">trending_up</span>
            Evolution du trafic
          </h2>
          <p class="text-sm text-slate-500 mt-1">Pages vues et sessions sur la periode</p>
        </div>
        <% if (!dailyTraffic || dailyTraffic.length === 0) { %>
          <div class="px-6 py-12 flex flex-col items-center text-center">
            <span class="material-symbols-outlined text-slate-300" style="font-size:48px">show_chart</span>
            <p class="mt-3 font-medium text-slate-600">Pas encore de donnees de trafic</p>
            <p class="mt-1 text-sm text-slate-400 max-w-[400px]">Le graphique apparaitra des que le tracker collectera des visites. Verifiez que le script <code class="bg-slate-100 px-1 rounded text-xs">analytics-tracker.js</code> est bien charge sur votre site.</p>
          </div>
        <% } else { %>
          <div class="px-6 py-6">
            <canvas id="trafficChart" height="80"></canvas>
          </div>
        <% } %>
      </div>

      <!-- Device breakdown (1/3) -->
      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="px-6 py-5 border-b border-slate-100">
          <h2 class="text-lg font-semibold text-slate-900 flex items-center gap-2">
            <span class="material-symbols-outlined text-purple-600">devices</span>
            Appareils
          </h2>
          <p class="text-sm text-slate-500 mt-1">Repartition par type d'appareil</p>
        </div>
        <% if (!deviceBreakdown || deviceBreakdown.total === 0) { %>
          <div class="px-6 py-12 flex flex-col items-center text-center">
            <span class="material-symbols-outlined text-slate-300" style="font-size:48px">devices</span>
            <p class="mt-3 font-medium text-slate-600">Pas encore de donnees d'appareils</p>
            <p class="mt-1 text-sm text-slate-400 max-w-[400px]">Le tracking des appareils sera disponible des les premieres visites.</p>
          </div>
        <% } else { %>
          <div class="px-6 py-6 flex flex-col items-center gap-5">
            <div style="width:150px;height:150px">
              <canvas id="deviceChart"></canvas>
            </div>
            <div class="w-full space-y-3">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <span class="w-3 h-3 rounded-full bg-blue-500 shrink-0"></span>
                  <span class="text-sm text-slate-700">Desktop</span>
                </div>
                <div class="text-sm">
                  <span class="font-semibold text-slate-800"><%= deviceBreakdown.desktop.toLocaleString('fr-FR') %></span>
                  <span class="text-slate-400 ml-1">(<%= deviceBreakdown.desktopPct %>%)</span>
                </div>
              </div>
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <span class="w-3 h-3 rounded-full bg-green-500 shrink-0"></span>
                  <span class="text-sm text-slate-700">Mobile</span>
                </div>
                <div class="text-sm">
                  <span class="font-semibold text-slate-800"><%= deviceBreakdown.mobile.toLocaleString('fr-FR') %></span>
                  <span class="text-slate-400 ml-1">(<%= deviceBreakdown.mobilePct %>%)</span>
                </div>
              </div>
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <span class="w-3 h-3 rounded-full bg-orange-400 shrink-0"></span>
                  <span class="text-sm text-slate-700">Tablette</span>
                </div>
                <div class="text-sm">
                  <span class="font-semibold text-slate-800"><%= deviceBreakdown.tablet.toLocaleString('fr-FR') %></span>
                  <span class="text-slate-400 ml-1">(<%= deviceBreakdown.tabletPct %>%)</span>
                </div>
              </div>
            </div>
          </div>
        <% } %>
      </div>

    </div>

    <!-- Grid: 2 columns -->
    <div class="mt-8 grid grid-cols-1 xl:grid-cols-2 gap-8">

      <!-- 1. Conversion par source de trafic -->
      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="px-6 py-5 border-b border-slate-100">
          <h2 class="text-lg font-semibold text-slate-900 flex items-center gap-2">
            <span class="material-symbols-outlined text-green-600">conversion_path</span>
            Conversion par source de trafic
          </h2>
          <p class="text-sm text-slate-500 mt-1">Taux de conversion par canal d'acquisition</p>
        </div>
        <div class="overflow-x-auto">
          <% if (conversionBySource.length === 0) { %>
            <div class="px-6 py-12 flex flex-col items-center text-center">
              <span class="material-symbols-outlined text-slate-300" style="font-size:48px">hourglass_empty</span>
              <p class="mt-3 font-medium text-slate-600">Pas encore de donnees de conversion</p>
              <p class="mt-1 text-sm text-slate-400 max-w-[400px]">Les sources de trafic et taux de conversion apparaitront ici une fois que des visiteurs auront ete detectes. Essayez de selectionner une periode plus large.</p>
            </div>
          <% } else { %>
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50">
                  <th class="text-left px-6 py-3 font-medium text-slate-600">Source</th>
                  <th class="text-left px-4 py-3 font-medium text-slate-600">Medium</th>
                  <th class="text-right px-4 py-3 font-medium text-slate-600">Sessions</th>
                  <th class="text-right px-4 py-3 font-medium text-slate-600">Conversions</th>
                  <th class="text-right px-6 py-3 font-medium text-slate-600">Taux</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <% conversionBySource.forEach(function(row) { %>
                  <tr class="hover:bg-slate-50 transition">
                    <td class="px-6 py-3 font-medium text-slate-900"><%= row.source %></td>
                    <td class="px-4 py-3 text-slate-600"><%= row.medium %></td>
                    <td class="px-4 py-3 text-right text-slate-700"><%= row.sessions %></td>
                    <td class="px-4 py-3 text-right text-slate-700"><%= row.conversions %></td>
                    <td class="px-6 py-3 text-right">
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold
                        <%= parseFloat(row.rate) > 3 ? 'bg-green-100 text-green-800' : parseFloat(row.rate) > 1 ? 'bg-yellow-100 text-yellow-800' : 'bg-slate-100 text-slate-600' %>">
                        <%= row.rate %>%
                      </span>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>

      <!-- 3. Recherches sans resultat -->
      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="px-6 py-5 border-b border-slate-100">
          <h2 class="text-lg font-semibold text-slate-900 flex items-center gap-2">
            <span class="material-symbols-outlined text-red-500">search_off</span>
            Recherches sans resultat
            <% if (failedSearches.length > 0) { %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-red-100 text-red-700 ml-1"><%= failedSearches.length %></span>
            <% } %>
          </h2>
          <p class="text-sm text-slate-500 mt-1">Produits que vos clients cherchent mais ne trouvent pas</p>
        </div>
        <div class="overflow-x-auto">
          <% if (failedSearches.length === 0) { %>
            <div class="px-6 py-12 flex flex-col items-center text-center">
              <span class="material-symbols-outlined text-green-400" style="font-size:48px">check_circle</span>
              <p class="mt-3 font-medium text-slate-600">Parfait ! Tous les termes recherches ont trouve des resultats.</p>
              <p class="mt-1 text-sm text-slate-400 max-w-[400px]">Aucun visiteur n'a cherche un produit introuvable sur cette periode. Votre catalogue couvre bien la demande !</p>
            </div>
          <% } else { %>
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50">
                  <th class="text-left px-6 py-3 font-medium text-slate-600">Terme recherche</th>
                  <th class="text-right px-4 py-3 font-medium text-slate-600">Recherches</th>
                  <th class="text-right px-4 py-3 font-medium text-slate-600">Derniere fois</th>
                  <th class="text-right px-6 py-3 font-medium text-slate-600">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <% failedSearches.forEach(function(row, idx) { %>
                  <%
                    var badgeClass = row.count > 5 ? 'bg-red-100 text-red-700' : row.count >= 2 ? 'bg-orange-100 text-orange-700' : 'bg-slate-100 text-slate-600';
                  %>
                  <tr class="hover:bg-slate-50 transition" id="failed-search-<%= idx %>">
                    <td class="px-6 py-3">
                      <span class="font-medium text-slate-900">"<%= row.query %>"</span>
                    </td>
                    <td class="px-4 py-3 text-right">
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold <%= badgeClass %>"><%= row.count %></span>
                    </td>
                    <td class="px-4 py-3 text-right text-slate-500 text-xs">
                      <%= row.lastSearched ? new Date(row.lastSearched).toLocaleDateString('fr-FR') : '-' %>
                    </td>
                    <td class="px-6 py-3 text-right">
                      <div class="flex items-center justify-end gap-1.5">
                        <a href="/admin/catalogue/nouveau?search_term=<%= encodeURIComponent(row.query) %>" class="inline-flex items-center gap-1 px-2.5 py-1.5 rounded-lg text-xs font-semibold bg-blue-50 text-blue-700 hover:bg-blue-100 transition" title="Creer un produit pour ce terme">
                          <span class="material-symbols-outlined" style="font-size:14px">add_circle</span>
                          Creer
                        </a>
                        <div class="relative">
                          <button type="button" class="synonym-btn inline-flex items-center gap-1 px-2 py-1.5 rounded-lg text-xs font-semibold bg-slate-50 text-slate-600 hover:bg-slate-100 transition" data-idx="<%= idx %>" data-terme="<%= row.query %>" title="Associer comme synonyme a un produit existant">
                            <span class="material-symbols-outlined" style="font-size:14px">link</span>
                          </button>
                          <!-- Synonym dropdown -->
                          <div class="synonym-dropdown hidden absolute right-0 top-full mt-1 z-50 bg-white rounded-xl border border-slate-200 shadow-lg p-3 w-64" data-idx="<%= idx %>">
                            <div class="text-xs font-semibold text-slate-700 mb-2">Associer "<%= row.query %>" a :</div>
                            <input type="text" class="synonym-search w-full px-2.5 py-1.5 border border-slate-200 rounded-lg text-xs focus:outline-none focus:ring-2 focus:ring-primary/20 mb-2" placeholder="Rechercher un produit..." data-idx="<%= idx %>" />
                            <div class="synonym-results max-h-32 overflow-y-auto text-xs" data-idx="<%= idx %>"></div>
                            <div class="synonym-status hidden mt-2 text-xs font-medium text-green-600" data-idx="<%= idx %>"></div>
                          </div>
                        </div>
                      </div>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>

    </div>

    <!-- Top pages visitées -->
    <div class="mt-8 bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
      <div class="px-6 py-5 border-b border-slate-100">
        <h2 class="text-lg font-semibold text-slate-900 flex items-center gap-2">
          <span class="material-symbols-outlined text-indigo-600">description</span>
          Pages les plus visitees
        </h2>
        <p class="text-sm text-slate-500 mt-1">Les pages les plus consultees sur la periode</p>
      </div>
      <div class="overflow-x-auto">
        <% if (!topPages || topPages.length === 0) { %>
          <div class="px-6 py-12 flex flex-col items-center text-center">
            <span class="material-symbols-outlined text-slate-300" style="font-size:48px">description</span>
            <p class="mt-3 font-medium text-slate-600">Aucune page visitee sur cette periode</p>
            <p class="mt-1 text-sm text-slate-400 max-w-[400px]">Les pages les plus consultees apparaitront ici des que des visiteurs navigueront sur votre site.</p>
          </div>
        <% } else { %>
          <% var maxViews = topPages[0].views || 1; %>
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-slate-50">
                <th class="text-left px-6 py-3 font-medium text-slate-600">Page</th>
                <th class="text-right px-4 py-3 font-medium text-slate-600">Vues</th>
                <th class="text-right px-6 py-3 font-medium text-slate-600">Visiteurs uniques</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% topPages.forEach(function(row) { %>
                <%
                  var barWidth = ((row.views / maxViews) * 100).toFixed(1);
                  var displayUrl = row.page.length > 60 ? row.page.slice(0, 57) + '...' : row.page;
                %>
                <tr class="hover:bg-slate-50/50 transition relative">
                  <td class="px-6 py-3 relative">
                    <!-- Background bar -->
                    <div class="absolute inset-y-0 left-0 bg-indigo-50 rounded-r" style="width: <%= barWidth %>%; transition: width 0.4s ease;"></div>
                    <div class="relative">
                      <% if (row.isProduct && row.productName) { %>
                        <a href="<%= row.page %>" target="_blank" class="font-medium text-slate-900 hover:text-indigo-600 transition"><%= row.productName %></a>
                        <div class="text-xs text-slate-400 mt-0.5 truncate max-w-sm"><%= row.page %></div>
                      <% } else { %>
                        <a href="<%= row.page %>" target="_blank" class="font-medium text-slate-900 hover:text-indigo-600 transition"><%= displayUrl %></a>
                      <% } %>
                    </div>
                  </td>
                  <td class="px-4 py-3 text-right relative">
                    <span class="font-semibold text-slate-800"><%= row.views.toLocaleString('fr-FR') %></span>
                  </td>
                  <td class="px-6 py-3 text-right relative">
                    <span class="text-slate-600"><%= row.visitors.toLocaleString('fr-FR') %></span>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } %>
      </div>
    </div>

    <!-- Funnel (full width) -->
    <div class="mt-8 bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
      <div class="px-6 py-5 border-b border-slate-100">
        <h2 class="text-lg font-semibold text-slate-900 flex items-center gap-2">
          <span class="material-symbols-outlined text-blue-600">filter_alt</span>
          Tunnel de conversion
        </h2>
        <p class="text-sm text-slate-500 mt-1">Taux d'abandon a chaque etape du parcours d'achat</p>
      </div>

      <% if (funnelSteps.length === 0) { %>
        <div class="px-6 py-12 flex flex-col items-center text-center">
          <span class="material-symbols-outlined text-slate-300" style="font-size:48px">route</span>
          <p class="mt-3 font-medium text-slate-600">Pas assez de trafic pour afficher le tunnel</p>
          <p class="mt-1 text-sm text-slate-400 max-w-[400px]">Le tunnel de conversion se construit au fur et a mesure que les visiteurs parcourent votre site : page produit &rarr; panier &rarr; commande. Revenez quand le trafic aura augmente.</p>
        </div>
      <% } else { %>
        <%
          var maxCount = funnelSteps[0].count || 1;
          var funnelColors = ['#2563eb', '#3b82f6', '#60a5fa', '#93c5fd', '#bfdbfe', '#22c55e'];
        %>
        <div class="px-6 py-6 space-y-1">
          <% funnelSteps.forEach(function(step, i) { %>
            <%
              var widthPct = maxCount > 0 ? Math.max(5, (step.count / maxCount) * 100) : 5;
              var barColor = step.count === 0 ? '#e2e8f0' : (funnelColors[i] || '#93c5fd');
              var textColor = step.count === 0 ? 'text-slate-400' : 'text-white';
              var pctDisplay = step.percentage !== '—' ? step.percentage + '%' : '—';
            %>
            <!-- Step bar -->
            <div class="flex items-center gap-3">
              <div class="w-28 sm:w-36 shrink-0 text-right">
                <span class="text-xs sm:text-sm font-semibold text-slate-700"><%= step.label %></span>
              </div>
              <div class="flex-1 min-w-0">
                <div class="relative mx-auto" style="width: <%= widthPct.toFixed(1) %>%; transition: width 0.6s ease;">
                  <div class="h-11 sm:h-12 rounded-lg flex items-center justify-between px-3 sm:px-4" style="background: <%= barColor %>;">
                    <span class="text-sm sm:text-base font-bold <%= textColor %> truncate"><%= step.count.toLocaleString('fr-FR') %></span>
                    <span class="text-xs font-semibold <%= textColor %> opacity-80 ml-2 shrink-0"><%= pctDisplay %></span>
                  </div>
                </div>
              </div>
            </div>
            <!-- Drop-off indicator between steps -->
            <% if (i < funnelSteps.length - 1) { %>
              <div class="flex items-center gap-3">
                <div class="w-28 sm:w-36 shrink-0"></div>
                <div class="flex-1 min-w-0 pl-2">
                  <% if (step.count > 0 && funnelSteps[i+1].dropoff !== '—' && parseFloat(funnelSteps[i+1].dropoff) > 0) { %>
                    <span class="inline-flex items-center gap-1 text-xs font-medium text-red-500">
                      <span class="material-symbols-outlined" style="font-size:14px">south</span>
                      -<%= funnelSteps[i+1].dropoff %>% abandonnent
                    </span>
                  <% } else if (step.count > 0 && funnelSteps[i+1].count > 0) { %>
                    <span class="inline-flex items-center gap-1 text-xs font-medium text-green-600">
                      <span class="material-symbols-outlined" style="font-size:14px">south</span>
                      100% passent
                    </span>
                  <% } else { %>
                    <span class="text-xs text-slate-300">&darr;</span>
                  <% } %>
                </div>
              </div>
            <% } %>
          <% }); %>
        </div>
      <% } %>
    </div>

    <!-- Product interactions -->
    <div class="mt-8 bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
      <div class="px-6 py-5 border-b border-slate-100">
        <h2 class="text-lg font-semibold text-slate-900 flex items-center gap-2">
          <span class="material-symbols-outlined text-orange-500">touch_app</span>
          Interactions sur les fiches produit
        </h2>
        <p class="text-sm text-slate-500 mt-1">Ce que vos clients regardent et cliquent sur les pages produit</p>
      </div>

      <% if (!productClicks || !productClicks.summary || productClicks.summary.length === 0) { %>
        <div class="px-6 py-12 flex flex-col items-center text-center">
          <span class="material-symbols-outlined text-slate-300" style="font-size:48px">touch_app</span>
          <p class="mt-3 font-medium text-slate-600">Aucune interaction trackee</p>
          <p class="mt-1 text-sm text-slate-400 max-w-[400px]">Les clics sur les images, descriptions, FAQ et boutons d'ajout au panier apparaitront ici des que des visiteurs interagiront avec vos fiches produit.</p>
        </div>
      <% } else { %>
        <!-- Summary cards -->
        <div class="px-6 py-5 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
          <% productClicks.summary.forEach(function(item) { %>
            <div class="bg-slate-50 rounded-xl p-4 text-center">
              <div class="text-2xl font-bold text-slate-800"><%= item.count %></div>
              <div class="text-xs text-slate-600 mt-1"><%= item.label %></div>
              <div class="text-xs text-slate-400"><%= item.uniqueProducts %> produit<%= item.uniqueProducts > 1 ? 's' : '' %></div>
            </div>
          <% }); %>
        </div>

        <!-- Top interactions detail -->
        <% if (productClicks.details && productClicks.details.length > 0) { %>
          <div class="border-t border-slate-100 overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50">
                  <th class="text-left px-6 py-3 font-medium text-slate-600">Produit</th>
                  <th class="text-left px-4 py-3 font-medium text-slate-600">Interaction</th>
                  <th class="text-right px-6 py-3 font-medium text-slate-600">Nombre</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <% productClicks.details.slice(0, 20).forEach(function(row) { %>
                  <tr class="hover:bg-slate-50 transition">
                    <td class="px-6 py-3 font-medium text-slate-900 max-w-xs truncate"><%= row.productName %></td>
                    <td class="px-4 py-3 text-slate-600"><%= row.interactionLabel %></td>
                    <td class="px-6 py-3 text-right text-slate-700"><%= row.count %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      <% } %>
    </div>

    <div class="h-8"></div>
  </div>
</main>

<% var needsChartJs = (dailyTraffic && dailyTraffic.length > 0) || (deviceBreakdown && deviceBreakdown.total > 0); %>
<% if (needsChartJs) { %>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<% } %>

<% if (dailyTraffic && dailyTraffic.length > 0) { %>
<script>
(function() {
  var data = <%- JSON.stringify(dailyTraffic) %>;
  var labels = data.map(function(d) {
    var parts = d.date.split('-');
    return parts[2] + '/' + parts[1];
  });
  var pageviews = data.map(function(d) { return d.pageviews; });
  var sessions = data.map(function(d) { return d.sessions; });

  var ctx = document.getElementById('trafficChart');
  if (!ctx) return;

  new Chart(ctx, {
    type: 'line',
    data: {
      labels: labels,
      datasets: [
        {
          label: 'Pages vues',
          data: pageviews,
          borderColor: 'rgb(59, 130, 246)',
          backgroundColor: 'rgba(59, 130, 246, 0.08)',
          fill: true,
          tension: 0.3,
          pointRadius: data.length > 60 ? 0 : 3,
          pointHoverRadius: 5,
          borderWidth: 2,
        },
        {
          label: 'Sessions',
          data: sessions,
          borderColor: 'rgb(34, 197, 94)',
          backgroundColor: 'rgba(34, 197, 94, 0.08)',
          fill: true,
          tension: 0.3,
          pointRadius: data.length > 60 ? 0 : 3,
          pointHoverRadius: 5,
          borderWidth: 2,
        },
      ],
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { position: 'top', labels: { usePointStyle: true, padding: 20 } },
        tooltip: {
          backgroundColor: 'rgba(15, 23, 42, 0.9)',
          padding: 12,
          cornerRadius: 8,
          titleFont: { weight: 'bold' },
        },
      },
      scales: {
        x: {
          grid: { display: false },
          ticks: {
            maxTicksLimit: data.length > 60 ? 10 : 15,
            font: { size: 11 },
            color: '#94a3b8',
          },
        },
        y: {
          beginAtZero: true,
          grid: { color: 'rgba(148, 163, 184, 0.1)' },
          ticks: {
            font: { size: 11 },
            color: '#94a3b8',
            precision: 0,
          },
        },
      },
    },
  });
})();
</script>
<% } %>

<% if (deviceBreakdown && deviceBreakdown.total > 0) { %>
<script>
(function() {
  var ctx = document.getElementById('deviceChart');
  if (!ctx) return;

  new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: ['Desktop', 'Mobile', 'Tablette'],
      datasets: [{
        data: [<%= deviceBreakdown.desktop %>, <%= deviceBreakdown.mobile %>, <%= deviceBreakdown.tablet %>],
        backgroundColor: ['rgb(59, 130, 246)', 'rgb(34, 197, 94)', 'rgb(251, 146, 60)'],
        borderWidth: 0,
        hoverOffset: 6,
      }],
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      cutout: '65%',
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: 'rgba(15, 23, 42, 0.9)',
          padding: 10,
          cornerRadius: 8,
          callbacks: {
            label: function(ctx) {
              var total = ctx.dataset.data.reduce(function(a, b) { return a + b; }, 0);
              var pct = total > 0 ? ((ctx.raw / total) * 100).toFixed(1) : '0';
              return ctx.label + ': ' + ctx.raw.toLocaleString('fr-FR') + ' (' + pct + '%)';
            },
          },
        },
      },
    },
  });
})();
</script>
<% } %>

<script>
(function() {
  var btn = document.getElementById('customDateBtn');
  var picker = document.getElementById('customDatePicker');
  var cancel = document.getElementById('customDateCancel');
  var fromInput = document.getElementById('customDateFrom');
  var toInput = document.getElementById('customDateTo');

  if (!btn || !picker) return;

  btn.addEventListener('click', function(e) {
    e.stopPropagation();
    picker.classList.toggle('hidden');
  });

  cancel.addEventListener('click', function() {
    picker.classList.add('hidden');
  });

  // Close on outside click
  document.addEventListener('click', function(e) {
    if (!picker.contains(e.target) && e.target !== btn && !btn.contains(e.target)) {
      picker.classList.add('hidden');
    }
  });

  // Ensure "from" <= "to"
  fromInput.addEventListener('change', function() {
    if (toInput.value && fromInput.value > toInput.value) {
      toInput.value = fromInput.value;
    }
    toInput.min = fromInput.value;
  });

  toInput.addEventListener('change', function() {
    if (fromInput.value && toInput.value < fromInput.value) {
      fromInput.value = toInput.value;
    }
  });
})();
</script>

<script>
(function() {
  // Synonym dropdown logic
  var searchTimers = {};

  // Toggle synonym dropdowns
  document.querySelectorAll('.synonym-btn').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      var idx = btn.getAttribute('data-idx');
      var dd = document.querySelector('.synonym-dropdown[data-idx="' + idx + '"]');
      // Close all others
      document.querySelectorAll('.synonym-dropdown').forEach(function(d) {
        if (d !== dd) d.classList.add('hidden');
      });
      dd.classList.toggle('hidden');
      if (!dd.classList.contains('hidden')) {
        dd.querySelector('.synonym-search').focus();
      }
    });
  });

  // Close dropdowns on outside click
  document.addEventListener('click', function(e) {
    if (!e.target.closest('.synonym-dropdown') && !e.target.closest('.synonym-btn')) {
      document.querySelectorAll('.synonym-dropdown').forEach(function(d) { d.classList.add('hidden'); });
    }
  });

  // Search products on input
  document.querySelectorAll('.synonym-search').forEach(function(input) {
    input.addEventListener('input', function() {
      var idx = input.getAttribute('data-idx');
      var q = input.value.trim();
      if (searchTimers[idx]) clearTimeout(searchTimers[idx]);
      if (q.length < 2) {
        document.querySelector('.synonym-results[data-idx="' + idx + '"]').innerHTML = '<div class="text-slate-400 py-2">Tapez au moins 2 caracteres...</div>';
        return;
      }
      searchTimers[idx] = setTimeout(function() {
        fetch('/admin/api/products/search?q=' + encodeURIComponent(q) + '&limit=6')
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var resultsEl = document.querySelector('.synonym-results[data-idx="' + idx + '"]');
            var items = data.items || data.products || [];
            if (items.length === 0) {
              resultsEl.innerHTML = '<div class="text-slate-400 py-2">Aucun produit trouve.</div>';
              return;
            }
            resultsEl.innerHTML = items.map(function(p) {
              var id = p._id || p.id;
              var name = p.name || p.title || '';
              return '<button type="button" class="synonym-pick w-full text-left px-2 py-1.5 rounded hover:bg-blue-50 transition truncate" data-idx="' + idx + '" data-product-id="' + id + '">' + name + '</button>';
            }).join('');
          })
          .catch(function() {
            document.querySelector('.synonym-results[data-idx="' + idx + '"]').innerHTML = '<div class="text-red-500 py-2">Erreur de recherche.</div>';
          });
      }, 300);
    });
  });

  // Handle product pick (add synonym)
  document.addEventListener('click', function(e) {
    var pick = e.target.closest('.synonym-pick');
    if (!pick) return;
    var idx = pick.getAttribute('data-idx');
    var productId = pick.getAttribute('data-product-id');
    var btn = document.querySelector('.synonym-btn[data-idx="' + idx + '"]');
    var terme = btn ? btn.getAttribute('data-terme') : '';

    fetch('/admin/analytics/synonyme', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ terme: terme, product_id: productId }),
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var statusEl = document.querySelector('.synonym-status[data-idx="' + idx + '"]');
      if (data.ok) {
        statusEl.textContent = '"' + terme + '" associe a ' + (data.productName || 'ce produit');
        statusEl.className = 'synonym-status mt-2 text-xs font-medium text-green-600';
        statusEl.classList.remove('hidden');
        // Fade out the row after a moment
        setTimeout(function() {
          var row = document.getElementById('failed-search-' + idx);
          if (row) { row.style.opacity = '0.4'; }
          document.querySelector('.synonym-dropdown[data-idx="' + idx + '"]').classList.add('hidden');
        }, 1200);
      } else {
        statusEl.textContent = data.error || 'Erreur';
        statusEl.className = 'synonym-status mt-2 text-xs font-medium text-red-500';
        statusEl.classList.remove('hidden');
      }
    })
    .catch(function() {
      var statusEl = document.querySelector('.synonym-status[data-idx="' + idx + '"]');
      statusEl.textContent = 'Erreur reseau.';
      statusEl.className = 'synonym-status mt-2 text-xs font-medium text-red-500';
      statusEl.classList.remove('hidden');
    });
  });
})();
</script>

