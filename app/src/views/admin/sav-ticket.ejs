      <p class="text-slate-600">Confirmez les étapes et la cause racine.</p>
      <div><label class="block text-xs font-semibold text-slate-600 mb-1">Statut</label><select name="targetStatut" class="w-full rounded-xl border border-slate-300 px-3 py-2 text-sm" required><option value="resolu_garantie">✅ Résolu (garantie)</option><option value="resolu_facture">💶 Résolu (facturé)</option><option value="clos">🔒 Clos</option><option value="refuse">🚫 Refusé</option></select></div>
      <div class="space-y-2 rounded-xl border border-slate-200 bg-slate-50 p-3">
        <label class="flex items-start gap-2 cursor-pointer"><input type="checkbox" name="clientNotified" class="mt-0.5" required><span><strong>Client notifié</strong> <span class="text-red-500">*</span></span></label>
        <label class="flex items-start gap-2 cursor-pointer"><input type="checkbox" name="refundDone" class="mt-0.5"><span>Remboursement effectué</span></label>
        <label class="flex items-start gap-2 cursor-pointer"><input type="checkbox" name="docsArchived" class="mt-0.5" required><span><strong>Documents archivés</strong> <span class="text-red-500">*</span></span></label>
      </div>
      <div><label class="block text-xs font-semibold text-slate-600 mb-1">Cause racine <span class="text-red-500">*</span></label><select name="rootCause" class="w-full rounded-xl border border-slate-300 px-3 py-2 text-sm" required><option value="">— Sélectionner —</option><option value="defaut_produit">Défaut produit</option><option value="defaut_fournisseur">Défaut fournisseur</option><option value="erreur_preparation">Erreur préparation</option><option value="erreur_client">Erreur client</option><option value="dommage_transport">Dommage transport</option><option value="incompatibilite">Incompatibilité</option><option value="rétractation_client">Rétractation</option><option value="autre">Autre</option></select></div>
      <div><label class="block text-xs font-semibold text-slate-600 mb-1">Détail (optionnel)</label><textarea name="rootCauseDetail" rows="2" class="w-full rounded-xl border border-slate-300 px-3 py-2 text-sm" placeholder="Ex : Défaut capteur…"></textarea></div>
      <div class="flex items-center justify-end gap-2 pt-2 border-t border-slate-200">
        <button type="button" id="sav-close-cancel-2" class="px-4 py-2 rounded-xl border border-slate-300 text-slate-700 hover:bg-slate-50 text-sm font-semibold">Annuler</button>
        <button type="submit" class="px-4 py-2 rounded-xl bg-primary hover:bg-primary-hover text-white text-sm font-semibold inline-flex items-center gap-1.5"><span class="material-symbols-outlined" style="font-size:16px;">check</span>Clôturer</button>
      </div>
    </form>
  </div>
</div>

