  <div class="bg-white rounded-2xl shadow-xl max-w-md w-full p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 id="sav-kbd-modal-title" class="text-lg font-semibold">Raccourcis clavier</h3>
      <button type="button" data-close-kbd aria-label="Fermer la modale" class="text-slate-400 text-2xl leading-none">×</button>
