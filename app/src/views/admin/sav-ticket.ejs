<%- include('./partials/head') %>
<link rel="stylesheet" href="/css/sav.css?v=20">
<%- include('./partials/sidebar', { active: 'sav' }) %>

<main class="flex-1 sav-module" data-sav-token="<%= savApiToken %>" data-sav-numero="<%= numero %>" data-current-statut="" data-current-user-id="<%= (typeof currentAdmin !== 'undefined' && currentAdmin && currentAdmin.adminUserId) || '' %>">

  <!-- HEADER STICKY -->
  <header class="sticky top-0 z-30 bg-white border-b border-slate-200 px-6 lg:px-10 py-3">
    <!-- Breadcrumb -->
    <nav aria-label="Fil d'Ariane" class="text-xs text-slate-500 mb-2 flex items-center gap-1.5">
      <a href="/admin" class="hover:text-slate-900">Admin</a>
      <span class="text-slate-300">/</span>
      <a href="/admin/sav" class="hover:text-slate-900">SAV</a>
      <span class="text-slate-300">/</span>
      <a href="/admin/sav/tickets" class="hover:text-slate-900">Tickets</a>
      <span class="text-slate-300">/</span>
      <span class="font-mono text-slate-700"><%= numero %></span>
    </nav>

    <div class="flex items-start justify-between gap-4 flex-wrap">
      <!-- Bloc gauche : retour + titre + meta -->
      <div class="flex items-start gap-3 min-w-0 flex-1">
        <a href="/admin/sav/tickets" title="Retour à la liste" aria-label="Retour à la liste des tickets"
           class="shrink-0 inline-flex items-center justify-center w-8 h-8 rounded-xl text-slate-500 hover:text-slate-900 hover:bg-slate-100 transition">
          <span class="material-symbols-outlined" style="font-size:20px;" aria-hidden="true">arrow_back</span>
        </a>
        <div class="min-w-0">
          <div class="flex items-center gap-2">
            <h1 class="text-lg font-mono font-bold text-slate-900 truncate"><%= numero %></h1>
            <button type="button" id="sav-copy-numero" data-copy="<%= numero %>" title="Copier le numéro" aria-label="Copier le numéro de ticket"
              class="inline-flex items-center justify-center w-7 h-7 rounded-md text-slate-400 hover:text-primary hover:bg-slate-100 transition">
              <span class="material-symbols-outlined" style="font-size:16px;">content_copy</span>
            </button>
          </div>
          <div id="sav-header-meta" class="mt-1 flex flex-col gap-1.5 text-xs text-slate-500" aria-busy="true">
            <span class="sav-skeleton sav-skeleton--line" style="width:200px;"></span>
            <span class="sav-skeleton sav-skeleton--line" style="width:200px;"></span>
          </div>
        </div>
      </div>

      <!-- Bloc droit : SLA + statut + assigné + help -->
      <div class="flex items-center gap-2 flex-wrap shrink-0">
        <div id="sav-sla-badge" class="sav-sla-badge sav-sla-badge--ok inline-flex items-center gap-1">
          <span class="material-symbols-outlined" style="font-size:14px;">schedule</span>
          <span>SLA —</span>
        </div>
        <div id="sav-statut-badge" class="px-3 py-1 rounded-full text-xs font-semibold bg-slate-100 text-slate-700">—</div>
        <button type="button" id="sav-assign-btn" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-xl text-xs border border-slate-300 hover:border-primary hover:text-primary transition">
          <span id="sav-assign-avatar" class="hidden w-5 h-5 rounded-full bg-primary text-white text-[10px] font-bold items-center justify-center"></span>
          <span class="material-symbols-outlined" id="sav-assign-icon" style="font-size:14px;">person_add</span>
          <span id="sav-assign-label">Assigner</span>
        </button>
        <button type="button" id="sav-help-btn" title="Raccourcis clavier" aria-label="Afficher les raccourcis clavier" class="w-7 h-7 rounded-full border border-slate-300 hover:border-primary text-slate-500 hover:text-primary text-xs font-bold">?</button>
      </div>
    </div>
  </header>

  <!-- NOTES ÉPINGLÉES (résumé interne) — placée AVANT le stepper pour visibilité max -->
  <section id="sav-pinned-notes-section" class="px-6 lg:px-10 pt-3 pb-1">
    <div id="sav-pinned-notes-wrap" class="hidden">
      <div class="flex items-center justify-between mb-1.5">
        <h2 class="text-[11px] font-semibold uppercase tracking-wide text-slate-500 flex items-center gap-1">
          <span class="material-symbols-outlined" style="font-size:14px;">push_pin</span>
          Notes épinglées
          <span id="sav-pinned-count" class="ml-1 inline-flex items-center justify-center min-w-[18px] h-[18px] px-1.5 rounded-full bg-slate-200 text-slate-700 text-[10px] font-bold"></span>
        </h2>
        <div class="flex items-center gap-2">
          <button type="button" id="sav-pinned-dense-toggle" class="text-[11px] text-slate-500 hover:text-slate-700" title="Mode dense">
            <span class="material-symbols-outlined" style="font-size:14px;">density_small</span>
          </button>
          <button type="button" id="sav-pinned-history-btn" class="text-[11px] text-slate-500 hover:text-slate-700" title="Historique notes supprimées">
            <span class="material-symbols-outlined" style="font-size:14px;">history</span>
          </button>
          <button type="button" id="sav-pinned-add-btn-top" class="inline-flex items-center gap-1 rounded-md bg-primary text-white px-2.5 py-1 text-[11px] font-semibold hover:bg-primary-dark">
            <span class="material-symbols-outlined" style="font-size:14px;">add</span> Épingler <kbd class="ml-1 px-1 bg-white/20 rounded text-[9px]">⇧P</kbd>
          </button>
        </div>
      </div>
      <div id="sav-pinned-notes" class="flex flex-wrap gap-2"></div>
      <button type="button" id="sav-pinned-showall" class="hidden mt-1.5 text-[11px] text-primary hover:underline"></button>
    </div>
    <div id="sav-pinned-empty" class="flex items-center justify-end">
      <button type="button" id="sav-pinned-add-btn-empty" class="inline-flex items-center gap-1 rounded-md border border-dashed border-slate-300 px-2.5 py-1 text-[11px] font-medium text-slate-500 hover:border-primary hover:text-primary">
        <span class="material-symbols-outlined" style="font-size:14px;">push_pin</span>
        Épingler une note <kbd class="ml-1 px-1 bg-slate-100 rounded text-[9px]">⇧P</kbd>
      </button>
    </div>

    <!-- Form ajout/édition -->
    <form id="sav-pinned-add-form" class="hidden mt-2 rounded-lg border border-slate-200 bg-slate-50 p-3">
      <input type="hidden" id="sav-pinned-edit-id" value="" />
      <div class="flex flex-wrap gap-1.5 mb-2" id="sav-pinned-templates">
        <button type="button" data-tpl="⚠️ Client difficile" class="sav-pinned-tpl text-[10px] px-2 py-0.5 rounded-full bg-white border border-slate-300 hover:border-primary">⚠️ Client difficile</button>
        <button type="button" data-tpl="📞 Rappel promis le " class="sav-pinned-tpl text-[10px] px-2 py-0.5 rounded-full bg-white border border-slate-300 hover:border-primary">📞 Rappel promis</button>
        <button type="button" data-tpl="🔗 Dossier lié #SAV-" class="sav-pinned-tpl text-[10px] px-2 py-0.5 rounded-full bg-white border border-slate-300 hover:border-primary">🔗 Dossier lié</button>
        <button type="button" data-tpl="⚖️ Litige / Avocat" class="sav-pinned-tpl text-[10px] px-2 py-0.5 rounded-full bg-white border border-slate-300 hover:border-primary">⚖️ Litige</button>
        <button type="button" data-tpl="💰 Geste commercial accordé : " class="sav-pinned-tpl text-[10px] px-2 py-0.5 rounded-full bg-white border border-slate-300 hover:border-primary">💰 Geste co.</button>
        <button type="button" data-tpl="🚚 Attente transporteur" class="sav-pinned-tpl text-[10px] px-2 py-0.5 rounded-full bg-white border border-slate-300 hover:border-primary">🚚 Transporteur</button>
      </div>
      <textarea id="sav-pinned-input" maxlength="500" rows="2" placeholder="Saisissez une note… (Entrée = épingler · Échap = annuler · #SAV-2025-0042 auto-lien · @prenom mention)" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-primary focus:ring-1 focus:ring-primary resize-none"></textarea>
      <div class="mt-2 flex flex-col sm:flex-row sm:items-center gap-2">
        <div class="flex gap-1" role="radiogroup" aria-label="Couleur">
          <button type="button" data-color="rose"    class="sav-pinned-color w-6 h-6 rounded-full border-2 border-transparent" style="background:#e11d48" title="Urgent"></button>
          <button type="button" data-color="amber"   class="sav-pinned-color w-6 h-6 rounded-full border-2 border-transparent" style="background:#f59e0b" title="Attention"></button>
          <button type="button" data-color="blue"    class="sav-pinned-color w-6 h-6 rounded-full border-2 border-transparent" style="background:#2563eb" title="Info"></button>
          <button type="button" data-color="emerald" class="sav-pinned-color w-6 h-6 rounded-full border-2 border-transparent" style="background:#059669" title="OK"></button>
          <button type="button" data-color="slate"   class="sav-pinned-color w-6 h-6 rounded-full border-2 border-transparent" style="background:#64748b" title="Neutre"></button>
        </div>
        <label class="inline-flex items-center gap-1 text-[11px] text-slate-600">
          <span class="material-symbols-outlined" style="font-size:14px;">event</span>
          Expire le
          <input type="date" id="sav-pinned-expires" class="rounded border border-slate-300 px-1.5 py-0.5 text-[11px]" />
        </label>
        <div class="flex-1"></div>
        <span class="text-[10px] text-slate-400"><kbd class="px-1 bg-white border border-slate-300 rounded text-[9px]">Entrée</kbd> épingler</span>
        <button type="button" id="sav-pinned-cancel" class="rounded-lg border border-slate-300 bg-white px-3 py-1 text-xs">Annuler</button>
        <button type="submit" id="sav-pinned-submit" class="rounded-lg bg-primary text-white px-3 py-1 text-xs font-semibold hover:bg-primary-dark">Épingler</button>
      </div>
    </form>

    <!-- Historique notes supprimées -->
    <div id="sav-pinned-history" class="hidden mt-2 rounded-lg border border-slate-200 bg-slate-50 p-3">
      <div class="flex items-center justify-between mb-1">
        <div class="text-[11px] font-semibold uppercase tracking-wide text-slate-500">Notes supprimées</div>
        <button type="button" id="sav-pinned-history-close" class="text-[11px] text-slate-500 hover:text-slate-700">Fermer</button>
      </div>
      <div id="sav-pinned-history-list" class="space-y-1 max-h-48 overflow-y-auto"></div>
    </div>
  </section>

  <!-- STEPPER CYCLE SAV -->
  <nav id="sav-stepper" class="sav-stepper" aria-label="Cycle de vie du ticket SAV"></nav>

  <div class="px-6 lg:px-10 py-6">
    <div id="sav-detail-error" class="hidden mt-2 mb-4 rounded-xl border border-red-200 bg-red-50 p-3 text-sm text-red-800"></div>

    <!-- LAYOUT 2 COLONNES -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

      <!-- COLONNE PRINCIPALE -->
      <div class="lg:col-span-2 space-y-4">

        <!-- Onglets -->
        <div class="rounded-2xl border border-slate-200 bg-white">
          <nav class="flex gap-1 px-3 pt-3 border-b border-slate-100 overflow-x-auto" role="tablist">
            <% const tabs = [
              ['apercu','Aperçu','dashboard'],
              ['historique','Historique','timeline'],
              ['documents','Documents','folder'],
              ['communications','Communications','forum'],
              ['diagnostic','Diagnostic banc','science'],
              ['fournisseur','Fournisseur','local_shipping'],
            ]; %>
            <% tabs.forEach(function(t, i){ %>
              <button type="button" role="tab"
                      id="tab-<%= t[0] %>"
                      data-tab="<%= t[0] %>"
                      aria-controls="panel-<%= t[0] %>"
                      aria-selected="<%= i === 0 ? 'true' : 'false' %>"
                      tabindex="<%= i === 0 ? '0' : '-1' %>"
                      class="sav-tab <%= i === 0 ? 'is-active' : '' %>">
                <span class="material-symbols-outlined text-base"><%= t[2] %></span>
                <span class="sav-tab__label"><%= t[1] %></span>
                <span class="sav-tab__count hidden" data-tab-count="<%= t[0] %>"></span>
                <span class="sav-tab__dot hidden bg-red-500 w-2 h-2 rounded-full" data-tab-dot="<%= t[0] %>" aria-hidden="true"></span>
              </button>
            <% }); %>
          </nav>

          <!-- Tab Aperçu (dossier) -->
          <section class="sav-tabpanel p-5" data-tab-panel="apercu" id="panel-apercu" role="tabpanel" aria-labelledby="tab-apercu" tabindex="0">
            <!-- Mini KPIs -->
            <div id="sav-apercu-kpis" class="grid grid-cols-3 gap-3 mb-4">
              <div class="rounded-xl border border-slate-200 bg-white p-3 text-center">
                <div class="text-2xl font-bold text-slate-900" data-kpi="duree">—</div>
                <div class="text-xs text-slate-500 mt-0.5">Jours ouvrés</div>
              </div>
              <div class="rounded-xl border border-slate-200 bg-white p-3 text-center">
                <div class="text-2xl font-bold text-slate-900" data-kpi="messages">—</div>
                <div class="text-xs text-slate-500 mt-0.5">Messages</div>
              </div>
              <div class="rounded-xl border border-slate-200 bg-white p-3 text-center">
                <div class="text-2xl font-bold text-slate-900" data-kpi="relances">—</div>
                <div class="text-xs text-slate-500 mt-0.5">Relances client</div>
              </div>
            </div>

            <!-- Objectifs SLA (jalons métier) -->
            <div class="mb-4">
              <div class="flex items-center gap-2 mb-2">
                <span class="material-symbols-outlined text-slate-500 text-base">flag</span>
                <h3 class="text-sm font-semibold text-slate-700">Objectifs SLA</h3>
                <span class="text-[11px] text-slate-400">· basé sur la date d'ouverture, jours ouvrés</span>
              </div>
              <div id="sav-sla-objectives" class="grid grid-cols-1 sm:grid-cols-3 gap-3"></div>
            </div>

            <!-- 4 cards résumé -->
            <div id="sav-dossier" class="grid grid-cols-1 sm:grid-cols-2 gap-4" aria-busy="true">
              <% for (var _si = 0; _si < 4; _si++) { %>
              <div class="sav-skeleton-card">
                <div class="flex items-center gap-2 mb-3">
                  <span class="sav-skeleton sav-skeleton--circle" style="width:18px;height:18px;"></span>
                  <span class="sav-skeleton sav-skeleton--title" style="width:40%;"></span>
                </div>
                <span class="sav-skeleton sav-skeleton--line" style="width:85%;"></span>
                <span class="sav-skeleton sav-skeleton--line" style="width:70%;"></span>
                <span class="sav-skeleton sav-skeleton--line" style="width:55%;"></span>
              </div>
              <% } %>
            </div>
          </section>

          <!-- Tab Historique -->
          <section class="sav-tabpanel hidden p-5" data-tab-panel="historique" id="panel-historique" role="tabpanel" aria-labelledby="tab-historique" tabindex="0">
            <div id="sav-timeline-filters" class="flex flex-wrap gap-2 mb-4">
              <% const _flt = [
                ['all','Tous'],['message','Messages'],['statut','Statuts'],
                ['systeme','Système'],['fournisseur','Fournisseur'],['diagnostic','Diagnostic']
              ]; %>
              <% _flt.forEach(function(f){ %>
                <button type="button" data-tl-filter="<%= f[0] %>"
                  class="sav-tl-chip<%= f[0]==='all' ? ' is-active' : '' %>"><%= f[1] %></button>
              <% }); %>
            </div>
            <div class="sav-timeline" id="sav-timeline" aria-busy="true">
              <% for (var _ti = 0; _ti < 5; _ti++) { %>
              <div class="flex items-start gap-3 mb-4">
                <span class="sav-skeleton sav-skeleton--circle shrink-0" style="width:32px;height:32px;"></span>
                <div class="flex-1 space-y-2">
                  <span class="sav-skeleton sav-skeleton--line" style="width:30%;"></span>
                  <span class="sav-skeleton sav-skeleton--line" style="width:85%;"></span>
                  <span class="sav-skeleton sav-skeleton--line" style="width:60%;"></span>
                </div>
              </div>
              <% } %>
            </div>
          </section>

          <!-- Tab Documents -->
          <section class="sav-tabpanel hidden p-5" data-tab-panel="documents" id="panel-documents" role="tabpanel" aria-labelledby="tab-documents" tabindex="0">
            <div id="sav-documents" class="grid grid-cols-2 sm:grid-cols-3 gap-3" aria-busy="true">
              <% for (var _di = 0; _di < 6; _di++) { %>
              <span class="sav-skeleton sav-skeleton--thumb"></span>
              <% } %>
            </div>
          </section>

          <!-- Tab Communications (avec WYSIWYG vanilla + templates + variables) -->
          <section class="sav-tabpanel hidden p-5" data-tab-panel="communications" id="panel-communications" role="tabpanel" aria-labelledby="tab-communications" tabindex="0">
            <div id="sav-messages" class="space-y-3 mb-4 max-h-[600px] overflow-y-auto pr-1"></div>

            <form id="sav-msg-form" class="space-y-3">
              <!-- Pill toggle canaux -->
              <div id="sav-canal-pills" class="flex flex-wrap gap-2" role="radiogroup" aria-label="Canal">
                <button type="button" data-canal="email" class="sav-canal-pill sav-canal-pill--email is-active" role="radio" aria-checked="true">
                  <span class="material-symbols-outlined" style="font-size:16px;">mail</span><span>Email</span>
                </button>
                <button type="button" data-canal="interne" class="sav-canal-pill sav-canal-pill--interne" role="radio" aria-checked="false">
                  <span class="material-symbols-outlined" style="font-size:16px;">lock</span><span>Note interne</span>
                </button>
              </div>
              <input type="hidden" name="canal" id="sav-canal-input" value="email">

              <!-- Templates en chips + bouton favori -->
              <div class="flex items-center justify-between gap-2 flex-wrap mt-2">
                <span class="text-[10px] uppercase tracking-wide font-bold text-slate-400">Modèles de réponse</span>
                <button type="button" id="sav-save-favorite" class="text-xs inline-flex items-center gap-1 text-slate-500 hover:text-primary"
                  title="Sauver le message courant comme favori personnel">
                  <span class="material-symbols-outlined" style="font-size:14px;" aria-hidden="true">star</span>
                  Sauver comme favori
                </button>
              </div>
              <div id="sav-templates-chips" class="flex flex-wrap gap-2">
                <% const _tpls = [
                  ['reception','Pièce reçue à l\'atelier','inventory'],
                  ['analyse_ok','Défaut produit confirmé','verified'],
                  ['analyse_neg','Pas de défaut (149€)','euro'],
                  ['relance_doc','Relance documents','description'],
                  ['rdv','Proposition de RDV','event'],
                ]; %>
                <% _tpls.forEach(function(t){ %>
                  <button type="button" data-template="<%= t[0] %>" title="<%= t[1] %>" class="sav-tpl-chip">
                    <span class="material-symbols-outlined" style="font-size:14px;"><%= t[2] %></span>
                    <span><%= t[1] %></span>
                  </button>
                <% }); %>
              </div>
              <select id="sav-template" class="hidden">
                <option value=""></option>
                <option value="reception"></option>
                <option value="analyse_ok"></option>
                <option value="analyse_neg"></option>
                <option value="relance_doc"></option>
                <option value="rdv"></option>
              </select>

              <input type="text" name="sujet" placeholder="Sujet (email)" class="w-full rounded-xl border border-slate-300 px-3 py-2 text-sm">

              <!-- Mini WYSIWYG -->
              <div class="rounded-xl border border-slate-300">
                <div class="flex items-center gap-1 border-b border-slate-200 px-2 py-1 bg-slate-50 text-xs">
                  <button type="button" data-cmd="bold" class="px-2 py-1 hover:bg-white rounded font-bold">B</button>
                  <button type="button" data-cmd="italic" class="px-2 py-1 hover:bg-white rounded italic">I</button>
                  <button type="button" data-cmd="insertUnorderedList" class="px-2 py-1 hover:bg-white rounded">• Liste</button>
                  <button type="button" data-cmd="insertOrderedList" class="px-2 py-1 hover:bg-white rounded">1. Num</button>
                  <button type="button" data-cmd-link class="px-2 py-1 hover:bg-white rounded">🔗 Lien</button>
                  <span class="ml-auto text-slate-400 text-[10px]">Variables : {client_prenom} {ticket_numero} {piece_type} {garage_nom}</span>
                </div>
                <div id="sav-msg-editor" contenteditable="true" class="min-h-[120px] px-3 py-2 text-sm focus:outline-none" data-placeholder="Tapez votre message…"></div>
                <input type="hidden" name="contenu" id="sav-msg-contenu">
                <input type="hidden" name="html" id="sav-msg-html">
              </div>

              <!-- Aperçu email type Gmail -->
              <details class="rounded-xl border border-slate-300 bg-white" open>
                <summary class="cursor-pointer list-none px-3 py-2 text-xs font-semibold text-slate-600 flex items-center gap-1.5 select-none border-b border-slate-200">
                  <span class="material-symbols-outlined text-base" aria-hidden="true">visibility</span>
                  Aperçu de l'email final (variables remplacées)
                </summary>
                <div class="p-4 bg-slate-50">
                  <div class="bg-white rounded-lg border border-slate-200 shadow-sm overflow-hidden max-w-2xl mx-auto">
                    <div class="px-4 py-2 border-b border-slate-100 bg-slate-50 text-[11px] text-slate-600 space-y-0.5">
                      <div class="flex"><span class="font-semibold w-16">De :</span><span>SAV CarParts France &lt;sav@carpartsfrance.fr&gt;</span></div>
                      <div class="flex"><span class="font-semibold w-16">À :</span><span id="sav-preview-to">—</span></div>
                      <div class="flex"><span class="font-semibold w-16">Objet :</span><span id="sav-preview-subject" class="font-semibold text-slate-900">—</span></div>
                      <div class="flex"><span class="font-semibold w-16">Réf. :</span><span id="sav-preview-ref" class="font-mono text-[10px]">—</span></div>
                    </div>
                    <div class="p-4 text-sm text-slate-800">
                      <div id="sav-msg-preview"></div>
                      <hr class="my-4 border-slate-200">
                      <div class="text-xs text-slate-500 leading-relaxed">
                        <div class="font-semibold text-slate-700">L'équipe SAV CarParts France</div>
                        <div>sav@carpartsfrance.fr · 04 65 84 54 88</div>
                        <div><a href="https://www.carpartsfrance.fr" class="text-primary">www.carpartsfrance.fr</a></div>
                      </div>
                    </div>
                  </div>
                </div>
              </details>

              <!-- Pièces jointes -->
              <div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2">
                <div class="flex items-center justify-between gap-2 flex-wrap">
                  <div class="flex items-center gap-2">
                    <button type="button" id="sav-attach-btn" class="text-xs inline-flex items-center gap-1 px-2 py-1 rounded-lg border border-slate-300 bg-white hover:bg-slate-100">
                      <span class="material-symbols-outlined" style="font-size:14px;">attach_file</span>
                      Joindre un fichier
                    </button>
                    <button type="button" id="sav-return-label-btn" class="text-xs inline-flex items-center gap-1 px-2 py-1 rounded-lg border border-amber-300 bg-amber-50 text-amber-800 hover:bg-amber-100">
