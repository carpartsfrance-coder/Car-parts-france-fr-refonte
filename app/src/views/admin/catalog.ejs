<%- include('./partials/head') %>

<%- include('./partials/sidebar', { active: 'catalog' }) %>

<main class="flex-1 relative">
  <%- include('./partials/skeleton-table') %>
  <% const batchAiProfiles = typeof aiBatchProfiles !== 'undefined' && Array.isArray(aiBatchProfiles) && aiBatchProfiles.length ? aiBatchProfiles : [
    { key: 'batch_fast', label: 'Rapide', description: 'Priorité à la vitesse et au coût.', defaultModel: 'gpt-4.1' },
    { key: 'batch_balanced', label: 'Avancé', description: 'Qualité renforcée avec gpt-5.4 pour les lots.', defaultModel: 'gpt-5.4' },
    { key: 'batch_quality', label: 'Qualité', description: 'Meilleur équilibre pour les lots.', defaultModel: 'gpt-4.1' },
  ]; %>
  <% const defaultBatchAiProfileKey = typeof defaultAiBatchProfileKey !== 'undefined' && defaultAiBatchProfileKey ? defaultAiBatchProfileKey : 'batch_quality'; %>
  <% const maxBatchDraftSelection = typeof batchDraftMax !== 'undefined' && batchDraftMax ? batchDraftMax : 50; %>
  <div class="px-6 lg:px-10 py-8">
    <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">
      <div>
        <%- include('./partials/breadcrumb', { breadcrumbs: [{label: 'Produits'}] }) %>
        <div class="text-2xl md:text-3xl font-semibold text-slate-900">Catalogue</div>
        <div class="mt-1 text-sm text-slate-500">Produits, prix et stock.</div>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <a class="btn btn-secondary" href="/admin/catalogue/options">
          <span class="material-symbols-outlined mr-2 text-base">tune</span>
          Options produit
        </a>
        <a class="btn btn-primary" href="/admin/catalogue/nouveau">
          <span class="material-symbols-outlined mr-2 text-base">add</span>
          Nouveau produit
        </a>
      </div>
    </div>

    <form action="/admin/catalogue" class="sticky top-0 z-30 mt-6 bg-white/98 backdrop-blur rounded-2xl border border-slate-200 p-4 shadow-lg shadow-slate-200/70" method="GET">
      <div class="flex flex-col xl:flex-row xl:items-center gap-4">
        <div class="flex-1">
          <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">search</span>
            <input class="w-full rounded-2xl border border-slate-200 bg-white pl-10 pr-4 py-3 text-sm font-semibold text-slate-900 placeholder:text-slate-400" name="q" placeholder="Rechercher: nom, SKU, marque, catégorie..." type="text" value="<%= filters && filters.q ? filters.q : '' %>" />
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-3 flex-wrap">
          <% const currentCat = filters && filters.cat ? filters.cat : ''; %>
          <select class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-bold text-slate-900" name="cat">
            <option value="">Toutes les catégories</option>
            <% if (typeof categoryOptions !== 'undefined' && categoryOptions && categoryOptions.length) { %>
              <% categoryOptions.forEach((opt) => { %>
                <option value="<%= opt.value %>" <%= currentCat === opt.value ? 'selected' : '' %>><%= opt.label %></option>
              <% }) %>
            <% } %>
          </select>

          <select class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-bold text-slate-900" name="stock">
            <option value="">Tous les stocks</option>
            <option value="in" <%= filters && filters.stock === 'in' ? 'selected' : '' %>>En stock</option>
            <option value="out" <%= filters && filters.stock === 'out' ? 'selected' : '' %>>Stock limité</option>
          </select>

          <% const currentSort = filters && filters.sort ? filters.sort : 'updated_desc'; %>
          <select class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-bold text-slate-900" name="sort">
            <option value="updated_desc" <%= currentSort === 'updated_desc' ? 'selected' : '' %>>Plus récents d'abord</option>
            <option value="updated_asc" <%= currentSort === 'updated_asc' ? 'selected' : '' %>>Plus anciens d'abord</option>
            <option value="category_asc" <%= currentSort === 'category_asc' ? 'selected' : '' %>>Catégorie A → Z</option>
            <option value="category_desc" <%= currentSort === 'category_desc' ? 'selected' : '' %>>Catégorie Z → A</option>
            <option value="seo_desc" <%= currentSort === 'seo_desc' ? 'selected' : '' %>>Score SEO décroissant</option>
            <option value="seo_asc" <%= currentSort === 'seo_asc' ? 'selected' : '' %>>Score SEO croissant</option>
          </select>

          <select class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-bold text-slate-900" name="limit">
            <% const perPage = pagination && pagination.perPage ? pagination.perPage : 20; %>
            <option value="20" <%= perPage === 20 ? 'selected' : '' %>>20 / page</option>
            <option value="50" <%= perPage === 50 ? 'selected' : '' %>>50 / page</option>
            <option value="100" <%= perPage === 100 ? 'selected' : '' %>>100 / page</option>
            <option value="200" <%= perPage === 200 ? 'selected' : '' %>>200 / page</option>
          </select>

          <button class="btn btn-secondary" type="submit">
            Filtrer
          </button>
        </div>
      </div>
    </form>

    <% if (successMessage) { %>
      <div class="mt-6 rounded-xl border border-green-200 bg-green-50 p-4 text-green-900">
        <div class="font-bold"><%= successMessage %></div>
      </div>
    <% } %>

    <% if (errorMessage) { %>
      <div class="mt-6 rounded-xl border border-amber-200 bg-amber-50 p-4 text-amber-900">
        <div class="font-bold"><%= errorMessage %></div>
      </div>
    <% } %>

    <div class="mt-8 bg-white rounded-2xl border border-slate-200 overflow-hidden">
      <div class="px-6 py-4 bg-slate-50 flex items-center justify-between">
        <div class="font-semibold text-slate-900">Produits</div>
        <% if (pagination && typeof pagination.totalItems !== 'undefined' && pagination.totalItems > 0) { %>
          <div class="text-xs font-bold text-slate-500">
            <%= pagination.totalItems %> produit<%= pagination.totalItems > 1 ? 's' : '' %>
          </div>
        <% } %>
      </div>

      <% if (products && products.length) { %>
      <%
        const currentPage = pagination && pagination.page ? pagination.page : 1;
        const currentLimit = pagination && pagination.perPage ? pagination.perPage : 20;
        const currentQ = filters && filters.q ? filters.q : '';
        const currentStock = filters && filters.stock ? filters.stock : '';
        const currentSort = filters && filters.sort ? filters.sort : '';
        const queryParts = [];
        if (currentQ) queryParts.push('q=' + encodeURIComponent(currentQ));
        if (currentStock) queryParts.push('stock=' + encodeURIComponent(currentStock));
        if (currentSort) queryParts.push('sort=' + encodeURIComponent(currentSort));
        if (currentLimit) queryParts.push('limit=' + encodeURIComponent(String(currentLimit)));
        const baseQuery = queryParts.length ? ('?' + queryParts.join('&')) : '';
        const urlForPage = (p) => {
          const parts = queryParts.slice();
          parts.push('page=' + encodeURIComponent(String(p)));
          return '/admin/catalogue?' + parts.join('&');
        };
        function buildCatalogPageItems(currentPage, totalPages) {
          if (totalPages <= 7) {
            const r = [];
            for (let i = 1; i <= totalPages; i++) r.push({ type: 'page', page: i });
            return r;
          }
          const lo = Math.max(2, currentPage - 1);
          const hi = Math.min(totalPages - 1, currentPage + 1);
          const r = [{ type: 'page', page: 1 }];
          if (lo > 2) r.push({ type: 'ellipsis' });
          for (let pp = lo; pp <= hi; pp++) r.push({ type: 'page', page: pp });
          if (hi < totalPages - 1) r.push({ type: 'ellipsis' });
          r.push({ type: 'page', page: totalPages });
          return r;
        }
        const cPageItems = buildCatalogPageItems(pagination.page, pagination.totalPages);
        const cPageUrls = {};
        cPageItems.forEach(function(i) { if (i.type === 'page') cPageUrls[i.page] = urlForPage(i.page); });
        const cTotalLabel = pagination.totalItems + ' produit' + (pagination.totalItems > 1 ? 's' : '');
        const catalogPb = {
          pagination: pagination,
          totalLabel: cTotalLabel,
          pageItems: cPageItems,
          pageUrls: cPageUrls,
          prevUrl: urlForPage(pagination.prevPage),
          nextUrl: urlForPage(pagination.nextPage),
        };
        const getDraftBadge = (draft) => {
          if (!draft || !draft.status) return null;
          if (draft.status === 'completed') return { label: 'Brouillon IA prêt', className: 'bg-emerald-50 text-emerald-700' };
          if (draft.status === 'processing') return { label: 'IA en cours', className: 'bg-violet-50 text-violet-700' };
          if (draft.status === 'queued') return { label: 'IA en file', className: 'bg-sky-50 text-sky-700' };
          if (draft.status === 'canceled') return { label: 'IA arrêtée', className: 'bg-slate-100 text-slate-500' };
          if (draft.status === 'failed') return { label: 'IA en erreur', className: 'bg-red-50 text-red-700' };
          return { label: 'IA', className: 'bg-slate-100 text-slate-500' };
        };
      %>

        <form id="bulkForm" action="/admin/catalogue/supprimer-multi" method="POST" data-ajax="true">
          <input type="hidden" name="returnTo" value="<%= urlForPage(currentPage) %>" />

          <div class="px-6 py-4 bg-white border-b border-slate-100 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
            <div class="flex flex-col gap-3">
              <div class="flex flex-wrap items-center gap-3">
                <button id="bulkGenerateBtn" class="btn btn-primary" type="submit" formaction="/admin/catalogue/generer-ia-multi" formmethod="POST" disabled>
                  <span class="material-symbols-outlined mr-2 text-base">auto_awesome</span>
                  Générer IA la sélection
                </button>
                <% const activeJobsCount = typeof activeAiDraftJobsCount === 'number' ? activeAiDraftJobsCount : 0; %>
                <button id="cancelAllAiBtn" class="inline-flex items-center justify-center rounded-xl border border-amber-200 bg-amber-50 px-4 py-2 text-xs font-semibold uppercase tracking-wider text-amber-900 hover:bg-amber-100 transition disabled:opacity-50" type="submit" formaction="/admin/api/products/generate-draft/cancel-all" formmethod="POST" <%= activeJobsCount > 0 ? '' : 'disabled' %>>
                  <span class="material-symbols-outlined mr-2 text-base">stop_circle</span>
                  Arrêter toute l’IA<%= activeJobsCount > 0 ? ' (' + activeJobsCount + ')' : '' %>
                </button>
                <button id="bulkDeleteBtn" class="btn btn-secondary disabled:opacity-50" type="submit" disabled>
                  <span class="material-symbols-outlined mr-2 text-base">delete</span>
                  Supprimer la sélection
                </button>
                <div id="selectedCount" class="text-xs font-bold text-slate-500">0 sélectionné</div>
              </div>
              <div>
                <div class="grid gap-3 lg:grid-cols-[280px_minmax(0,1fr)] lg:items-start">
                  <div>
                    <label class="block text-[11px] font-semibold uppercase tracking-widest text-violet-700" for="bulkAiProfile">Mode IA du lot</label>
                    <select class="mt-2 w-full rounded-xl border border-violet-200 bg-violet-50/60 px-4 py-3 text-sm font-bold text-slate-900" id="bulkAiProfile" name="aiProfile">
                      <% batchAiProfiles.forEach((profile) => { %>
                        <option value="<%= profile.key %>" <%= profile.key === defaultBatchAiProfileKey ? 'selected' : '' %>><%= profile.label %> — <%= profile.defaultModel %></option>
                      <% }) %>
                    </select>
                    <div class="mt-2 text-[11px] font-bold text-slate-500">Rapide = plus rapide. Avancé = gpt-5.4 avec une qualité proche du mode individuel avancé. Qualité = équilibré pour de gros lots.</div>
                  </div>
                  <div>
                    <label class="block text-[11px] font-semibold uppercase tracking-widest text-violet-700" for="bulkAiSourceNotes">Notes pour l’IA (optionnel)</label>
                    <textarea class="mt-2 min-h-[84px] w-full rounded-xl border border-violet-200 bg-violet-50/60 px-4 py-3 text-sm text-slate-500" id="bulkAiSourceNotes" name="bulkAiSourceNotes" placeholder="Ex : style rassurant, priorité SEO, éviter les affirmations non vérifiées, viser les références d’origine."></textarea>
                  </div>
                </div>
                <div class="mt-2 text-[11px] font-bold text-slate-500">Jusqu’à <%= maxBatchDraftSelection %> produits à la fois. La génération part en arrière-plan et vous pourrez relire chaque brouillon dans la fiche produit.</div>
              </div>
            </div>
            <% if (pagination.totalPages > 1) { %>
            <div>
              <%- include('./partials/pagination', { pb: catalogPb }) %>
            </div>
            <% } %>
          </div>

          <%
            const cSortKey = filters.sort || 'updated_desc';
            const cSortParts = cSortKey.split('_');
            const cSortDir = cSortParts[cSortParts.length - 1];
            const cSortField = cSortParts.slice(0, -1).join('_');
            function cSortUrl(field) {
              const nextDir = (cSortField === field && cSortDir === 'asc') ? 'desc' : 'asc';
              const p = [];
              if (filters.q) p.push('q=' + encodeURIComponent(filters.q));
              if (filters.stock) p.push('stock=' + encodeURIComponent(filters.stock));
              p.push('sort=' + field + '_' + nextDir);
              return '/admin/catalogue?' + p.join('&');
            }
            function cSortIcon(field) {
              if (cSortField !== field) return 'unfold_more';
              return cSortDir === 'asc' ? 'arrow_upward' : 'arrow_downward';
            }
          %>
          <div class="overflow-x-auto">
            <table class="w-full text-left admin-table">
            <thead>
              <tr class="text-xs font-semibold text-slate-400 uppercase tracking-widest bg-white">
                <th class="px-6 py-4">
                  <input id="selectAll" type="checkbox" class="h-4 w-4 rounded border-slate-300" />
                </th>
                <th class="px-6 py-4 th-sortable <%= cSortField === 'name' ? 'sort-active' : '' %>" style="min-width:300px;">
                  <a href="<%= cSortUrl('name') %>" style="color:inherit;text-decoration:none;display:inline-flex;align-items:center;gap:2px;">
                    Nom<span class="sort-icon material-symbols-outlined"><%= cSortIcon('name') %></span>
                  </a>
                </th>
                <th class="px-6 py-4" style="width:80px;">SKU</th>
                <th class="px-6 py-4">Marque</th>
                <th class="px-6 py-4">Catégorie</th>
                <th class="px-6 py-4 th-sortable <%= cSortField === 'seo' ? 'sort-active' : '' %>">
                  <a href="<%= cSortUrl('seo') %>" style="color:inherit;text-decoration:none;display:inline-flex;align-items:center;gap:2px;">
                    Score SEO<span class="sort-icon material-symbols-outlined"><%= cSortIcon('seo') %></span>
                  </a>
                </th>
                <th class="px-6 py-4 th-sortable <%= cSortField === 'price' ? 'sort-active' : '' %>">
                  <a href="<%= cSortUrl('price') %>" style="color:inherit;text-decoration:none;display:inline-flex;align-items:center;gap:2px;">
                    Prix<span class="sort-icon material-symbols-outlined"><%= cSortIcon('price') %></span>
                  </a>
                </th>
                <th class="px-6 py-4" style="width:80px;">Qté</th>
                <th class="px-6 py-4 th-sortable <%= cSortField === 'stock' ? 'sort-active' : '' %>">
                  <a href="<%= cSortUrl('stock') %>" style="color:inherit;text-decoration:none;display:inline-flex;align-items:center;gap:2px;">
                    Stock<span class="sort-icon material-symbols-outlined"><%= cSortIcon('stock') %></span>
                  </a>
                </th>
                <th class="px-6 py-4 text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% products.forEach((p) => { %>
                <tr data-row-id="<%= p.id %>" class="hover:bg-gray-50 transition-colors duration-150">
                  <td class="px-6 py-4">
                    <input class="rowSelect h-4 w-4 rounded border-slate-300" type="checkbox" name="productIds" value="<%= p.id %>" />
                  </td>
                  <td class="px-6 py-4 font-semibold text-slate-900" style="min-width:300px;">
                    <div style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:400px;" title="<%= p.name %>"><%= p.name %></div>
                  </td>
                  <td class="px-6 py-4 text-sm text-slate-500" style="width:80px;"><%= p.sku || '—' %></td>
                  <td class="px-6 py-4 text-sm text-slate-500"><%= p.brand || '—' %></td>
                  <td class="px-6 py-4 text-sm text-slate-500"><%= p.category || '—' %></td>
                  <td class="px-6 py-4">
                    <% const score = Number.isFinite(p.seoScore) ? p.seoScore : 0; %>
                    <% const badgeClass = score >= 85 ? 'bg-green-50 text-green-700' : (score >= 65 ? 'bg-amber-50 text-amber-800' : 'bg-red-50 text-red-700'); %>
                    <span class="inline-flex items-center rounded-full px-3 py-1 text-[10px] font-semibold uppercase tracking-widest <%= badgeClass %>"><%= score %>/100</span>
                    <% const draftBadge = getDraftBadge(p.aiDraft); %>
                    <% if (draftBadge) { %>
                      <div class="mt-2">
                        <span class="inline-flex items-center rounded-full px-3 py-1 text-[10px] font-semibold uppercase tracking-widest <%= draftBadge.className %>"><%= draftBadge.label %></span>
                      </div>
                    <% } %>
                    <% if (p.aiDraft && p.aiDraft.createdAtLabel) { %>
                      <div class="mt-2 text-[11px] font-bold text-slate-500">Dernière demande : <%= p.aiDraft.createdAtLabel %></div>
                    <% } %>
                    <% if (p.aiDraft && (p.aiDraft.status === 'failed' || p.aiDraft.status === 'canceled') && p.aiDraft.errorMessage) { %>
                      <div class="mt-2 text-[11px] font-bold text-red-600"><%= p.aiDraft.errorMessage %></div>
                    <% } %>
                  </td>
                  <td class="px-6 py-4 font-semibold text-slate-900"><%= p.price %></td>
                  <td class="px-6 py-4 text-sm font-semibold text-slate-900" style="width:80px;"><%= p.stockQty !== null && typeof p.stockQty !== 'undefined' ? p.stockQty : '—' %></td>
                  <td class="px-6 py-4">
                    <% if (p.inStock === true) { %>
                      <span class="badge badge-success">En stock</span>
                    <% } else { %>
                      <span class="badge badge-warning">Stock limité</span>
                    <% } %>
                  </td>
                  <td class="px-6 py-4 text-right">
                    <div class="inline-flex items-center gap-2">
                      <% if (p.aiDraft && (p.aiDraft.status === 'queued' || p.aiDraft.status === 'processing')) { %>
                        <button
                          class="inline-flex items-center justify-center rounded-xl border border-amber-200 bg-amber-50 px-4 py-2 text-xs font-semibold uppercase tracking-wider text-amber-900 hover:bg-amber-100 transition"
                          type="submit"
                          formaction="/admin/api/products/generate-draft/<%= p.aiDraft.jobId %>/cancel"
                          formmethod="POST"
                          onclick="return confirm('Arrêter cette génération IA ?');"
                        >
                          <span class="material-symbols-outlined mr-2 text-base">stop_circle</span>
                          Arrêter l’IA
                        </button>
                      <% } %>
                      <a class="btn btn-ghost" href="/admin/catalogue/<%= p.id %>">
                        <span class="material-symbols-outlined mr-2 text-base">edit</span>
                        Modifier
                      </a>
                      <form data-ajax="true" data-confirm="Supprimer ce produit ?" action="/admin/catalogue/<%= p.id %>/supprimer" method="POST" class="inline">
                        <input type="hidden" name="returnTo" value="<%= urlForPage(currentPage) %>" />
                        <button
                          class="btn btn-danger"
                          type="submit"
                        >
                          <span class="material-symbols-outlined mr-2 text-base">delete</span>
                          Supprimer
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
            </table>
          </div>

          <% if (pagination && pagination.totalPages > 1) { %>
            <div class="border-t border-slate-100">
              <%- include('./partials/pagination', { pb: catalogPb }) %>
            </div>
          <% } %>

        </form>

        <script>
          (function () {
            var form = document.getElementById('bulkForm');
            var selectAll = document.getElementById('selectAll');
            var bulkBtn = document.getElementById('bulkDeleteBtn');
            var bulkGenerateBtn = document.getElementById('bulkGenerateBtn');
            var cancelAllAiBtn = document.getElementById('cancelAllAiBtn');
            var selectedCount = document.getElementById('selectedCount');
            var checkboxes = Array.prototype.slice.call(document.querySelectorAll('.rowSelect'));

            /* Confirm attributes on bulk buttons — handled by admin-ajax.js */
            if (bulkBtn) bulkBtn.setAttribute('data-confirm', 'Supprimer les produits sélectionnés ?');
            if (bulkGenerateBtn) bulkGenerateBtn.setAttribute('data-confirm', 'Lancer la génération IA pour les produits sélectionnés ?');
            if (cancelAllAiBtn) cancelAllAiBtn.setAttribute('data-confirm', 'Arrêter toutes les générations IA actives ?');

            function updateState() {
              var count = checkboxes.filter(function (c) { return c && c.checked; }).length;
              if (selectedCount) selectedCount.textContent = count + ' sélectionné' + (count > 1 ? 's' : '');
              if (bulkBtn) bulkBtn.disabled = count === 0;
              if (bulkGenerateBtn) bulkGenerateBtn.disabled = count === 0;
              if (selectAll) {
                selectAll.checked = count > 0 && count === checkboxes.length;
                selectAll.indeterminate = count > 0 && count < checkboxes.length;
              }
            }

            if (selectAll) {
              selectAll.addEventListener('change', function () {
                var isChecked = !!selectAll.checked;
                checkboxes.forEach(function (c) { c.checked = isChecked; });
                updateState();
              });
            }

            checkboxes.forEach(function (c) {
              c.addEventListener('change', updateState);
            });

            updateState();
          })();
        </script>
      <% } else { %>
        <div class="p-6 text-slate-500">Aucun produit.</div>
      <% } %>
    </div>

    <% if (!dbConnected) { %>
      <div class="mt-8 rounded-xl border border-amber-200 bg-amber-50 p-4 text-amber-900">
        <div class="font-bold">Mode démo</div>
        <div class="mt-1 text-sm">La base de données est indisponible : la liste du catalogue n’est pas disponible.</div>
      </div>
    <% } %>
  </div>
</main>

<script>
  (function () {
    function revealPage() {
      var sk = document.getElementById('page-skeleton');
      if (!sk) return;
      sk.classList.add('is-hidden');
      setTimeout(function () { sk.remove(); }, 200);
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', revealPage);
    } else {
      revealPage();
    }
  })();
</script>

<%- include('./partials/footer') %>
