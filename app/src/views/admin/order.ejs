<%- include('./partials/head') %>

<%- include('./partials/sidebar', { active: 'orders' }) %>

<main class="flex-1">
  <div class="px-6 lg:px-10 py-8">
    <div class="flex items-start justify-between gap-6">
      <div class="flex items-start gap-4">
        <a class="w-10 h-10 rounded-xl border border-slate-200 hover:bg-slate-50 transition flex items-center justify-center bg-white" href="/admin/commandes">
          <span class="material-symbols-outlined text-slate-500">arrow_back</span>
        </a>
        <div>
          <%- include('./partials/breadcrumb', { breadcrumbs: [{label: 'Commandes', url: '/admin/commandes'}, {label: order ? order.number : 'Commande'}] }) %>
          <div class="text-2xl md:text-3xl font-semibold text-slate-900"><%= order ? order.number : 'Commande' %></div>
          <div class="mt-1 text-sm text-slate-500"><%= order ? (order.dateTime || '') : '' %></div>
        </div>
      </div>

      <div class="flex items-center gap-3">
        <button class="btn btn-secondary" onclick="window.print()" type="button">
          <span class="material-symbols-outlined mr-2 text-base">print</span>
          Imprimer
        </button>

        <% if (order && order.id) { %>
          <form action="/admin/commandes/<%= order.id %>/retour" method="POST">
            <button class="btn btn-secondary" type="submit">
              <span class="material-symbols-outlined mr-2 text-base">assignment_return</span>
              Créer un retour
            </button>
          </form>
        <% } %>

        <% if (order && order.statusBadge) { %>
          <span class="<%= order.statusBadge.className %>"><%= order.statusBadge.label %></span>
        <% } %>
      </div>
    </div>

    <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
      <div class="mt-6 rounded-xl border border-red-200 bg-red-50 p-4 text-red-900">
        <div class="font-bold">Erreur</div>
        <div class="mt-1 text-sm"><%= errorMessage %></div>
      </div>
    <% } %>

    <% if (typeof successMessage !== 'undefined' && successMessage) { %>
      <div class="mt-6 rounded-xl border border-green-200 bg-green-50 p-4 text-green-900">
        <div class="font-bold">OK</div>
        <div class="mt-1 text-sm"><%= successMessage %></div>
      </div>
    <% } %>

    <% if (!order) { %>
      <div class="mt-8 bg-white rounded-2xl border border-slate-200 p-6">
        <div class="text-slate-500">Aucune donnée de commande à afficher.</div>
      </div>
    <% } else { %>
      <div class="mt-8 grid grid-cols-1 xl:grid-cols-12 gap-6">
        <section class="xl:col-span-8 space-y-6">
          <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
            <div class="px-6 py-4 bg-slate-50 flex items-center justify-between">
              <div class="font-semibold text-slate-900">Informations</div>
            </div>

            <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <div class="text-[10px] font-semibold uppercase tracking-widest text-slate-400">Client</div>
                <div class="mt-2 font-semibold text-slate-900"><%= order.customer %></div>
                <% if (order.customerEmail) { %>
                  <div class="mt-1 text-sm text-slate-500"><%= order.customerEmail %></div>
                <% } %>
                <div class="mt-2">
                  <span class="badge <%= order.accountType === 'pro' ? 'badge-pro' : 'badge-particulier' %>">
                    <%= order.accountType === 'pro' ? 'PRO' : 'PARTICULIER' %>
                  </span>
                </div>

                <% if (order.vehicle && (order.vehicle.plate || order.vehicle.vin)) { %>
                  <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-4">
                    <div class="text-[10px] font-semibold uppercase tracking-widest text-slate-400">Véhicule</div>
                    <% if (order.vehicle.plate) { %>
                      <div class="mt-2 text-sm text-slate-500">Plaque : <span class="font-semibold text-slate-900"><%= order.vehicle.plate %></span></div>
                    <% } %>
                    <% if (order.vehicle.vin) { %>
                      <div class="mt-1 text-sm text-slate-500">VIN : <span class="font-semibold text-slate-900"><%= order.vehicle.vin %></span></div>
                    <% } %>
                    <% if (order.vehicle.consentAt) { %>
                      <div class="mt-2 text-xs text-slate-500">Accord donné le : <span class="font-semibold text-slate-500"><%= order.vehicle.consentAt %></span></div>
                    <% } %>
                  </div>
                <% } %>

                <% if (order.legal && (order.legal.cgvAcceptedAt || order.legal.cgvUpdatedAt)) { %>
                  <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-4">
                    <div class="text-[10px] font-semibold uppercase tracking-widest text-slate-400">CGV</div>
                    <% if (order.legal.cgvAcceptedAt) { %>
                      <div class="mt-2 text-sm text-slate-500">Acceptées le : <span class="font-semibold text-slate-900"><%= order.legal.cgvAcceptedAt %></span></div>
                    <% } %>
                    <% if (order.legal.cgvUpdatedAt) { %>
                      <div class="mt-1 text-xs text-slate-500">Version (mise à jour) : <span class="font-semibold text-slate-500"><%= order.legal.cgvUpdatedAt %></span></div>
                    <% } %>
                  </div>
                <% } %>
              </div>

              <div>
                <div class="text-[10px] font-semibold uppercase tracking-widest text-slate-400">Statut</div>
                <form action="/admin/commandes/<%= order.id %>/statut" class="mt-3 flex flex-col sm:flex-row gap-3" method="POST" data-ajax="true">
                  <select class="flex-1 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-bold text-slate-900" name="status">
                    <% (statusOptions || []).forEach((s) => { %>
                      <option value="<%= s.key %>" <%= s.key === order.statusKey ? 'selected' : '' %>><%= s.label %></option>
                    <% }) %>
                  </select>
                  <button class="rounded-xl bg-slate-800 text-white px-5 py-3 text-xs font-semibold uppercase tracking-wider hover:bg-slate-700 transition" type="submit">
                    Mettre à jour
                  </button>
                </form>
                <div class="mt-2 text-xs text-slate-500">Cette action change le statut visible côté client.</div>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-white rounded-2xl border border-slate-200 p-6">
              <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-slate-400">
                <span class="material-symbols-outlined text-base text-primary">local_shipping</span>
                Livraison
              </div>
              <% if (order.shippingAddress) { %>
                <div class="mt-4">
                  <% if (order.shippingAddress.fullName) { %><div class="text-sm font-semibold text-slate-900"><%= order.shippingAddress.fullName %></div><% } %>
                  <div class="mt-2 text-sm text-slate-500"><%= order.shippingAddress.line1 %></div>
                  <% if (order.shippingAddress.line2) { %><div class="text-sm text-slate-500"><%= order.shippingAddress.line2 %></div><% } %>
                  <div class="text-sm text-slate-500"><%= order.shippingAddress.postalCode %> <%= order.shippingAddress.city %></div>
                  <div class="text-sm text-slate-500"><%= order.shippingAddress.country %></div>
                  <% if (order.shippingAddress.phone) { %><div class="mt-1 text-xs text-slate-500">Téléphone : <%= order.shippingAddress.phone %></div><% } %>
                </div>
              <% } else { %>
                <div class="mt-4 text-sm text-slate-500">Non renseignée</div>
              <% } %>
            </div>

            <div class="bg-white rounded-2xl border border-slate-200 p-6">
              <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-slate-400">
                <span class="material-symbols-outlined text-base text-primary">receipt_long</span>
                Facturation
              </div>
              <% if (order.billingAddress) { %>
                <div class="mt-4">
                  <% if (order.billingAddress.fullName) { %><div class="text-sm font-semibold text-slate-900"><%= order.billingAddress.fullName %></div><% } %>
                  <div class="mt-2 text-sm text-slate-500"><%= order.billingAddress.line1 %></div>
                  <% if (order.billingAddress.line2) { %><div class="text-sm text-slate-500"><%= order.billingAddress.line2 %></div><% } %>
                  <div class="text-sm text-slate-500"><%= order.billingAddress.postalCode %> <%= order.billingAddress.city %></div>
                  <div class="text-sm text-slate-500"><%= order.billingAddress.country %></div>
                  <% if (order.billingAddress.phone) { %><div class="mt-1 text-xs text-slate-500">Téléphone : <%= order.billingAddress.phone %></div><% } %>
                </div>
              <% } else { %>
                <div class="mt-4 text-sm text-slate-500">Non renseignée</div>
              <% } %>
            </div>
          </div>

          <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
            <div class="px-6 py-4 bg-slate-50 flex items-center justify-between">
              <div class="font-semibold text-slate-900">Articles (<%= order.items ? order.items.length : 0 %>)</div>
            </div>

            <% if (order.items && order.items.length) { %>
              <div class="p-6 space-y-4">
                <% order.items.forEach((it) => { %>
                  <div class="rounded-2xl border border-slate-200 bg-white p-4 flex items-center gap-4">
                    <div class="w-16 h-16 rounded-2xl bg-slate-50 overflow-hidden flex items-center justify-center flex-shrink-0">
                      <% if (it.imageUrl) { %>
                        <img alt="<%= it.name %>" class="w-full h-full object-cover" src="<%= it.imageUrl %>" />
                      <% } else { %>
                        <span class="material-symbols-outlined text-slate-400">inventory_2</span>
                      <% } %>
                    </div>

                    <div class="flex-1 min-w-0">
                      <div class="flex items-start justify-between gap-4">
                        <div class="min-w-0">
                          <div class="font-semibold text-slate-900 truncate"><%= it.name %></div>
                          <% if (it.sku) { %>
                            <div class="mt-1 text-xs text-slate-500">Réf : <%= it.sku %></div>
                          <% } %>
                          <% if (it.optionsSummary) { %>
                            <div class="mt-1 text-xs text-slate-500"><%= it.optionsSummary %></div>
                          <% } %>
                          <div class="mt-2 flex items-center gap-2">
                            <% if (it.inStock === true) { %>
                              <span class="badge badge-success">En stock</span>
                            <% } else if (it.inStock === false) { %>
                              <span class="badge badge-warning">Stock limité</span>
                            <% } %>
                            <span class="text-xs text-slate-500">Quantité : <span class="font-semibold text-slate-500"><%= it.quantity %></span></span>
                          </div>
                        </div>

                        <div class="text-right flex-shrink-0">
                          <div class="font-semibold text-slate-900"><%= it.lineTotal %></div>
                          <div class="mt-1 text-xs text-slate-500">PU : <%= it.unitPrice %></div>
                        </div>
                      </div>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <div class="p-6 text-slate-500">Aucun article.</div>
            <% } %>
          </div>

          <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
            <div class="px-6 py-4 bg-slate-50 flex items-center justify-between">
              <div class="font-semibold text-slate-900">Historique des statuts</div>
            </div>

            <% if (order.statusHistory && order.statusHistory.length) { %>
              <div class="p-6 space-y-4">
                <% order.statusHistory.forEach((h) => { %>
                  <div class="flex items-start gap-4">
                    <div class="mt-1 w-2.5 h-2.5 rounded-full bg-slate-300"></div>
                    <div class="flex-1">
                      <div class="flex flex-wrap items-center gap-3">
                        <span class="<%= h.statusBadge.className %>"><%= h.statusBadge.label %></span>
                        <div class="text-sm font-semibold text-slate-500"><%= h.changedAt %></div>
                      </div>
                      <div class="mt-1 text-xs text-slate-500">Par <span class="font-semibold text-slate-500"><%= h.changedBy %></span></div>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <div class="p-6 text-slate-500">Aucun historique.</div>
            <% } %>
          </div>
        </section>

        <aside class="xl:col-span-4 space-y-6">
          <div class="bg-white rounded-2xl border border-slate-200 p-6">
            <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-slate-400">
              <span class="material-symbols-outlined text-base text-primary">package_2</span>
              Suivis d’expédition
            </div>

            <% if (order.shipments && order.shipments.length) { %>
              <div class="mt-4 space-y-3">
                <% order.shipments.forEach((s) => { %>
                  <div class="rounded-xl border border-slate-200 p-4">
                    <div class="flex items-start justify-between gap-3">
                      <div class="min-w-0">
                        <div class="font-semibold text-slate-900 truncate"><%= s.label || 'Expédition' %></div>
                        <div class="mt-1 text-sm text-slate-500 break-words">
                          <span class="font-semibold">Suivi :</span>
                          <span class="font-mono"><%= s.trackingNumber %></span>
                        </div>
                        <% if (s.carrier) { %>
                          <div class="mt-1 text-xs text-slate-500">Transporteur : <span class="font-semibold text-slate-500"><%= s.carrier %></span></div>
                        <% } %>
                        <div class="mt-1 text-xs text-slate-500">Ajouté le <span class="font-semibold text-slate-500"><%= s.createdAt %></span><% if (s.createdBy) { %> par <span class="font-semibold text-slate-500"><%= s.createdBy %></span><% } %></div>
                        <% if (s.note) { %>
                          <div class="mt-2 text-xs text-slate-500"><%= s.note %></div>
                        <% } %>
                      </div>

                      <form action="/admin/commandes/<%= order.id %>/suivi/<%= s.id %>/supprimer" method="POST" data-ajax="true" data-confirm="Supprimer ce suivi ?">
                        <button class="btn btn-secondary" type="submit">
                          Supprimer
                        </button>
                      </form>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <div class="mt-4 text-sm text-slate-500">Aucun suivi pour le moment.</div>
            <% } %>

            <div class="mt-6 pt-6 border-t border-slate-200">
              <div class="text-[10px] font-semibold uppercase tracking-widest text-slate-400">Ajouter un suivi</div>

              <form action="/admin/commandes/<%= order.id %>/suivi" class="mt-4 space-y-3" method="POST">
                <div>
                  <label class="block text-xs font-semibold uppercase tracking-widest text-slate-400" for="shipmentLabel">Type</label>
                  <select class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-bold text-slate-900" id="shipmentLabel" name="label">
                    <option value="Envoi">Envoi</option>
                    <option value="Envoi partiel">Envoi partiel</option>
                    <option value="Renvoi SAV">Renvoi SAV</option>
                    <option value="Autre">Autre</option>
                  </select>
                </div>

                <div>
                  <label class="block text-xs font-semibold uppercase tracking-widest text-slate-400" for="trackingNumber">Numéro de suivi</label>
                  <input class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold" id="trackingNumber" name="trackingNumber" placeholder="Ex: 6A1234567890" type="text" />
                </div>

                <div>
                  <label class="block text-xs font-semibold uppercase tracking-widest text-slate-400" for="carrier">Transporteur (optionnel)</label>
                  <input class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold" id="carrier" name="carrier" placeholder="Ex: Colissimo, DHL…" type="text" />
                </div>

                <div>
                  <label class="block text-xs font-semibold uppercase tracking-widest text-slate-400" for="shipmentNote">Note (optionnel)</label>
                  <textarea class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold" id="shipmentNote" name="note" placeholder="Ex: 1ère partie expédiée, reste à envoyer" rows="3"></textarea>
                </div>

                <button class="w-full rounded-xl bg-slate-800 text-white px-5 py-3 text-xs font-semibold uppercase tracking-wider hover:bg-slate-700 transition" type="submit">
                  Ajouter le suivi
                </button>
              </form>
            </div>
          </div>

          <% if (order && order.consigne && order.consigne.hasConsigne) { %>
            <div class="bg-white rounded-2xl border border-slate-200 p-6">
              <div class="flex items-center justify-between gap-4">
                <div class="text-[10px] font-semibold uppercase tracking-widest text-slate-400">Consigne (ancienne pièce)</div>
                <% if (order.consigne.hasPending) { %>
                  <form action="/admin/commandes/<%= order.id %>/consigne/recu" method="POST" data-ajax="true">
                    <button class="btn btn-primary" type="submit">
                      Marquer reçu
                    </button>
                  </form>
                <% } %>
              </div>

              <div class="mt-4 space-y-3">
                <% (order.consigne.lines || []).forEach((l) => { %>
                  <div class="rounded-xl border border-slate-200 p-4">
                    <div class="flex items-start justify-between gap-4">
                      <div class="min-w-0">
                        <div class="font-semibold text-slate-900 truncate"><%= l.name %></div>
                        <% if (l.sku) { %><div class="mt-1 text-xs text-slate-500">Réf : <span class="font-semibold text-slate-500"><%= l.sku %></span></div><% } %>
                        <div class="mt-2 text-xs text-slate-500">
                          Quantité : <span class="font-semibold text-slate-500"><%= l.quantity %></span>
                          • Montant : <span class="font-semibold text-slate-500"><%= l.amount %></span>
                          • Total : <span class="font-semibold text-slate-500"><%= l.total %></span>
                        </div>
                        <% if (l.isReceived) { %>
                          <div class="mt-2 text-xs font-semibold uppercase tracking-widest text-green-700">Reçu</div>
                        <% } else if (l.isOverdue) { %>
                          <div class="mt-2 text-xs font-semibold uppercase tracking-widest text-red-700">En retard (garantie annulée)</div>
                        <% } else if (l.daysLeft !== null) { %>
                          <div class="mt-2 text-xs font-semibold uppercase tracking-widest text-amber-800">Jours restants : <%= l.daysLeft %></div>
                        <% } %>
                      </div>
                      <div class="text-right">
                        <% if (l.dueAt) { %><div class="text-xs text-slate-500">Échéance</div><div class="text-xs font-semibold text-slate-900"><%= l.dueAt %></div><% } %>
                      </div>
                    </div>
                  </div>
                <% }) %>
              </div>

              <% if (order.consigne.hasOverdue) { %>
                <div class="mt-4 rounded-xl border border-red-200 bg-red-50 p-4 text-red-900">
                  <div class="font-semibold">Consigne due : <%= order.consigne.totalDue %></div>
                  <div class="mt-1 text-xs">La garantie est annulée tant que l’ancienne pièce n’est pas reçue.</div>
                </div>
              <% } %>
            </div>
          <% } %>

          <div class="bg-white rounded-2xl border border-slate-200 p-6">
            <div class="text-[10px] font-semibold uppercase tracking-widest text-slate-400">Récapitulatif</div>

            <div class="mt-4 space-y-3 text-sm">
              <div class="flex items-center justify-between">
                <div class="text-slate-500">Sous-total articles</div>
                <div class="font-semibold text-slate-900"><%= order.itemsSubtotal %></div>
              </div>

              <% if (typeof order.clientDiscountCents !== 'undefined' && order.clientDiscountCents > 0) { %>
                <div class="flex items-center justify-between">
                  <div class="text-slate-500">Remise compte (<%= typeof order.clientDiscountPercent !== 'undefined' ? String(order.clientDiscountPercent).replace('.', ',') : '' %>%)</div>
                  <div class="font-semibold text-slate-900">- <%= (order.clientDiscountCents / 100).toFixed(2).replace('.', ',') %> €</div>
                </div>
              <% } %>

              <% if (typeof order.promoDiscountCents !== 'undefined' && order.promoDiscountCents > 0) { %>
                <div class="flex items-center justify-between">
                  <div class="text-slate-500">Code promo <%= order.promoCode ? '(' + order.promoCode + ')' : '' %></div>
                  <div class="font-semibold text-slate-900">- <%= (order.promoDiscountCents / 100).toFixed(2).replace('.', ',') %> €</div>
                </div>
              <% } %>

              <% if ((typeof order.clientDiscountCents !== 'undefined' && order.clientDiscountCents > 0) || (typeof order.promoDiscountCents !== 'undefined' && order.promoDiscountCents > 0)) { %>
                <div class="flex items-center justify-between">
                  <div class="text-slate-500">Sous-total après remise</div>
                  <div class="font-semibold text-slate-900"><%= typeof order.itemsTotalAfterDiscount !== 'undefined' ? order.itemsTotalAfterDiscount : order.itemsSubtotal %></div>
                </div>
              <% } %>

              <div class="flex items-center justify-between">
                <div class="text-slate-500">Livraison</div>
                <div class="font-semibold <%= order.shippingCostCents === 0 ? 'text-green-600' : 'text-slate-900' %>">
                  <%= order.shippingCostCents === 0 ? 'OFFERT' : order.shippingCost %>
                </div>
              </div>
              <div class="flex items-center justify-between">
                <div class="text-slate-500">HT</div>
                <div class="font-semibold text-slate-900"><%= order.ht %></div>
              </div>
              <div class="flex items-center justify-between">
                <div class="text-slate-500">TVA</div>
                <div class="font-semibold text-slate-900"><%= order.vat %></div>
              </div>
            </div>

            <div class="mt-6 pt-6 border-t border-slate-200 flex items-center justify-between">
              <div class="font-semibold text-slate-900">Total TTC</div>
              <div class="text-primary font-semibold text-2xl"><%= order.total %></div>
            </div>
          </div>

          <div class="bg-white rounded-2xl border border-slate-200 p-6">
            <div class="flex items-center justify-between gap-4">
              <div class="text-[10px] font-semibold uppercase tracking-widest text-slate-400">Emails</div>
              <div class="relative" id="send-email-dropdown">
                <button type="button" class="btn btn-secondary text-xs" id="send-email-btn">
                  <span class="material-symbols-outlined mr-1 text-base">send</span>
                  Envoyer
                  <span class="material-symbols-outlined ml-1 text-sm">expand_more</span>
                </button>
                <div id="send-email-menu" class="hidden absolute right-0 top-full mt-2 w-72 bg-white rounded-xl border border-slate-200 shadow-xl z-50 overflow-hidden">
                  <%
                    var emailTypes = [
                      { key: 'order_confirmation', label: 'Confirmation de commande', icon: 'receipt_long' },
                      { key: 'shipment_tracking', label: "Suivi d'expedition", icon: 'local_shipping' },
                      { key: 'delivery_confirmed', label: 'Livraison confirmee', icon: 'done_all' },
                      { key: 'status_change_validee', label: 'Statut : Validee', icon: 'check_circle' },
                      { key: 'consigne_start', label: 'Consigne : retour piece', icon: 'assignment_return' },
                      { key: 'consigne_received', label: 'Consigne recue', icon: 'inventory' },
                    ];
                  %>
                  <% emailTypes.forEach(function(et) { %>
                    <div class="flex items-center gap-1 border-b border-slate-100 last:border-0">
                      <button type="button" class="email-preview-btn flex-1 flex items-center gap-3 px-4 py-3 text-sm text-slate-700 hover:bg-slate-50 transition text-left" data-type="<%= et.key %>" title="Apercu">
                        <span class="material-symbols-outlined text-base text-slate-400"><%= et.icon %></span>
                        <span class="flex-1 truncate"><%= et.label %></span>
                        <span class="material-symbols-outlined text-base text-slate-300">visibility</span>
                      </button>
                      <form action="/admin/commandes/<%= order.id %>/email/resend" method="POST" class="flex-shrink-0 pr-2" onsubmit="return confirm('Envoyer cet email maintenant ?')">
                        <input type="hidden" name="type" value="<%= et.key %>" />
                        <button type="submit" class="w-8 h-8 rounded-lg hover:bg-primary/10 flex items-center justify-center transition" title="Envoyer">
                          <span class="material-symbols-outlined text-base text-primary">send</span>
                        </button>
                      </form>
                    </div>
                  <% }) %>
                </div>
              </div>
            </div>

            <% if (order.emailsSent && order.emailsSent.length) { %>
              <div class="mt-4 space-y-2">
                <% order.emailsSent.forEach(function(e) { %>
                  <div class="rounded-xl border border-slate-100 p-3 flex items-start gap-3">
                    <div class="mt-0.5 w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 <%= e.status === 'sent' ? 'bg-green-50 text-green-600' : 'bg-red-50 text-red-600' %>">
                      <span class="material-symbols-outlined text-[14px]"><%= e.status === 'sent' ? 'check' : 'close' %></span>
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="text-sm font-semibold text-slate-900"><%= e.typeLabel || e.type %></div>
                      <div class="text-xs text-slate-500"><%= e.sentAt %></div>
                      <% if (e.recipientEmail) { %>
                        <div class="text-xs text-slate-400"><%= e.recipientEmail %></div>
                      <% } %>
                      <% if (e.status === 'failed' && e.reason) { %>
                        <div class="text-xs text-red-500 mt-0.5">Erreur : <%= e.reason %></div>
                      <% } %>
                    </div>
                    <div class="flex items-center gap-1 flex-shrink-0">
                      <button type="button" class="email-preview-btn w-7 h-7 rounded-lg hover:bg-slate-100 flex items-center justify-center transition" data-type="<%= e.type %>" title="Apercu">
                        <span class="material-symbols-outlined text-base text-slate-400">visibility</span>
                      </button>
                      <form action="/admin/commandes/<%= order.id %>/email/resend" method="POST" class="inline" onsubmit="return confirm('Renvoyer cet email ?')">
                        <input type="hidden" name="type" value="<%= e.type %>" />
                        <button type="submit" class="w-7 h-7 rounded-lg hover:bg-primary/10 flex items-center justify-center transition" title="Renvoyer">
                          <span class="material-symbols-outlined text-base text-primary">replay</span>
                        </button>
                      </form>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <div class="mt-4 text-sm text-slate-500">Aucun email envoy&eacute; pour cette commande.</div>
            <% } %>
          </div>

          <div class="bg-white rounded-2xl border border-slate-200 p-6" data-notes-widget data-entity-type="order" data-entity-id="<%= order ? order.id : '' %>"></div>

          <% if (!dbConnected) { %>
            <div class="rounded-xl border border-amber-200 bg-amber-50 p-4 text-amber-900">
              <div class="font-bold">Mode d&eacute;mo</div>
              <div class="mt-1 text-sm">La base de donn&eacute;es est indisponible : impossible de modifier le statut.</div>
            </div>
          <% } %>
        </aside>
      </div>
    <% } %>
  </div>
</main>

<!-- Email preview modal -->
<div id="email-preview-modal" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/50" id="email-preview-overlay"></div>
  <div class="absolute inset-4 lg:inset-8 bg-white rounded-2xl shadow-2xl flex flex-col overflow-hidden">
    <div class="px-6 py-4 border-b border-slate-200 flex items-center justify-between flex-shrink-0">
      <div class="font-semibold text-slate-900" id="email-preview-title">Apercu email</div>
      <button type="button" id="email-preview-close" class="w-8 h-8 rounded-lg hover:bg-slate-100 flex items-center justify-center">
        <span class="material-symbols-outlined">close</span>
      </button>
    </div>
    <div class="flex-1 overflow-hidden">
      <iframe id="email-preview-iframe" class="w-full h-full border-0" sandbox="allow-same-origin"></iframe>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Dropdown toggle
  var dropBtn = document.getElementById('send-email-btn');
  var dropMenu = document.getElementById('send-email-menu');
  if (dropBtn && dropMenu) {
    dropBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      dropMenu.classList.toggle('hidden');
    });
    document.addEventListener('click', function() {
      dropMenu.classList.add('hidden');
    });
    dropMenu.addEventListener('click', function(e) {
      e.stopPropagation();
    });
  }

  // Email preview modal
  var modal = document.getElementById('email-preview-modal');
  var overlay = document.getElementById('email-preview-overlay');
  var closeBtn = document.getElementById('email-preview-close');
  var iframe = document.getElementById('email-preview-iframe');
  var titleEl = document.getElementById('email-preview-title');

  var typeLabels = {
    order_confirmation: 'Confirmation de commande',
    shipment_tracking: "Suivi d'expedition",
    delivery_confirmed: 'Livraison confirmee',
    status_change_validee: 'Statut : Validee',
    consigne_start: 'Consigne : retour piece',
    consigne_received: 'Consigne recue'
  };

  var orderId = '<%= order ? order.id : "" %>';

  document.querySelectorAll('.email-preview-btn').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      var emailType = this.dataset.type;
      if (!emailType || !orderId) return;

      if (dropMenu) dropMenu.classList.add('hidden');

      modal.classList.remove('hidden');
      titleEl.textContent = 'Apercu : ' + (typeLabels[emailType] || emailType);
      iframe.src = '';
      iframe.src = '/admin/commandes/' + orderId + '/email/preview/' + emailType;
    });
  });

  function closeModal() {
    modal.classList.add('hidden');
    iframe.src = '';
  }
  if (overlay) overlay.addEventListener('click', closeModal);
  if (closeBtn) closeBtn.addEventListener('click', closeModal);
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
  });
});
</script>

<%- include('./partials/footer') %>
