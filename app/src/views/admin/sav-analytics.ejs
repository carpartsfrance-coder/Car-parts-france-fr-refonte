<%- include('./partials/head') %>
<link rel="stylesheet" href="/css/sav.css?v=21">
<%- include('./partials/sidebar', { active: 'sav' }) %>

<main class="flex-1 sav-module" data-sav-token="<%= savApiToken %>">
  <div class="px-6 lg:px-10 py-8">

    <div class="flex items-start justify-between gap-4 mb-6">
      <div>
        <div class="text-2xl md:text-3xl font-semibold text-slate-900">Analytics SAV</div>
        <div class="mt-1 text-sm text-slate-500">Indicateurs détaillés et exports Excel</div>
      </div>
      <a id="sav-analytics-export" href="#" class="btn btn-primary">
        <span class="material-symbols-outlined mr-1 text-base">download</span>
        Export Excel (.csv)
      </a>
    </div>

    <div id="sav-analytics-error" class="hidden mb-4 rounded-xl border border-red-200 bg-red-50 p-3 text-sm text-red-800"></div>

    <!-- KPI top -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
      <div class="rounded-2xl border border-slate-200 bg-white p-4">
        <div class="text-xs uppercase text-slate-500">CA récupéré</div>
        <div class="mt-1 text-2xl font-bold text-emerald-700" id="ana-ca-recup">—</div>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-4">
        <div class="text-xs uppercase text-slate-500">Coût garantie</div>
        <div class="mt-1 text-2xl font-bold text-red-700" id="ana-cout-gar">—</div>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-4">
        <div class="text-xs uppercase text-slate-500">Balance SAV</div>
        <div class="mt-1 text-2xl font-bold text-slate-900" id="ana-balance">—</div>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-4">
        <div class="text-xs uppercase text-slate-500">Taux récidive</div>
        <div class="mt-1 text-2xl font-bold text-violet-700" id="ana-recidive">—</div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <section class="rounded-2xl border border-slate-200 bg-white p-5">
        <h2 class="text-sm font-semibold text-slate-700 mb-3">Nb SAV par mois (12 mois)</h2>
        <canvas id="ana-monthly" height="80"></canvas>
      </section>

      <section class="rounded-2xl border border-slate-200 bg-white p-5">
        <h2 class="text-sm font-semibold text-slate-700 mb-3">Top 5 pièces SAV</h2>
        <table class="w-full text-sm">
          <thead><tr class="text-xs text-slate-500"><th class="text-left py-1">Pièce</th><th class="text-right py-1">Tickets</th></tr></thead>
          <tbody id="ana-top-pieces"></tbody>
        </table>
      </section>

      <section class="rounded-2xl border border-slate-200 bg-white p-5">
        <h2 class="text-sm font-semibold text-slate-700 mb-3">Taux défaut produit par fournisseur</h2>
        <canvas id="ana-fournisseur" height="120"></canvas>
        <div id="ana-fournisseur-empty" class="hidden text-xs text-slate-400 text-center mt-3">Aucune donnée fournisseur disponible.</div>
      </section>

      <section class="rounded-2xl border border-slate-200 bg-white p-5">
        <h2 class="text-sm font-semibold text-slate-700 mb-3">Délai moyen de résolution par type</h2>
        <table class="w-full text-sm">
          <thead><tr class="text-xs text-slate-500"><th class="text-left py-1">Pièce</th><th class="text-right py-1">Délai (j)</th><th class="text-right py-1">Tickets</th></tr></thead>
          <tbody id="ana-avg-by-type"></tbody>
        </table>
      </section>

      <section class="rounded-2xl border border-slate-200 bg-white p-5 lg:col-span-2">
        <h2 class="text-sm font-semibold text-slate-700 mb-3">Répartition par département (top 30)</h2>
        <div id="ana-departments" class="grid grid-cols-3 sm:grid-cols-5 md:grid-cols-6 gap-2 text-xs"></div>
      </section>
    </div>
  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script src="/js/sav-admin.js?v=4" defer></script>
<%- include('./partials/footer') %>
