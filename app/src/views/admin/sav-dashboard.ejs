<%- include('./partials/head') %>
<link rel="stylesheet" href="/css/sav.css?v=21">
<%- include('./partials/sidebar', { active: 'sav' }) %>

<main class="flex-1 sav-module" data-sav-token="<%= savApiToken %>" data-current-user-id="<%= (typeof currentAdmin !== 'undefined' && currentAdmin && currentAdmin.adminUserId) || '' %>">
  <div class="px-6 lg:px-10 py-8">

    <div class="flex items-start justify-between gap-4 mb-6">
      <div>
        <div class="text-2xl md:text-3xl font-semibold text-slate-900">SAV — Tableau de bord</div>
        <div class="mt-1 text-sm text-slate-500">État en temps réel des dossiers SAV</div>
      </div>
      <div class="flex items-center gap-2">
        <a href="/admin/parametres/sav" class="btn btn-secondary">
          <span class="material-symbols-outlined mr-2 text-base">tune</span>
          Paramètres SAV
        </a>
        <a href="/admin/sav/tickets" class="btn btn-primary">
          <span class="material-symbols-outlined mr-2 text-base">list_alt</span>
          Voir tous les tickets
        </a>
      </div>
    </div>

    <!-- KPI cards (10 tuiles) -->
    <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-5 gap-4" id="sav-kpi-grid">
      <% const kpis = [
        { key:'ouverts',          label:'Ouverts',                icon:'inbox',           color:'sky',     tip:'Tickets non clôturés à ce jour (tous statuts actifs).', filter:'?statut=ouvert' },
        { key:'en_attente_doc',   label:'Attente docs',           icon:'pending_actions', color:'amber',   tip:'En attente de documents client (en_attente_documents + relance_1 + relance_2).', filter:'?statut=en_attente_documents' },
        { key:'en_analyse',       label:'En analyse',             icon:'science',         color:'violet',  tip:'Tickets actuellement sur le banc.', filter:'?statut=en_analyse' },
        { key:'sla_depasse',      label:'SLA dépassé',            icon:'alarm',           color:'red',     tip:'Tickets actifs dont la date limite SLA est passée.', filter:'?sla_depasse=true' },
        { key:'mes_tickets',      label:'Mes tickets ouverts',    icon:'person',          color:'indigo',  tip:'Tickets actifs assignés à votre compte.', filter:'?assignedToMe=true' },
        { key:'avg_resolution_days', label:'Délai moyen résolution', icon:'schedule',     color:'slate',   tip:'Moyenne en jours entre création et clôture, sur 365 jours.', isUnit:'j' },
        { key:'taux_defaut_produit', label:'Taux défaut produit', icon:'verified',        color:'emerald', tip:'Part des analyses concluant à un défaut produit.', isPct:true },
        { key:'ca_recupere',      label:'CA récupéré',            icon:'euro',            color:'emerald', tip:'Total cumulé des forfaits 149€ payés.', isMoney:true },
        { key:'ca_perdu',         label:'CA perdu (impayés)',     icon:'money_off',       color:'red',     tip:'Total cumulé des forfaits 149€ marqués impayés.', isMoney:true },
        { key:'sav_recurrents',   label:'SAV récurrents',         icon:'autorenew',       color:'orange',  tip:'Nombre de VIN ayant > 1 ticket SAV (récurrence fournisseur).' },
      ]; %>
      <% kpis.forEach(function(k){ %>
        <button type="button" class="text-left rounded-2xl border border-slate-200 bg-white p-4 shadow-premium hover:border-primary hover:shadow-lg transition relative group"
                data-kpi="<%= k.key %>"
                data-kpi-filter="<%= k.filter || '' %>"
                data-kpi-money="<%= k.isMoney ? '1' : '' %>"
                data-kpi-pct="<%= k.isPct ? '1' : '' %>"
                data-kpi-unit="<%= k.isUnit || '' %>"
                title="<%= k.tip %>">
          <div class="flex items-center gap-2 text-<%= k.color %>-600">
            <span class="material-symbols-outlined text-base"><%= k.icon %></span>
            <span class="text-xs font-semibold uppercase tracking-wide"><%= k.label %></span>
          </div>
          <div class="mt-2 text-2xl font-bold text-slate-900" data-kpi-value>0</div>
          <div class="absolute bottom-1 right-2 text-[10px] text-slate-300 opacity-0 group-hover:opacity-100">cliquer →</div>
        </button>
      <% }); %>
    </div>

    <!-- État loading / error -->
    <div id="sav-dashboard-error" class="hidden mt-6 rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-800"></div>

    <!-- KPIs Performance SAV (Sprint 3) -->
    <section class="mt-8 rounded-2xl border border-slate-200 bg-white p-5" id="sav-perf-kpis">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h2 class="text-lg font-semibold text-slate-900 flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">monitoring</span>
            Performance SAV
          </h2>
          <p class="text-xs text-slate-500 mt-0.5">Fenêtre : <span id="sav-perf-window">30 jours</span></p>
        </div>
        <select id="sav-perf-days" class="text-xs rounded-lg border border-slate-300 px-2 py-1">
          <option value="7">7 jours</option>
          <option value="30" selected>30 jours</option>
          <option value="90">90 jours</option>
        </select>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="rounded-xl border border-slate-200 p-4">
          <div class="text-[10px] uppercase tracking-wide font-bold text-slate-400">FRT médian</div>
          <div class="mt-1 text-2xl font-bold text-slate-900" id="sav-perf-frt">—</div>
          <div class="text-[10px] text-slate-500">Temps de 1ʳᵉ réponse</div>
        </div>
        <div class="rounded-xl border border-slate-200 p-4">
          <div class="text-[10px] uppercase tracking-wide font-bold text-slate-400">Résolution médiane</div>
          <div class="mt-1 text-2xl font-bold text-slate-900" id="sav-perf-rt">—</div>
          <div class="text-[10px] text-slate-500">Ticket ouvert → clos</div>
        </div>
        <div class="rounded-xl border border-slate-200 p-4">
          <div class="text-[10px] uppercase tracking-wide font-bold text-slate-400">Breach SLA</div>
          <div class="mt-1 text-2xl font-bold" id="sav-perf-breach">—</div>
          <div class="text-[10px] text-slate-500">% clos hors SLA</div>
        </div>
        <div class="rounded-xl border border-slate-200 p-4">
          <div class="text-[10px] uppercase tracking-wide font-bold text-slate-400">Backlog actuel</div>
          <div class="mt-1 text-2xl font-bold text-slate-900" id="sav-perf-backlog">—</div>
          <div class="text-[10px] text-slate-500">Tickets ouverts</div>
        </div>
      </div>
      <!-- Pyramide des âges -->
      <div class="mt-4">
        <div class="text-[10px] uppercase tracking-wide font-bold text-slate-400 mb-2">Pyramide des âges du backlog</div>
        <div class="flex items-end gap-1 h-20" id="sav-perf-aging"></div>
      </div>
    </section>

    <!-- Chart 12 mois (Chart.js via CDN) -->
    <div class="mt-8 rounded-2xl border border-slate-200 bg-white p-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-slate-900">Évolution des SAV (12 derniers mois)</h2>
        <div class="flex items-center gap-3 text-xs">
          <span class="flex items-center gap-1"><span class="inline-block w-3 h-3 rounded bg-sky-500"></span> Ouverts</span>
          <span class="flex items-center gap-1"><span class="inline-block w-3 h-3 rounded bg-emerald-500"></span> Clos</span>
        </div>
      </div>
      <canvas id="sav-chart" height="80"></canvas>
    </div>

    <!-- SLA dépassés table -->
    <div class="mt-8 rounded-2xl border border-slate-200 bg-white overflow-hidden">
      <div class="flex items-center justify-between px-5 py-4 border-b border-slate-200">
        <h2 class="text-lg font-semibold text-slate-900">Dossiers à traiter en priorité</h2>
        <a href="/admin/sav/tickets?sla_depasse=true" class="text-sm text-primary hover:underline">Voir tout →</a>
      </div>
      <div id="sav-priority-list" class="divide-y divide-slate-100">
        <div class="px-5 py-8 text-center text-sm text-slate-500">Chargement…</div>
      </div>
    </div>
  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js" defer></script>
<script src="/js/sav-labels.js?v=3" defer></script>
<script src="/js/sav-admin.js?v=19" defer></script>
<%- include('./partials/footer') %>
