<%- include('./partials/head') %>
<%- include('./partials/sidebar', { active: 'profil' }) %>

<main class="flex-1">
  <div class="px-6 lg:px-10 py-8 max-w-2xl">

    <div class="mb-6">
      <div class="text-2xl md:text-3xl font-semibold text-slate-900">Sécurité de mon compte</div>
      <div class="mt-1 text-sm text-slate-500">Authentification à deux facteurs (TOTP)</div>
    </div>

    <% if (typeof flashMessage !== 'undefined' && flashMessage) { %>
      <div class="mb-4 rounded-xl border <%= (flashType||'success') === 'success' ? 'border-emerald-200 bg-emerald-50 text-emerald-900' : 'border-red-200 bg-red-50 text-red-900' %> p-3 text-sm">
        <%= flashMessage %>
      </div>
    <% } %>

    <section class="rounded-2xl border border-slate-200 bg-white p-5">
      <% if (twoFactorEnabled) { %>
        <div class="flex items-center gap-3 mb-4">
          <span class="material-symbols-outlined text-emerald-600 text-3xl">verified_user</span>
          <div>
            <div class="font-semibold text-slate-900">2FA activée</div>
            <div class="text-xs text-slate-500">Activée le <%= twoFactorActivatedAt ? new Date(twoFactorActivatedAt).toLocaleString('fr-FR') : '—' %></div>
          </div>
        </div>
        <p class="text-sm text-slate-600 mb-4">Votre compte est protégé par un code TOTP à 6 chiffres demandé à chaque connexion.</p>
        <form action="/admin/profil/securite/2fa/disable" method="POST">
          <input type="password" name="password" required placeholder="Mot de passe actuel" class="w-full rounded-xl border border-slate-300 px-3 py-2 text-sm mb-2">
          <button type="submit" class="btn btn-secondary text-red-700 border-red-200 hover:bg-red-50">Désactiver la 2FA</button>
        </form>
      <% } else if (typeof setupSecret !== 'undefined' && setupSecret) { %>
        <div class="space-y-4">
          <p class="text-sm text-slate-700">1. Scannez ce QR code dans Google Authenticator / Authy / Bitwarden / 1Password :</p>
          <div class="flex justify-center">
            <div id="qr-target" data-otpauth="<%= otpauthUrl %>" class="border border-slate-200 rounded-lg p-3"></div>
          </div>
          <details class="text-xs text-slate-500">
            <summary class="cursor-pointer">Saisir manuellement</summary>
            <code class="block mt-2 break-all bg-slate-50 p-2 rounded"><%= setupSecret %></code>
          </details>
          <p class="text-sm text-slate-700">2. Tapez le code à 6 chiffres généré pour confirmer :</p>
          <form action="/admin/profil/securite/2fa/confirm" method="POST" class="space-y-3">
            <input type="hidden" name="secret" value="<%= setupSecret %>">
            <input type="text" name="code" required pattern="[0-9]{6}" maxlength="6" inputmode="numeric"
                   placeholder="123456" autocomplete="one-time-code"
                   class="w-full rounded-xl border border-slate-300 px-4 py-3 text-center text-2xl font-mono tracking-widest focus:border-primary focus:ring-2 focus:ring-primary/20">
            <button type="submit" class="btn btn-primary w-full">Activer la 2FA</button>
          </form>
        </div>
      <% } else { %>
        <p class="text-sm text-slate-700 mb-4">L'authentification à deux facteurs ajoute une couche de sécurité supplémentaire en demandant un code à 6 chiffres généré par votre téléphone à chaque connexion.</p>
        <% if (currentRole === 'owner') { %>
          <div class="mb-4 rounded-xl border border-amber-200 bg-amber-50 p-3 text-xs text-amber-900">
            En tant que <strong>Propriétaire</strong>, la 2FA est <strong>obligatoire</strong> et vous sera demandée à chaque connexion une fois activée.
          </div>
        <% } %>
        <form action="/admin/profil/securite/2fa/setup" method="POST">
          <button type="submit" class="btn btn-primary">Configurer la 2FA</button>
        </form>
      <% } %>
    </section>

    <% if (typeof backupCodes !== 'undefined' && backupCodes && backupCodes.length) { %>
      <section class="mt-6 rounded-2xl border border-amber-200 bg-amber-50 p-5">
        <h2 class="font-semibold text-amber-900 flex items-center gap-2">
          <span class="material-symbols-outlined">save</span>
          Codes de secours
        </h2>
        <p class="text-sm text-amber-900 mt-1">Conservez ces codes en lieu sûr. Chaque code ne peut être utilisé qu'une seule fois en cas de perte de votre application 2FA.</p>
        <ul class="mt-3 grid grid-cols-2 gap-2 font-mono text-sm">
          <% backupCodes.forEach(function(c){ %>
            <li class="px-3 py-2 rounded bg-white border border-amber-200 text-center"><%= c %></li>
          <% }); %>
        </ul>
      </section>
    <% } %>

  </div>
</main>

<% if (typeof setupSecret !== 'undefined' && setupSecret) { %>
  <script src="https://cdn.jsdelivr.net/npm/qrcode@1.5.3/build/qrcode.min.js"></script>
  <script>
    (function(){
      var target = document.getElementById('qr-target');
      if (target && window.QRCode) {
        QRCode.toCanvas(target, target.getAttribute('data-otpauth'), { width: 200, margin: 1 });
      }
    })();
  </script>
<% } %>
<%- include('./partials/footer') %>
