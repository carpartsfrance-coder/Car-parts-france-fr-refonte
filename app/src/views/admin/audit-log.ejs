<%- include('./partials/head') %>
<link rel="stylesheet" href="/css/sav.css?v=21">
<%- include('./partials/sidebar', { active: 'sav' }) %>

<main class="flex-1 sav-module" data-sav-token="<%= savApiToken %>">
  <div class="px-6 lg:px-10 py-8">

    <div class="flex items-start justify-between gap-4 mb-6">
      <div>
        <div class="text-2xl md:text-3xl font-semibold text-slate-900">Journal d'audit</div>
        <div class="mt-1 text-sm text-slate-500">Toutes les actions sensibles back-office (TTL 2 ans)</div>
      </div>
      <a href="/admin" class="btn btn-secondary">← Back-office</a>
    </div>

    <form id="sav-audit-filters" class="grid grid-cols-1 sm:grid-cols-4 gap-3 mb-4">
      <input type="text" name="action" placeholder="Action (sav.statut, sav.assign…)" class="rounded-xl border border-slate-300 px-3 py-2 text-sm">
      <input type="text" name="userEmail" placeholder="Email utilisateur" class="rounded-xl border border-slate-300 px-3 py-2 text-sm">
      <input type="text" name="entityId" placeholder="Entity ID (n° ticket)" class="rounded-xl border border-slate-300 px-3 py-2 text-sm">
      <button type="submit" class="btn btn-primary">Filtrer</button>
    </form>

    <div class="rounded-2xl border border-slate-200 bg-white overflow-hidden">
      <table class="w-full text-xs">
        <thead class="bg-slate-50 text-left">
          <tr>
            <th class="px-3 py-3">Date</th>
            <th class="px-3 py-3">Utilisateur</th>
            <th class="px-3 py-3">Action</th>
            <th class="px-3 py-3">Entité</th>
            <th class="px-3 py-3">Avant</th>
            <th class="px-3 py-3">Après</th>
            <th class="px-3 py-3">IP</th>
          </tr>
        </thead>
        <tbody id="sav-audit-tbody" class="divide-y divide-slate-100">
          <tr><td colspan="7" class="px-4 py-10 text-center text-slate-500">Chargement…</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</main>

<script src="/js/sav-admin.js?v=4" defer></script>
<%- include('./partials/footer') %>
