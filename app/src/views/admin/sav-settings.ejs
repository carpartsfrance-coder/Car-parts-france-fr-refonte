<%- include('./partials/head') %>
<link rel="stylesheet" href="/css/sav.css?v=21">
<%- include('./partials/sidebar', { active: 'sav' }) %>

<main class="flex-1 sav-module" data-sav-token="<%= savApiToken %>">
  <div class="px-6 lg:px-10 py-8 max-w-4xl">

    <div class="flex items-start justify-between gap-4 mb-6">
      <div>
        <div class="text-2xl md:text-3xl font-semibold text-slate-900">Paramètres SAV</div>
        <div class="mt-1 text-sm text-slate-500">Délais SLA par type de pièce et règles d'automatisation</div>
      </div>
      <a href="/admin/sav" class="btn btn-secondary">← Dashboard</a>
    </div>

    <!-- SLA -->
    <section class="rounded-2xl border border-slate-200 bg-white p-5 mb-6">
      <h2 class="text-lg font-semibold mb-4">Délais SLA par type de pièce (jours ouvrés)</h2>
      <div id="sav-sla-grid" class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        <div class="text-sm text-slate-500 col-span-full">Chargement…</div>
      </div>
    </section>

    <!-- Automatisations -->
    <section class="rounded-2xl border border-slate-200 bg-white p-5 mb-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold">Règles d'automatisation</h2>
        <button id="sav-auto-run-now" type="button" class="btn btn-secondary text-sm">
          <span class="material-symbols-outlined text-base mr-1">play_arrow</span> Exécuter maintenant
        </button>
      </div>
      <div id="sav-auto-list" class="space-y-3">
        <div class="text-sm text-slate-500">Chargement…</div>
      </div>
    </section>

    <div class="flex justify-end gap-2">
      <button type="button" id="sav-settings-save" class="btn btn-primary">
        <span class="material-symbols-outlined text-base mr-1">save</span>
        Enregistrer
      </button>
    </div>

    <div id="sav-settings-feedback" class="hidden mt-3 rounded-xl border p-3 text-sm"></div>
  </div>
</main>

<div class="sav-toast-root" id="sav-toast-root" aria-live="polite"></div>
<script src="/js/sav-admin.js?v=4" defer></script>
<%- include('./partials/footer') %>
