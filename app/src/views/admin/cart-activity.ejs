<%- include('./partials/head') %>

<%- include('./partials/sidebar', { active: 'cart-activity' }) %>

<main class="flex-1">
  <div class="px-6 lg:px-10 py-8">
    <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">
      <div>
        <%- include('./partials/breadcrumb', { breadcrumbs: [{label: 'Activité panier'}] }) %>
        <div class="text-2xl md:text-3xl font-semibold text-slate-900">Activité panier</div>
        <div class="mt-1 text-sm text-slate-500">Historique des actions panier des clients connectés.</div>
      </div>
    </div>

    <!-- Filtres -->
    <form action="/admin/activite-panier" class="sticky top-0 z-30 mt-6 bg-white/98 backdrop-blur rounded-2xl border border-slate-200 p-4 shadow-lg shadow-slate-200/70" method="GET">
      <div class="flex flex-col xl:flex-row xl:items-center gap-4">
        <div class="flex-1">
          <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">search</span>
            <input class="w-full rounded-2xl border border-slate-200 bg-white pl-10 pr-4 py-3 text-sm font-semibold text-slate-900 placeholder:text-slate-400" name="q" placeholder="Rechercher : nom, email du client..." type="text" value="<%= filters && filters.q ? filters.q : '' %>" />
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-3">
          <select class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-bold text-slate-900" name="action">
            <option value="">Toutes les actions</option>
            <option value="add" <%= filters && filters.action === 'add' ? 'selected' : '' %>>Ajout</option>
            <option value="update" <%= filters && filters.action === 'update' ? 'selected' : '' %>>Modification</option>
            <option value="remove" <%= filters && filters.action === 'remove' ? 'selected' : '' %>>Suppression</option>
          </select>

          <select class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-bold text-slate-900" name="period">
            <option value="">Toutes périodes</option>
            <option value="24h" <%= filters && filters.period === '24h' ? 'selected' : '' %>>24 heures</option>
            <option value="7d" <%= filters && filters.period === '7d' ? 'selected' : '' %>>7 jours</option>
            <option value="30d" <%= filters && filters.period === '30d' ? 'selected' : '' %>>30 jours</option>
            <option value="90d" <%= filters && filters.period === '90d' ? 'selected' : '' %>>90 jours</option>
          </select>

          <button class="btn btn-secondary" type="submit">
            Filtrer
          </button>
        </div>
      </div>
    </form>

    <!-- Tableau -->
    <div class="mt-8 bg-white rounded-2xl border border-slate-200 overflow-hidden">
      <div class="px-6 py-4 bg-slate-50 flex items-center justify-between">
        <div class="font-semibold text-slate-900">Événements panier</div>
        <% if (typeof pagination !== 'undefined' && pagination && pagination.totalItems) { %>
          <div class="text-xs font-bold text-slate-500">
            <%= pagination.from %>–<%= pagination.to %> sur <%= pagination.totalItems %>
          </div>
        <% } %>
      </div>

      <% if (events && events.length) { %>
        <div class="overflow-x-auto">
          <table class="w-full text-left admin-table">
            <thead>
              <tr class="text-xs font-semibold text-slate-400 uppercase tracking-widest bg-white">
                <th class="px-6 py-4">Date / Heure</th>
                <th class="px-6 py-4">Client</th>
                <th class="px-6 py-4">Action</th>
                <th class="px-6 py-4">Produit</th>
                <th class="px-6 py-4 text-center">Quantité</th>
                <th class="px-6 py-4">Options</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% events.forEach((ev) => { %>
                <tr>
                  <!-- Date -->
                  <td class="px-6 py-4 text-sm text-slate-500 whitespace-nowrap"><%= ev.dateFormatted %></td>

                  <!-- Client -->
                  <td class="px-6 py-4">
                    <div class="flex items-center gap-2">
                      <div>
                        <a class="font-semibold text-slate-900 hover:text-primary transition" href="/admin/clients/<%= ev.userId %>"><%= ev.userName || 'Client' %></a>
                        <div class="text-xs text-slate-400"><%= ev.userEmail %></div>
                      </div>
                      <% if (ev.accountType === 'pro') { %>
                        <span class="badge badge-pro">PRO</span>
                      <% } %>
                    </div>
                  </td>

                  <!-- Action badge -->
                  <td class="px-6 py-4">
                    <% if (ev.action === 'add') { %>
                      <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-bold bg-emerald-50 text-emerald-700">
                        <span class="material-symbols-outlined text-sm">add_shopping_cart</span>
                        Ajout
                      </span>
                    <% } else if (ev.action === 'update') { %>
                      <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-bold bg-amber-50 text-amber-700">
                        <span class="material-symbols-outlined text-sm">edit</span>
                        Modification
                      </span>
                    <% } else if (ev.action === 'remove') { %>
                      <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-bold bg-red-50 text-red-700">
                        <span class="material-symbols-outlined text-sm">remove_shopping_cart</span>
                        Suppression
                      </span>
                    <% } %>
                  </td>

                  <!-- Produit -->
                  <td class="px-6 py-4">
                    <% if (ev.productName) { %>
                      <a class="font-semibold text-slate-900 hover:text-primary transition" href="/admin/catalogue/<%= ev.productId %>"><%= ev.productName %></a>
                    <% } else { %>
                      <span class="text-slate-400 italic">Produit supprimé</span>
                    <% } %>
                    <% if (ev.productSku) { %>
                      <div class="text-xs text-slate-400">SKU : <%= ev.productSku %></div>
                    <% } %>
                  </td>

                  <!-- Quantité -->
                  <td class="px-6 py-4 text-center text-sm font-semibold text-slate-700">
                    <% if (ev.action === 'update' && ev.previousQuantity != null) { %>
                      <span class="text-slate-400"><%= ev.previousQuantity %></span>
                      <span class="material-symbols-outlined text-xs text-slate-300 align-middle">arrow_forward</span>
                      <span><%= ev.quantity %></span>
                    <% } else if (ev.action === 'remove') { %>
                      <span class="text-red-400 line-through"><%= ev.previousQuantity || '-' %></span>
                    <% } else { %>
                      <%= ev.quantity %>
                    <% } %>
                  </td>

                  <!-- Options -->
                  <td class="px-6 py-4 text-xs text-slate-500">
                    <%= ev.optionsSummary || '—' %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <div class="px-6 py-4 border-t border-slate-100 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div class="text-xs font-semibold uppercase tracking-widest text-slate-400">
            Affichage <%= pagination.from %>-<%= pagination.to %> sur <%= pagination.totalItems %>
          </div>

          <%
            const qVal = filters && filters.q ? String(filters.q) : '';
            const actionVal = filters && filters.action ? String(filters.action) : '';
            const periodVal = filters && filters.period ? String(filters.period) : '';
            const extraQuery = [
              qVal ? `q=${encodeURIComponent(qVal)}` : '',
              actionVal ? `action=${encodeURIComponent(actionVal)}` : '',
              periodVal ? `period=${encodeURIComponent(periodVal)}` : '',
            ].filter(Boolean).join('&');
            const withExtra = extraQuery ? `&${extraQuery}` : '';
          %>

          <% if (typeof pagination !== 'undefined' && pagination && pagination.totalPages > 1) { %>
            <div class="flex items-center justify-end gap-2">
              <a class="w-9 h-9 inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white hover:bg-slate-50 transition <%= pagination.hasPrev ? '' : 'opacity-40 pointer-events-none' %>" href="?page=<%= pagination.prevPage %><%= withExtra %>" aria-label="Page précédente">
                <span class="material-symbols-outlined text-slate-500">chevron_left</span>
              </a>

              <% const startPage = Math.max(1, pagination.page - 2); %>
              <% const endPage = Math.min(pagination.totalPages, pagination.page + 2); %>
              <% for (let p = startPage; p <= endPage; p += 1) { %>
                <a class="w-9 h-9 inline-flex items-center justify-center rounded-xl border text-xs font-semibold <%= p === pagination.page ? 'bg-primary text-white border-primary' : 'bg-white text-slate-500 border-slate-200 hover:bg-slate-50' %>" href="?page=<%= p %><%= withExtra %>"><%= p %></a>
              <% } %>

              <a class="w-9 h-9 inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white hover:bg-slate-50 transition <%= pagination.hasNext ? '' : 'opacity-40 pointer-events-none' %>" href="?page=<%= pagination.nextPage %><%= withExtra %>" aria-label="Page suivante">
                <span class="material-symbols-outlined text-slate-500">chevron_right</span>
              </a>
            </div>
          <% } %>
        </div>

      <% } else { %>
        <div class="text-center py-12">
          <span class="material-symbols-outlined text-6xl text-slate-300">add_shopping_cart</span>
          <p class="text-lg font-semibold text-slate-500 mt-4">Aucune activité panier</p>
          <p class="text-slate-400 text-sm">Les actions panier des clients connectés apparaîtront ici.</p>
        </div>
      <% } %>
    </div>
  </div>
</main>

<%- include('./partials/footer') %>
