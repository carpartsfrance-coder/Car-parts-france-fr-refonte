<%
/**
 * Skeleton overlay shared by Orders, Catalog, Clients table pages.
 * Removed by JS on DOMContentLoaded — see skeleton-init inline script.
 */
%>
<div id="page-skeleton" class="absolute inset-0 z-[5] bg-white px-6 lg:px-10 py-8 pointer-events-none">

  <!-- Page header -->
  <div class="mb-6">
    <div class="skeleton" style="width:90px;height:13px;border-radius:4px;margin-bottom:10px;"></div>
    <div class="skeleton skeleton-title" style="width:180px;"></div>
    <div class="skeleton skeleton-text" style="width:260px;margin-top:4px;"></div>
  </div>

  <!-- Filter bar placeholder -->
  <div class="skeleton" style="width:100%;height:64px;border-radius:16px;margin-bottom:32px;"></div>

  <!-- Table card -->
  <div class="bg-slate-50 rounded-2xl border border-slate-100 overflow-hidden">
    <!-- Table header row -->
    <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
      <div class="skeleton" style="width:120px;height:16px;border-radius:5px;"></div>
      <div class="skeleton" style="width:80px;height:13px;border-radius:4px;"></div>
    </div>

    <!-- Column header row -->
    <div class="flex gap-4 px-6 py-3 border-b border-slate-100">
      <div class="skeleton" style="width:18px;height:18px;border-radius:4px;flex-shrink:0;"></div>
      <div class="skeleton" style="width:130px;height:13px;border-radius:4px;"></div>
      <div class="skeleton" style="width:90px;height:13px;border-radius:4px;margin-left:auto;"></div>
      <div class="skeleton" style="width:70px;height:13px;border-radius:4px;"></div>
      <div class="skeleton" style="width:80px;height:13px;border-radius:4px;"></div>
      <div class="skeleton" style="width:60px;height:13px;border-radius:4px;"></div>
    </div>

    <!-- Data rows -->
    <% for (let i = 0; i < 8; i++) { %>
      <div class="skeleton-row skeleton mx-6 my-1" style="border-radius:10px;height:52px;"></div>
    <% } %>

    <!-- Pagination row -->
    <div class="px-6 py-4 border-t border-slate-100 flex items-center justify-between">
      <div class="skeleton" style="width:160px;height:13px;border-radius:4px;"></div>
      <div class="flex gap-2">
        <div class="skeleton" style="width:32px;height:32px;border-radius:8px;"></div>
        <div class="skeleton" style="width:32px;height:32px;border-radius:8px;"></div>
        <div class="skeleton" style="width:32px;height:32px;border-radius:8px;"></div>
        <div class="skeleton" style="width:32px;height:32px;border-radius:8px;"></div>
      </div>
    </div>
  </div>
</div>
