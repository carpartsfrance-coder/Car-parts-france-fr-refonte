<%
/**
 * Skeleton overlay for Dashboard.
 * Removed by JS on DOMContentLoaded — see skeleton-init inline script.
 */
%>
<div id="page-skeleton" class="absolute inset-0 z-[5] bg-white px-6 lg:px-10 py-8 pointer-events-none">

  <!-- Title bar -->
  <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6 mb-8">
    <div style="width:260px;">
      <div class="skeleton skeleton-title" style="width:55%;"></div>
      <div class="skeleton skeleton-text" style="width:70%;margin-top:4px;"></div>
    </div>
    <div class="flex gap-3">
      <div class="skeleton" style="width:130px;height:38px;border-radius:10px;"></div>
      <div class="skeleton" style="width:150px;height:38px;border-radius:10px;"></div>
    </div>
  </div>

  <!-- KPI cards row 1 — 4 cols -->
  <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6 mb-6">
    <% for (let i = 0; i < 4; i++) { %>
      <div class="bg-slate-50 rounded-2xl border border-slate-100 p-5">
        <div class="flex items-center justify-between mb-4">
          <div class="skeleton" style="width:40px;height:40px;border-radius:10px;"></div>
          <div class="skeleton" style="width:36px;height:20px;border-radius:6px;"></div>
        </div>
        <div class="skeleton skeleton-text" style="width:60%;"></div>
        <div class="skeleton" style="width:50%;height:28px;margin-bottom:8px;border-radius:6px;"></div>
        <div class="skeleton skeleton-text" style="width:80%;"></div>
        <div class="skeleton" style="width:100%;height:36px;margin-top:12px;border-radius:6px;"></div>
      </div>
    <% } %>
  </div>

  <!-- KPI cards row 2 — 4 cols -->
  <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6 mb-6">
    <% for (let i = 0; i < 4; i++) { %>
      <div class="bg-slate-50 rounded-2xl border border-slate-100 p-5">
        <div class="flex items-center justify-between mb-3">
          <div class="skeleton" style="width:40px;height:40px;border-radius:10px;"></div>
          <div class="skeleton" style="width:8px;height:8px;border-radius:50%;"></div>
        </div>
        <div class="skeleton skeleton-text" style="width:55%;"></div>
        <div class="skeleton" style="width:40%;height:26px;border-radius:6px;"></div>
      </div>
    <% } %>
  </div>

  <!-- Bottom two-col layout: activity feed + chart -->
  <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

    <!-- Activity feed (col 2/3) -->
    <div class="xl:col-span-2 bg-slate-50 rounded-2xl border border-slate-100 p-6">
      <div class="flex items-center justify-between mb-6">
        <div class="skeleton skeleton-title" style="width:35%;margin-bottom:0;"></div>
        <div class="skeleton" style="width:80px;height:22px;border-radius:6px;"></div>
      </div>
      <% for (let i = 0; i < 5; i++) { %>
        <div class="flex items-start gap-3 mb-5">
          <div class="skeleton" style="width:40px;height:40px;border-radius:50%;flex-shrink:0;"></div>
          <div style="flex:1;">
            <div class="skeleton skeleton-text" style="width:70%;"></div>
            <div class="skeleton skeleton-text" style="width:50%;"></div>
            <div class="skeleton skeleton-text" style="width:30%;"></div>
          </div>
        </div>
      <% } %>
    </div>

    <!-- Chart (col 1/3) -->
    <div class="bg-slate-50 rounded-2xl border border-slate-100 p-6">
      <div class="skeleton skeleton-title" style="width:60%;margin-bottom:24px;"></div>
      <div class="skeleton" style="width:100%;height:220px;border-radius:12px;"></div>
    </div>

  </div>
</div>
