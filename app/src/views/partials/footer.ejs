<style>
  #cartFeedbackRoot {
    position: fixed;
    top: 1rem;
    left: 1rem;
    right: 1rem;
    z-index: 60;
    pointer-events: none;
  }
  @media (min-width: 640px) {
    #cartFeedbackRoot {
      left: auto;
      width: min(420px, calc(100vw - 2rem));
    }
  }
  .cart-feedback-toast {
    pointer-events: auto;
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
    border-radius: 1rem;
    background: #ffffff;
    border-left: 4px solid #38A169;
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.14);
    padding: 1rem;
    transform: translateX(110%);
    opacity: 0;
    transition: transform 0.28s ease, opacity 0.22s ease;
  }
  .cart-feedback-toast.is-visible {
    transform: translateX(0);
    opacity: 1;
  }
  .cart-feedback-toast.is-leaving {
    transform: translateX(0);
    opacity: 0;
  }
  .cart-feedback-toast.is-error {
    border-left-color: #E53E3E;
  }
  .cart-feedback-thumb {
    width: 3rem;
    height: 3rem;
    flex-shrink: 0;
    border-radius: 0.85rem;
    overflow: hidden;
    background: #F8FAFC;
    border: 1px solid #E2E8F0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cart-feedback-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cart-feedback-title {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .cart-feedback-icon-bounce {
    animation: cartFeedbackIconBounce 0.5s ease;
  }
  .cart-feedback-count-bounce {
    animation: cartFeedbackCountBounce 0.5s ease;
  }
  .cart-submit-success {
    background: #38A169 !important;
    border-color: #38A169 !important;
    color: #ffffff !important;
    box-shadow: 0 14px 28px rgba(56, 161, 105, 0.28) !important;
  }
  .cart-submit-success:hover {
    background: #38A169 !important;
    border-color: #38A169 !important;
    color: #ffffff !important;
  }
  @keyframes cartFeedbackIconBounce {
    0% { transform: scale(1); }
    30% { transform: scale(1.18) translateY(-2px); }
    60% { transform: scale(0.96) translateY(0); }
    100% { transform: scale(1); }
  }
  @keyframes cartFeedbackCountBounce {
    0% { transform: scale(1); }
    35% { transform: scale(1.28); }
    100% { transform: scale(1); }
  }
</style>

<div id="cartFeedbackRoot" aria-live="polite" aria-atomic="true" data-initial-cart-feedback="<%- encodeURIComponent(JSON.stringify(cartFeedback || null)) %>"></div>

<script>
  (function () {
    var root = document.getElementById('cartFeedbackRoot');
    if (!root) return;

    var initialCartFeedback = null;
    var initialCartFeedbackRaw = root.getAttribute('data-initial-cart-feedback') || '';

    if (initialCartFeedbackRaw) {
      try {
        initialCartFeedback = JSON.parse(decodeURIComponent(initialCartFeedbackRaw));
      } catch (e) {
        initialCartFeedback = null;
      }
    }

    var activeToast = null;
    var hideTimer = null;

    function formatCount(count) {
      var n = Number(count) || 0;
      if (n > 99) return '99+';
      if (n < 0) return '0';
      return String(n);
    }

    function restartAnimation(node, className) {
      if (!node) return;
      node.classList.remove(className);
      void node.offsetWidth;
      node.classList.add(className);
      window.setTimeout(function () {
        node.classList.remove(className);
      }, 520);
    }

    function removeToast(toast) {
      if (!toast || !toast.parentNode) return;
      toast.parentNode.removeChild(toast);
      if (activeToast === toast) activeToast = null;
    }

    function hideToast(toast) {
      if (!toast) return;
      toast.classList.remove('is-visible');
      toast.classList.add('is-leaving');
      window.setTimeout(function () {
        removeToast(toast);
      }, 220);
    }

    function updateCartCount(count) {
      var nodes = Array.prototype.slice.call(document.querySelectorAll('[data-cart-count]') || []);
      var display = formatCount(count);
      var n = Number(count) || 0;
      nodes.forEach(function (node) {
        node.textContent = display;
        if (node.dataset && node.dataset.cartCountZeroHidden === 'true') {
          if (n > 0) {
            node.classList.remove('hidden');
            node.classList.add('flex');
          } else {
            node.classList.add('hidden');
            node.classList.remove('flex');
          }
        }
        restartAnimation(node, 'cart-feedback-count-bounce');
      });
    }

    function animateCartIcon() {
      var icons = Array.prototype.slice.call(document.querySelectorAll('[data-cart-icon]') || []);
      icons.forEach(function (icon) {
        restartAnimation(icon, 'cart-feedback-icon-bounce');
      });
    }

    function buildThumb(imageUrl, isError) {
      if (imageUrl && !isError) {
        return '<div class="cart-feedback-thumb"><img alt="Produit" src="' + imageUrl.replace(/"/g, '&quot;') + '" /></div>';
      }
      return '<div class="cart-feedback-thumb"><span class="material-symbols-outlined ' + (isError ? 'text-red-500' : 'text-emerald-500') + '">' + (isError ? 'error' : 'check_circle') + '</span></div>';
    }

    function showToast(options) {
      var config = options && typeof options === 'object' ? options : {};
      var isError = config.type === 'error';
      var message = config.message ? String(config.message) : (isError ? 'Une erreur est survenue.' : 'Produit ajouté au panier');
      var productName = config.productName ? String(config.productName) : '';
      var imageUrl = config.imageUrl ? String(config.imageUrl) : '';
      var actionHref = config.actionHref ? String(config.actionHref) : '/panier';
      var actionLabel = config.actionLabel ? String(config.actionLabel) : 'Voir le panier';
      var duration = Number.isFinite(Number(config.duration)) ? Number(config.duration) : 4000;

      if (hideTimer) {
        window.clearTimeout(hideTimer);
        hideTimer = null;
      }
      if (activeToast) {
        removeToast(activeToast);
      }

      var toast = document.createElement('div');
      toast.className = 'cart-feedback-toast' + (isError ? ' is-error' : '');
      toast.innerHTML = ''
        + buildThumb(imageUrl, isError)
        + '<div class="min-w-0 flex-1">'
        +   '<div class="flex items-start gap-3">'
        +     '<div class="min-w-0 flex-1">'
        +       '<div class="flex items-center gap-2 text-sm font-black ' + (isError ? 'text-red-600' : 'text-emerald-600') + '">'
        +         '<span class="material-symbols-outlined text-[18px]">' + (isError ? 'error' : 'check_circle') + '</span>'
        +         '<span>' + message + '</span>'
        +       '</div>'
        +       (productName ? '<div class="cart-feedback-title mt-1 text-sm font-semibold text-slate-700">' + productName.replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</div>' : '')
        +     '</div>'
        +   '</div>'
        +   (!isError ? '<div class="mt-3"><a class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-4 py-2 text-xs font-black uppercase tracking-wider text-white hover:bg-black transition" href="' + actionHref.replace(/"/g, '&quot;') + '">' + actionLabel.replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</a></div>' : '')
        + '</div>';

      root.appendChild(toast);
      activeToast = toast;

      window.requestAnimationFrame(function () {
        toast.classList.add('is-visible');
      });

      hideTimer = window.setTimeout(function () {
        hideToast(toast);
      }, duration);

      return toast;
    }

    window.CPFCartFeedback = {
      animateCartIcon: animateCartIcon,
      showToast: showToast,
      updateCartCount: updateCartCount,
      notifyAdded: function (payload) {
        var data = payload && typeof payload === 'object' ? payload : {};
        updateCartCount(data.cartItemCount);
        animateCartIcon();
        showToast({
          type: 'success',
          message: 'Produit ajouté au panier',
          productName: data.productName,
          imageUrl: data.imageUrl,
          actionHref: '/panier',
          actionLabel: 'Voir le panier',
          duration: 4000,
        });
      },
      notifyError: function (message) {
        showToast({
          type: 'error',
          message: message || 'Impossible d’ajouter le produit au panier.',
          duration: 4000,
        });
      },
    };

    if (window.fetch && window.FormData) {
      var cartForms = Array.prototype.slice.call(document.querySelectorAll('form[action^="/panier/ajouter/"]') || []);

      cartForms.forEach(function (form) {
        if (!form || form.hasAttribute('data-add-to-cart-form')) return;

        var submitButton = form.querySelector('button[type="submit"]');
        if (!submitButton) return;

        var pending = false;
        var originalDisabled = !!submitButton.disabled;
        var resetTimer = null;

        function resetButton() {
          if (resetTimer) {
            window.clearTimeout(resetTimer);
            resetTimer = null;
          }
          submitButton.disabled = originalDisabled;
          submitButton.classList.remove('cart-submit-success');
        }

        function setSuccessState() {
          submitButton.classList.add('cart-submit-success');
          submitButton.disabled = true;
        }

        form.addEventListener('submit', function (event) {
          if (pending) {
            event.preventDefault();
            return;
          }

          event.preventDefault();
          pending = true;
          submitButton.disabled = true;

          var startedAt = Date.now();
          var formData = new FormData(form);

          fetch(form.getAttribute('action'), {
            method: 'POST',
            body: formData,
            credentials: 'same-origin',
            headers: {
              'Accept': 'application/json',
              'X-Requested-With': 'XMLHttpRequest'
            }
          })
            .then(function (response) {
              return response.json().catch(function () {
                return null;
              }).then(function (data) {
                if (!response.ok || !data || data.ok !== true) {
                  throw new Error(data && data.error ? data.error : 'Impossible d’ajouter le produit au panier pour le moment.');
                }
                return data;
              });
            })
            .then(function (data) {
              var payload = data && typeof data === 'object' ? data : {};
              var productData = payload.product && typeof payload.product === 'object' ? payload.product : {};

              window.CPFCartFeedback.notifyAdded({
                cartItemCount: payload.cartItemCount,
                productName: productData.name || 'Produit',
                imageUrl: productData.imageUrl || ''
              });

              setSuccessState();

              var minDisableRemaining = Math.max(0, 1000 - (Date.now() - startedAt));
              window.setTimeout(function () {
                resetTimer = window.setTimeout(function () {
                  resetButton();
                  pending = false;
                }, 2000);
              }, minDisableRemaining);
            })
            .catch(function (err) {
              var minDisableRemaining = Math.max(0, 1000 - (Date.now() - startedAt));
              window.CPFCartFeedback.notifyError(err && err.message ? err.message : 'Impossible d’ajouter le produit au panier pour le moment.');
              window.setTimeout(function () {
                resetButton();
                pending = false;
              }, minDisableRemaining);
            });
        });
      });
    }

    if (initialCartFeedback && typeof initialCartFeedback === 'object') {
      if (initialCartFeedback.type === 'success') {
        var initialProduct = initialCartFeedback.product && typeof initialCartFeedback.product === 'object' ? initialCartFeedback.product : {};
        window.setTimeout(function () {
          window.CPFCartFeedback.notifyAdded({
            cartItemCount: initialCartFeedback.cartItemCount,
            productName: initialProduct.name || 'Produit',
            imageUrl: initialProduct.imageUrl || ''
          });
        }, 80);
      } else if (initialCartFeedback.type === 'error') {
        window.setTimeout(function () {
          window.CPFCartFeedback.notifyError(initialCartFeedback.message || 'Impossible d’ajouter le produit au panier.');
        }, 80);
      }
    }
  })();
</script>
</div>

</body></html>
