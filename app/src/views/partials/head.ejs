<!DOCTYPE html>
<html class="light" lang="<%= typeof lang !== 'undefined' ? lang : 'fr' %>"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title><%= typeof title !== 'undefined' ? title : 'CarParts France' %></title>
<link rel="icon" type="image/png" href="/images/favicon.png" />
<!-- Google Tag Manager -->
<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-NZDFRVCG');</script>
<!-- End Google Tag Manager -->
<script>
  (function () {
    document.documentElement.classList.add('js');
  })();
</script>
<style>
  html.js:not(.icons-ready) .material-symbols-outlined,
  html.js:not(.icons-ready) .material-symbols-rounded {
    visibility: hidden;
  }
</style>
<meta name="robots" content="<%= (typeof metaRobots !== 'undefined' && metaRobots) ? metaRobots : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1' %>"/>
<% if (typeof metaDescription !== 'undefined' && metaDescription) { %>
<meta name="description" content="<%= metaDescription %>"/>
<% } %>
<% if (typeof canonicalUrl !== 'undefined' && canonicalUrl) { %>
<link rel="canonical" href="<%= canonicalUrl %>"/>
<% } %>
<% if (typeof hreflangTags !== 'undefined' && Array.isArray(hreflangTags) && hreflangTags.length > 0) { %>
<% hreflangTags.forEach(function(tag) { %>
<link rel="alternate" hreflang="<%= tag.lang %>" href="<%= tag.href %>"/>
<% }); %>
<% } else { %>
<% if (typeof hreflangFr !== 'undefined' && hreflangFr) { %>
<link rel="alternate" hreflang="fr" href="<%= hreflangFr %>"/>
<% } %>
<% if (typeof hreflangEn !== 'undefined' && hreflangEn) { %>
<link rel="alternate" hreflang="en" href="<%= hreflangEn %>"/>
<% } %>
<% if (typeof hreflangDefault !== 'undefined' && hreflangDefault) { %>
<link rel="alternate" hreflang="x-default" href="<%= hreflangDefault %>"/>
<% } %>
<% } %>
<% if (typeof ogTitle !== 'undefined' && ogTitle) { %>
<meta property="og:title" content="<%= ogTitle %>"/>
<% } %>
<% if (typeof ogDescription !== 'undefined' && ogDescription) { %>
<meta property="og:description" content="<%= ogDescription %>"/>
<% } %>
<% if (typeof ogUrl !== 'undefined' && ogUrl) { %>
<meta property="og:url" content="<%= ogUrl %>"/>
<% } %>
<% if (typeof ogSiteName !== 'undefined' && ogSiteName) { %>
<meta property="og:site_name" content="<%= ogSiteName %>"/>
<% } %>
<% if (typeof ogImage !== 'undefined' && ogImage) { %>
<meta property="og:image" content="<%= ogImage %>"/>
<% } %>
<meta property="og:type" content="<%= (typeof ogType !== 'undefined' && ogType) ? ogType : 'website' %>"/>
<% if (typeof ogArticlePublishedTime !== 'undefined' && ogArticlePublishedTime) { %>
<meta property="article:published_time" content="<%= ogArticlePublishedTime %>"/>
<% } %>
<% if (typeof ogArticleModifiedTime !== 'undefined' && ogArticleModifiedTime) { %>
<meta property="article:modified_time" content="<%= ogArticleModifiedTime %>"/>
<% } %>
<meta name="twitter:card" content="summary_large_image"/>
<% if (typeof ogTitle !== 'undefined' && ogTitle) { %>
<meta name="twitter:title" content="<%= ogTitle %>"/>
<% } %>
<% if (typeof ogDescription !== 'undefined' && ogDescription) { %>
<meta name="twitter:description" content="<%= ogDescription %>"/>
<% } %>
<% if (typeof ogImage !== 'undefined' && ogImage) { %>
<meta name="twitter:image" content="<%= ogImage %>"/>
<% } %>
<% if (typeof jsonLd !== 'undefined' && jsonLd) { %>
<script type="application/ld+json"><%- jsonLd %></script>
<% } %>
<!-- Preload critical CSS for faster FCP -->
<link rel="preload" href="/css/styles.css" as="style"/>
<link rel="stylesheet" href="/css/styles.css"/>
<!-- Preconnect to Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<!-- Critical fonts: Inter (body) + Outfit (headings) loaded with display=swap -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@500;600;700&amp;display=swap" rel="stylesheet"/>
<!-- Icon fonts -->
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&amp;display=swap" rel="stylesheet"/>
<script>
  (function () {
    var el = document.documentElement;
    if (!el.classList.contains('js')) el.classList.add('js');
    if (!document.fonts || typeof document.fonts.load !== 'function') {
      el.classList.add('icons-ready');
      return;
    }

    var done = false;
    function markReady() {
      if (done) return;
      done = true;
      el.classList.add('icons-ready');
    }

    Promise.all([
      document.fonts.load('1em "Material Symbols Outlined"'),
      document.fonts.load('1em "Material Symbols Rounded"'),
    ])
      .then(markReady)
      .catch(markReady);

    setTimeout(markReady, 2000);
  })();
</script>
</head>
<body class="bg-[#f6f7fb] font-display text-slate-900 transition-colors duration-200 antialiased overflow-x-hidden">
<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NZDFRVCG"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->
<div class="relative flex min-h-screen w-full flex-col pb-20 md:pb-0">
