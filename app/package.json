{
  "name": "carpartsfrance-refonte-node",
  "version": "0.1.0",
  "private": true,
  "main": "src/server.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "css:build": "npx tailwindcss -i src/styles/main.css -o public/css/styles.css --minify",
    "css:watch": "npx tailwindcss -i src/styles/main.css -o public/css/styles.css --watch",
    "dev": "concurrently \"npm run css:watch\" \"npm run css:watch:admin\" \"nodemon src/server.js\"",
    "start": "node src/server.js",
    "build": "npm run css:build:all",
    "heroku-postbuild": "npm run css:build:all",
    "emails:consigne:reminders": "node src/jobs/sendConsigneReminders.js",
    "seed": "node src/seed/seedProducts.js",
    "import:woo:dry": "node src/seed/importWooProductsFromCsv.js",
    "import:woo": "node src/seed/importWooProductsFromCsv.js --apply",
    "categories:setup:dry": "node src/seed/setupPartCategories.js",
    "categories:setup": "node src/seed/setupPartCategories.js --apply",
    "categories:reclassify:dry": "node src/seed/reclassifyProductCategories.js",
    "categories:reclassify": "node src/seed/reclassifyProductCategories.js --apply",
    "migrate:wp-images": "node scripts/migrate-wp-images.js",
    "migrate:order-statuses:dry": "node scripts/migrate-order-statuses.js",
    "migrate:order-statuses": "node scripts/migrate-order-statuses.js --apply",
    "migrate:wp-images:dry": "node scripts/migrate-wp-images.js --dry-run",
    "migrate:files-to-mongodb:dry": "node scripts/migrate-files-to-mongodb.js",
    "migrate:files-to-mongodb": "node scripts/migrate-files-to-mongodb.js --apply",
    "import:ovoko:dry": "node src/seed/importOvokoVehicleMakes.js --limitMakes=25",
    "import:ovoko": "node src/seed/importOvokoVehicleMakes.js --apply",
    "import:ovoko:urls:dry": "node src/seed/importOvokoVehicleMakesFromUrlsFile.js --input=src/seed/ovoko-make-model-urls.json --limitMakes=25",
    "import:ovoko:urls": "node src/seed/importOvokoVehicleMakesFromUrlsFile.js --input=src/seed/ovoko-make-model-urls.json --apply",
    "cleanup:vehicle-models:dry": "node src/seed/cleanupVehicleMakeModelNames.js",
    "cleanup:vehicle-models": "node src/seed/cleanupVehicleMakeModelNames.js --apply",
    "css:build:admin": "npx tailwindcss -c tailwind.config.admin.js -i src/styles/admin.css -o public/admin/style.css --minify",
    "css:build:all": "npm run css:build && npm run css:build:admin",
    "css:watch:admin": "npx tailwindcss -c tailwind.config.admin.js -i src/styles/admin.css -o public/admin/style.css --watch"
  },
  "dependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.27",
    "compression": "^1.7.4",
    "connect-mongo": "^5.1.0",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "mongoose": "^8.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.15.2",
    "postcss": "^8.5.8",
    "qrcode": "^1.5.4",
    "sanitize-html": "^2.13.1",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.9"
  }
}
